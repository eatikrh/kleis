define my_paper = arxiv_paper(
    paper_title,
    paper_authors,
    paper_affiliations,
    paper_abstract,
    paper_keywords,
    [
        sec_intro,
        sec_formulas,
        sec_numerical,
        subsec_deflection,
        fig_deflection,
        subsec_magnification,
        fig_magnification,
        sec_axiomatic,
        sec_discussion,
        subsec_observational,
        fig_einstein_comparison,
        subsec_epistemic,
        subsec_kernel_class,
        subsec_kernel_selection,
        subsec_coupling,
        subsec_falsification,
        subsec_binary_lensing,
        sec_conclusion,
        ref_pot, ref_mistele, ref_ciotti, ref_nfw, ref_bullet, ref_kleis, ref_slacs, ref_cassini
    ]
)

// =============================================================================
// COMPILE
// =============================================================================

example "compile" {
    let typst_output = compile_arxiv_paper(my_paper) in
    out(typst_raw(typst_output))
}
