// =============================================================================
// POT vs GR: Gravitational Lensing Predictions
// =============================================================================
//
// A machine-verified paper: axioms, numerics, diagrams, and typesetting
// from a single reproducible source.
//
// All diagram data is computed from physical constants — no hardcoded values.
//
// Compile:
//   kleis test --raw-output --example compile \
//       theories/pot_gr_lensing_paper.kleis > pot_lensing_paper.typ
//   typst compile pot_lensing_paper.typ pot_lensing_paper.pdf
//
// =============================================================================

import "stdlib/prelude.kleis"
import "stdlib/templates/arxiv_paper.kleis"

// =============================================================================
// PHYSICAL CONSTANTS
// =============================================================================

define G_N = 6.674 * pow(10.0, -11.0)
define c_light = 2.998 * pow(10.0, 8.0)
define c2 = c_light * c_light
define M_sun = 1.989 * pow(10.0, 30.0)
define kpc = 3.086 * pow(10.0, 19.0)
define Gpc = 3.086 * pow(10.0, 25.0)
define r2a = 180.0 * 3600.0 / pi()

define v_flat = 220000.0
define v2 = v_flat * v_flat
define M_halo = 1.5 * pow(10.0, 12.0) * M_sun
define M_bary = 6.0 * pow(10.0, 10.0) * M_sun
define sigma2 = v2 / 2.0
define mu_pot = v2 / G_N

define D_L = 1.0 * Gpc
define D_S = 2.0 * Gpc
define D_LS = 1.0 * Gpc

// Deflection formulas
define alpha_sis_val = 4.0 * pi() * sigma2 / c2
define alpha_pot_val = 4.0 * v2 / c2
define alpha_sis_arcsec = alpha_sis_val * r2a
define alpha_pot_arcsec = alpha_pot_val * r2a

// Pre-computed constant for GR point mass: α(b_kpc) = C_halo / b_kpc
define C_halo = 4.0 * G_N * M_halo * r2a / (c2 * kpc)

// Einstein ring radii in arcsec
define tE_sis_arcsec = alpha_sis_val * D_LS / D_S * r2a
define tE_pot_arcsec = alpha_pot_val * D_LS / D_S * r2a

// =============================================================================
// COMPUTED DIAGRAM DATA (every value from physical constants)
// =============================================================================

define bs = [2.0, 5.0, 10.0, 20.0, 50.0, 80.0, 100.0, 150.0, 200.0, 300.0, 500.0]

define alpha_halo_data = list_map(lambda b . C_halo / b, bs)
define alpha_sis_data = list_map(lambda b . alpha_sis_arcsec, bs)
define alpha_pot_data = list_map(lambda b . alpha_pot_arcsec, bs)

// Magnification data: source offsets in Einstein ring units
define us_inner = [0.05, 0.1, 0.2, 0.3, 0.5, 0.7, 1.0]
define us_outer = [1.0, 1.5, 2.0, 3.0, 5.0, 8.0]

// Point mass: μ(u) = (u² + 2) / (u √(u² + 4)) — valid for all u > 0
define us_all = [0.05, 0.1, 0.2, 0.3, 0.5, 0.7, 1.0, 1.5, 2.0, 3.0, 5.0, 8.0]
define mag_pm_data = list_map(lambda u . (u * u + 2.0) / (u * sqrt(u * u + 4.0)), us_all)

// Constant-deflection (SIS & POT): two-image regime (u < 1): μ = 2/u
define mag_cd_inner = list_map(lambda u . 2.0 / u, us_inner)
// Single-image regime (u ≥ 1): μ = 1 + 1/u
define mag_cd_outer = list_map(lambda u . 1.0 + 1.0 / u, us_outer)

// =============================================================================
// OBSERVATIONAL COMPARISON DATA: Einstein radii across velocity dispersions
// =============================================================================
// SLACS survey covers σ ≈ 150–350 km/s. We compute θ_E for both theories
// at each σ, using the same lens geometry (D_L=1 Gpc, D_S=2 Gpc, D_LS=1 Gpc).
// v_flat = σ√2 (SIS relation).

define sigma_values_kms = [150.0, 180.0, 200.0, 220.0, 250.0, 280.0, 300.0, 320.0, 350.0]

define tE_sis_survey = list_map(lambda s .
    let sig = s * 1000.0 in
    let sig2 = sig * sig in
    4.0 * pi() * sig2 / c2 * D_LS / D_S * r2a,
    sigma_values_kms)

define tE_pot_survey = list_map(lambda s .
    let sig = s * 1000.0 in
    let v2_local = 2.0 * sig * sig in
    4.0 * v2_local / c2 * D_LS / D_S * r2a,
    sigma_values_kms)

// =============================================================================
// METADATA
// =============================================================================

define paper_title = "Gravitational Lensing Predictions of Projected Ontology Theory: Numerical and Axiomatic Comparison with General Relativity"

define paper_authors = [Author("Engin Atik", "1")]
define paper_affiliations = [Affiliation(1, "Kleis Research", "https://kleis.io")]

define paper_abstract = "Projected Ontology Theory (POT) predicts that the gravitational lensing deflection angle for any isolated galaxy satisfies $alpha >= 4 v^2_(\"flat\") slash c^2$, where the bound is saturated by the minimal admissible kernel. General Relativity with a Singular Isothermal Sphere (SIS) dark matter halo predicts $alpha_(\"SIS\") = 4 pi sigma^2 slash c^2 = 2 pi v^2_(\"flat\") slash c^2$. The two theories therefore differ by at least a factor of $pi slash 2 approx 1.57$ — a prediction in principle testable with current galaxy-galaxy weak lensing surveys, particularly for isolated disk galaxies with measured flat outer rotation curves. The deflection formula is derived from three ingredients: a kernel-geometry coupling axiom (the Green kernel in three spatial dimensions produces a $1 slash r$ potential), a scalar isotropy theorem (the coherence function is scalar-valued, forcing the PPN parameter $gamma = 1$), and the equivalence principle (geodesic motion in the kernel-induced metric). Of these, the coupling axiom is motivated by the dimensionality of the projection space, $gamma = 1$ is derived from the scalar structure of the coherence function, and the equivalence principle is shared with GR. We verify the ratio numerically: for a Milky Way-like galaxy ($v_(\"flat\") = 220$ km/s), the minimal POT kernel gives $alpha = 0.44$ arcsec while GR+SIS gives $0.70$ arcsec. Einstein ring radii differ by the same factor, producing measurably different magnification profiles at fixed source position. Both models produce constant deflection in the outer region ($M prop r$), but the physical origin differs: GR integrates a three-dimensional halo along the line of sight, introducing a geometric $pi$ factor absent in POT, where projected mass is ontologically primary. Moreover, within the admissible class, exact asymptotic flatness of the rotation curve selects the $1 slash r$ kernel; observed approximately flat outer curves constrain the kernel to lie near that limit, making the $pi slash 2$ ratio an exact prediction in the mathematical limit and a tightly constrained one in practice. All numerical values are computed by the Kleis evaluator, axiomatic claims are Z3-checked for satisfiability (model consistency, not formal proof), and every diagram data point is calculated from physical constants. This paper is produced entirely from a single Kleis source file."

define paper_keywords = "gravitational lensing, dark matter, projected ontology, rotation curves, Tully-Fisher, Z3 verification"

// =============================================================================
// SECTION 1: Introduction
// =============================================================================

define sec_intro = ArxivSection("Introduction",
"Flat galactic rotation curves present one of the most persistent puzzles in modern physics. General Relativity, when applied to the observed distribution of luminous matter, predicts Keplerian decline ($v prop 1 slash sqrt(r)$) beyond the visible disk, contradicting the observed flat profiles ($v approx \"const\"$) extending to hundreds of kiloparsecs. The standard resolution invokes dark matter halos with density $rho(r) prop 1 slash r^2$, yielding enclosed mass $M(r) prop r$ and thus flat rotation curves.

Projected Ontology Theory (POT) derives the same linear mass growth — $M(r) = mu r$ with $mu = v^2_(\"flat\") slash G$ — not from invisible matter, but from structural properties of admissible Green's kernels in a projected ontological framework. Within the admissible kernel class and under the isolated-galaxy assumptions, the flat rotation curve follows as a _theorem_ rather than a phenomenological fit.

Both theories predict linear mass growth in the outer region. But lensing, which probes the _projected_ mass distribution, reveals a quantitative difference. GR requires projecting a three-dimensional density profile onto the lens plane, introducing a geometric factor. POT works directly with projected mass. The resulting $pi slash 2$ ratio is not a numerical fit or heuristic; it is analytic knowledge conditional on the stated mass profiles. The remaining question is whether nature selects those assumptions. This paper derives the ratio, identifies observationally testable predictions, and marks explicitly where the analytic result ends and the physical claim begins.

*Declared assumptions.* Throughout this paper we assume: (1) the weak-field thin-lens approximation ($alpha << 1$ radian), valid for all cases computed here; (2) circular symmetry of the lens; (3) for GR+SIS, the relation $sigma^2 = v^2_(\"flat\") slash 2$, which is exact for an idealized Singular Isothermal Sphere; (4) a specific lensing geometry with $D_L = 1$ Gpc, $D_S = 2$ Gpc; (5) Milky Way-like parameters $v_(\"flat\") = 220$ km/s; (6) for POT, the minimal admissible kernel $h(G, r) = kappa slash r$ (boundary case of Axiom A5). See Section 5.6 for discussion of other admissible kernels. All numerical values are computed by the Kleis evaluator from these inputs. Axiomatic claims are checked for Z3 consistency (satisfiability), not formally derived. The GR geometric foundations — Schwarzschild metric, connection, curvature, and vacuum Einstein equations $R_(mu nu) = 0$ — are DERIVED (not axiomatized) via the Cartan formalism in the companion file `gr_cartan_v1.kleis`, which computes the full pipeline: Metric → Tetrad → Connection → Curvature → Ricci, under four declared physical assumptions (4D spacetime, Lorentzian signature, torsion-free and metric-compatible connection). Energy conditions for dust, radiation, dark energy, and stiff matter are Z3-derived in `gr_cartan_v2.kleis` from declared equations of state.")

// =============================================================================
// SECTION 2: Lensing Formulas
// =============================================================================

define sec_formulas = ArxivSection("Deflection Angle Formulas",
"For an axially symmetric lens in the weak-field thin-lens regime, the deflection angle at impact parameter $b$ is

$ alpha(b) = (4 G M(b)) / (c^2 b) $

where $M(b)$ is the projected (2D) mass enclosed within radius $b$.

*GR point mass.* For a point mass $M_0$, $M(b) = M_0$ is constant, giving $alpha_(\"point\") = 4 G M_0 slash (c^2 b)$, which falls as $1 slash b$.

*GR + SIS dark matter halo.* A Singular Isothermal Sphere with velocity dispersion $sigma$ has 3D density $rho(r) = sigma^2 slash (2 pi G r^2)$. Projecting along the line of sight:

$ Sigma(xi) = sigma^2 / (2 G xi), quad M_(\"2D\")(b) = (pi sigma^2 b) / G $

This gives _constant_ deflection:

$ alpha_(\"SIS\") = (4 pi sigma^2) / c^2 $

*POT.* The projected mass is the fundamental quantity: $M(b) = mu b = v^2_(\"flat\") b slash G$. The deflection formula follows from three ingredients (formalized in the companion file `pot_kernel_geometry_coupling.kleis`): (A1) the Green kernel operates in three spatial dimensions, so the kernel-mediated potential is $Phi(r) = -G M(r) slash r$ — the $1 slash r$ form follows from the dimensionality of the projection space $bb(R)^4$; (T1) the coherence function $h(G, r)$ is scalar-valued ($bb(R) arrow bb(R)$), so the metric perturbation is the same in all components, giving PPN parameter $gamma = 1$; (A2) the equivalence principle — light follows null geodesics in the kernel-induced metric. Together: $alpha = (1 + gamma) dot 2 G M(b) slash (c^2 b) = 4 G M(b) slash (c^2 b)$. With $M(b) = mu b$:

$ alpha_(\"POT\") = (4 G mu b) / (c^2 b) = (4 v^2_(\"flat\")) / c^2 $

also constant, but different from SIS. Using $sigma^2 = v^2 slash 2$ (exact for SIS):

$ alpha_(\"SIS\") / alpha_(\"POT\") = (4 pi v^2 slash (2 c^2)) / (4 v^2 slash c^2) = pi / 2 approx 1.5708 $

This factor of $pi slash 2$ is the _geometric cost of 3D-to-2D projection_ in GR: the line-of-sight integration of $rho prop 1 slash r^2$ introduces a factor of $pi$ in the projected mass. POT bypasses this because projected mass is ontologically primary.")

// =============================================================================
// SECTION 3: Numerical Results (with diagrams)
// =============================================================================

define sec_numerical = ArxivSection("Numerical Results",
"We compute lensing observables for a Milky Way-like galaxy ($v_(\"flat\") = 220$ km/s, baryonic mass $M_b = 6 times 10^(10) M_dot.o$, DM halo mass $M_h = 1.5 times 10^(12) M_dot.o$) with a typical strong-lensing geometry: lens at $D_L = 1$ Gpc, source at $D_S = 2$ Gpc, $D_(L S) = 1$ Gpc. All values below are computed from these inputs by the Kleis evaluator.")

define subsec_deflection = ArxivSubsection("Deflection Angles",
"At a fiducial impact parameter $b = 10$ kpc, Kleis computes:

- GR point mass (baryonic): $alpha = 0.24$ arcsec
- GR point mass (DM halo): $alpha = 5.92$ arcsec
- GR + SIS: $alpha = 0.70$ arcsec (constant for all $b$)
- POT: $alpha = 0.44$ arcsec (constant for all $b$)

The GR point-mass deflection falls as $1 slash b$, dropping below the SIS/POT constant values at large radii. Figure 1 shows the deflection profile, with every data point computed from the formula $alpha = 4 G M slash (c^2 b)$ applied to the respective mass model.")

define fig_deflection = ArxivDiagram("fig:deflection", "Deflection angle $alpha$ vs impact parameter $b$ for three mass models. GR point mass (red) falls as $1 slash b$; GR+SIS (blue) and POT (green) are constant but differ by $pi slash 2$. All data points computed from physical constants.",
    export_typst_fragment(
        plot(bs, alpha_halo_data,
             color = "red", label = "GR point mass (DM halo)", mark = "o", mark_size = 3),
        plot(bs, alpha_sis_data,
             color = "blue", label = "GR + SIS", stroke = "2pt"),
        plot(bs, alpha_pot_data,
             color = "green", label = "POT", stroke = "2pt"),
        title = "Deflection Angle vs Impact Parameter",
        xlabel = "Impact parameter b (kpc)",
        ylabel = "Deflection α (arcsec)",
        legend_position = "right + top",
        width = 10,
        yscale = "log"
    )
)

define subsec_magnification = ArxivSubsection("Magnification",
"For a circularly symmetric lens, the magnification has radial and tangential components:

$ mu = 1 / (|1 - d alpha slash d theta| dot |1 - alpha slash theta|) $

*GR point mass.* With $alpha(theta) = theta_E^2 slash theta$, the total magnification (summing both images) is

$ mu_(\"pm\") = (u^2 + 2) / (u sqrt(u^2 + 4)) $

where $u = beta slash theta_E$ is the source offset in Einstein ring units. This diverges as $u arrow 0$ (caustic).

*Constant-deflection lens (SIS and POT).* With $alpha(theta) = theta_E$ (constant), $d alpha slash d theta = 0$, so $mu_r = 1$. But $mu_t = theta slash (theta - theta_E)$ diverges at $theta = theta_E$. In terms of $u = beta slash theta_E$:

- Primary image ($theta = beta + theta_E$): $mu_1 = 1 + 1 slash u$
- Secondary image ($theta = beta - theta_E$, exists for $u < 1$): $mu_2 = 1 slash u - 1$
- Total: $mu = 2 slash u$ for $u < 1$; $mu = 1 + 1 slash u$ for $u >= 1$

*Both* SIS and POT produce caustics with divergent magnification at their Einstein rings. The functional form is identical; only the Einstein ring radius differs by a factor of $pi slash 2$. At the same physical source offset $beta$, POT has a larger $u$ (by $pi slash 2$) and hence _weaker_ magnification.

Figure 2 compares the magnification profiles. The constant-deflection lens produces _higher_ magnification than a point mass at the same $u$, because the uniform deflection field focuses light more efficiently in the tangential direction.")

define fig_magnification = ArxivDiagram("fig:magnification", "Magnification $mu$ vs source offset $u = beta slash theta_E$. Red: GR point-mass lens. Blue: constant-deflection lens ($M prop r$, shared by SIS and POT). The constant-deflection magnification has two regimes, separated at $u = 1$ (the Einstein ring): inside ($u < 1$) the source is strongly lensed, outside ($u >= 1$) the magnification drops smoothly. Both models diverge as $u arrow 0$ (perfect source-lens alignment). At equal $u$, the constant-deflection model yields higher magnification. All data points computed by the Kleis evaluator.",
    export_typst_fragment(
        plot(us_all, mag_pm_data,
             color = "red", label = "GR point mass", stroke = "2pt", mark = "o", mark_size = 3),
        plot(us_inner, mag_cd_inner,
             color = "blue", label = "Constant defl. (u < 1)", stroke = "2pt"),
        plot(us_outer, mag_cd_outer,
             color = "blue", label = "Constant defl. (u >= 1)", stroke = "2pt"),
        title = "Magnification vs Source Offset",
        xlabel = "Source offset u = β/θ_E",
        ylabel = "Magnification μ",
        legend_position = "right + top",
        width = 10,
        yscale = "log"
    )
)

// =============================================================================
