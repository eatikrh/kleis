// =============================================================================
// Assemble Paper
// =============================================================================

define all_elements = [
    // Introduction
    sec_intro,

    // The Argument (with subsections)
    sec_argument, subsec_step1, subsec_step2, subsec_step3, subsec_step4, subsec_step5,

    // Relation to Prior Work
    sec_prior, subsec_prior_hp, subsec_prior_this,

    // Discretization Convergence
    sec_convergence, subsec_conv_identity, subsec_conv_connes, subsec_conv_approx, subsec_conv_chain,

    // Formal Verification
    sec_verification,

    // Conclusion
    sec_conclusion,

    // References
    ref_berry, ref_connes, ref_bbm, ref_kalman, ref_comb, ref_proof, ref_selberg,
    ref_horn, ref_hp, ref_sierra, ref_bbm_critique,
    ref_keller, ref_stummel, ref_chatelin, ref_kato, ref_szego, ref_bolte,
    ref_kleis
]

define my_paper = arxiv_paper(
    paper_title,
    paper_authors,
    paper_affiliations,
    paper_abstract,
    paper_keywords,
    all_elements
)

example "compile" {
    let typst_output = compile_arxiv_paper(my_paper) in
    out(typst_raw(typst_output))
}

example "validate" {
    assert(valid_arxiv_paper(my_paper) = true)
    out("Paper is valid!")
}
