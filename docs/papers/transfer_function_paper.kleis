define ref_kalman = ArxivReference("4", "R. E. Kalman, 'A new approach to linear filtering and prediction problems,' _Journal of Basic Engineering_ 82 (1960), 35–45. See also Kalman, 'Mathematical description of linear dynamical systems,' _SIAM J. Control_ 1 (1963), 152–192.")

define ref_comb = ArxivReference("5", "E. Atik, 'The spectral comb: antisymmetric operator architecture for the Riemann zeta zeros,' preprint, Kleis Research (2026).")

define ref_proof = ArxivReference("6", "E. Atik, 'The spectral comb and the Riemann Hypothesis: a proof via fixed-point theory,' preprint, Kleis Research (2026).")

define ref_selberg = ArxivReference("7", "E. Atik, 'Universality of the spectral comb across the Selberg class: numerical evidence from GL(1) through GL(3),' preprint, Kleis Research (2026).")

define ref_horn = ArxivReference("8", "R. A. Horn and C. R. Johnson, _Matrix Analysis_, 2nd ed., Cambridge University Press (2013).")

define ref_hp = ArxivReference("9", "The Hilbert–Pólya conjecture is attributed to conversations of Hilbert (c. 1914) and Pólya (c. 1950s). See E. Bombieri, 'Problems of the millennium: the Riemann Hypothesis,' Clay Mathematics Institute (2000).")

define ref_sierra = ArxivReference("10", "G. Sierra, 'The Riemann zeros and the cyclic renormalization group,' _Journal of Statistical Mechanics_ (2005), P006.")

define ref_bbm_critique = ArxivReference("11", "See the discussion following [3] in the mathematical physics literature, particularly regarding the domain and boundary conditions of the proposed operator.")

define ref_keller = ArxivReference("12", "H. B. Keller, 'On the accuracy of finite difference approximations to the eigenvalues of differential and integral operators,' _Numerische Mathematik_ 7 (1965), 412–419.")

define ref_stummel = ArxivReference("13", "F. Stummel, 'Diskrete Konvergenz linearer Operatoren,' _Mathematische Annalen_ 190 (1970), 45–92.")

define ref_chatelin = ArxivReference("14", "F. Chatelin, _Spectral Approximation of Linear Operators_, Academic Press (1983).")

define ref_kato = ArxivReference("15", "T. Kato, _Perturbation Theory for Linear Operators_, 2nd ed., Springer (1995).")

define ref_szego = ArxivReference("16", "G. Szegö, 'On certain Hermitian forms associated with the Fourier series of a positive function,' _Communications du Séminaire Mathématique de l'Université de Lund_, Tome Supplémentaire (1952), 228–238.")

define ref_bolte = ArxivReference("17", "J. Bolte, S. Egger, and S. Keppeler, 'A Berry–Keating operator on a lattice,' _Journal of Physics A_ 50 (2017), 105201.")

