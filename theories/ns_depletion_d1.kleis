// D1: Effective stretching rate directly bounded at a+b=2 level
// σ_eff² ≤ P/Ω  ⟹  S² = Ω²·σ_eff² ≤ Ω·P  (a+b = 2)
// Expect: UNSAT (this is the alignment axiom from Paper 1, reframed)

structure NS_Depletion_DirectBound {
    element Omega : ℝ
    element P : ℝ
    element S : ℝ
    element dOmega_dt : ℝ
    element sigma_eff : ℝ

    axiom Omega_pos : Omega > 0
    axiom P_pos : P > 0
    axiom S_nonneg : S ≥ 0
    axiom sigma_nonneg : sigma_eff ≥ 0

    axiom stretching_def : S = times(Omega, sigma_eff)

    // Ω·σ_eff² ≤ P  (equiv. σ_eff² ≤ P/Ω)
    axiom sigma_bound : times(Omega, times(sigma_eff, sigma_eff)) ≤ P

    axiom poincare : P ≥ Omega
    axiom enstrophy_eq : dOmega_dt = plus(S, negate(times(2, P)))
    axiom large_omega : Omega > 10
    axiom growth : dOmega_dt > 0
}

example "D1: σ_eff² ≤ P/Ω → S² ≤ Ω·P (a+b=2, expect UNSAT)" {
    assert(dOmega_dt > 0)
}
