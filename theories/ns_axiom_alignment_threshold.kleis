// Alignment threshold test: ν = 1/2 exactly.
//
// The critical condition is 1 > 4ν².
// At ν = 1/2: 4·(1/4) = 1, so 1 > 1 is FALSE. → UNSAT expected.
// This is the exact threshold where alignment closes the gap.

structure NS_Alignment_Threshold {
    element Omega : ℝ
    element P : ℝ
    element S : ℝ
    element dOmega_dt : ℝ

    axiom Omega_pos : Omega > 0
    axiom P_pos : P > 0
    axiom S_nonneg : S ≥ 0

    // enstrophy equation with ν = 1/2: dΩ/dt = S - 2·(1/2)·P = S - P
    axiom enstrophy_eq : dOmega_dt = plus(S, negate(P))

    axiom poincare : P ≥ Omega
    axiom alignment : times(S, S) ≤ times(Omega, P)
    axiom large_omega : Omega > 10

    axiom growth : dOmega_dt > 0
}

example "Alignment at ν=1/2 threshold: growth? (expect UNSAT)" {
    assert(dOmega_dt > 0)
}
