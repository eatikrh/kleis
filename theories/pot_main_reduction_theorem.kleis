//                 §7  PROGRAM COROLLARY
//
// =============================================================================

example "MAIN REDUCTION THEOREM: human-readable statement" {
    out("══════════════════════════════════════════════════════════")
    out("  MAIN REDUCTION THEOREM")
    out("══════════════════════════════════════════════════════════")
    out("")
    out("CONDITIONAL SPECTRAL THEOREM.")
    out("  Assume A, B, C, D.  Then the radial SL sector has a")
    out(format("  positive gap of size {:.4} * s^{{2/3}}.", airy_constant))
    out("")
    out("FULL REDUCTION.")
    out("  Assume additionally E.  Then 4D Yang-Mills has a")
    out("  positive mass gap m = D(L) > 0.")
    out("")
    out("──────────────────────────────────────────────────────────")
    out("")
    out("DEPENDENCY DECOMPOSITION:")
    out("  A supplies only sign(g) > 0    [physics, Level C+]")
    out("  B identifies kernel = Green's function   [Level A/B]")
    out("  C gives asymptotic regularity  [Level A/B]")
    out("  D converts kernel growth to potential growth  [A/B]")
    out("  E supplies 4D QFT existence + radial bridge  [C/D]")
    out("")
    out("PROVEN MATHEMATICAL CORE:")
    out(format("  B:  Level A/B  ({:.1})", level_B))
    out(format("  C:  Level A/B  ({:.1})", level_C))
    out(format("  D:  Level A/B  ({:.1})", level_D))
    out("  Chain backbone:  Level A  (algebraic + Rellich-Molchanov)")
    out("")
    out("EXTERNAL INPUTS:")
    out(format("  A (sign):  Level B/C  ({:.1})", level_A_sign))
    out(format("  E (QFT):   Level C/D  ({:.1})", level_E_combined))
    out("")
    out("GAP FORMULA:")
    out(format("  At g = {:.1}:  D = s^{{2/3}} * {:.4}", gamma_ym, airy_constant))
    out("  (Airy scaling, Level A for the formula itself)")
    out("")
    out("──────────────────────────────────────────────────────────")
    out("")
    out("HONEST SCOPE STATEMENT:")
    out("")
    out("  This does NOT solve the Clay Millennium Problem.")
    out("  E contains the unresolved existence/consistency")
    out("  problem for 4D Yang-Mills (Level D), and A remains")
    out("  an external physics input (Level C+).")
    out("")
    out("  The contribution is the reduction itself:")
    out("  a rigorous scaffold that converts two sharply stated")
    out("  external inputs into a mass gap.")
    out("")
    out("THE PUBLISHABLE CLAIM:")
    out("  The 14-file program proves a conditional reduction")
    out("  of the Yang-Mills mass-gap problem to two external")
    out("  inputs: A and E.")
}

