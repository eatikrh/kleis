// ─────────────────────────────────────────────────────────────────────────────
// §3  E1: EXISTENCE (Wightman/Osterwalder–Schrader)
// ─────────────────────────────────────────────────────────────────────────────
//
// The Wightman axioms for a quantum field theory on R⁴ require:
//
//   W1. HILBERT SPACE:
//     A separable Hilbert space H with a distinguished vacuum Ω.
//
//   W2. POINCARÉ COVARIANCE:
//     A continuous unitary representation U(a,Λ) of the Poincaré
//     group on H, with U(a,Λ)Ω = Ω.
//
//   W3. SPECTRAL CONDITION:
//     The joint spectrum of the energy-momentum operators (H,P)
//     is contained in the closed forward light cone V₊.
//     In particular: H ≥ 0 (positivity of energy).
//
//   W4. LOCALITY:
//     Fields at spacelike-separated points commute (or anti-commute
//     for fermions):  [φ(x), φ(y)] = 0 for (x-y)² < 0.
//
//   W5. COMPLETENESS:
//     The polynomials in the field operators applied to Ω are
//     dense in H (cyclicity of the vacuum).
//
// The Osterwalder–Schrader (OS) axioms are the Euclidean equivalent:
//   OS0 (temperedness), OS1 (Euclidean covariance), OS2 (reflection
//   positivity), OS3 (symmetry), OS4 (cluster property).
//
// OS reconstruction theorem (Osterwalder–Schrader, 1973–75):
//   OS axioms ⟹ Wightman axioms  (under technical conditions).
//
// For Yang–Mills: NO construction satisfying either set is known in 4D.
//
// ─────────────────────────────────────────────────────────────────────────────

structure WightmanAxioms {
    element W1_hilbert : ℝ
    element W2_poincare : ℝ
    element W3_spectral : ℝ
    element W4_locality : ℝ
    element W5_completeness : ℝ

    element axioms_count : ℝ

    axiom w1 : W1_hilbert = 1
    axiom w2 : W2_poincare = 1
    axiom w3 : W3_spectral = 1
    axiom w4 : W4_locality = 1
    axiom w5 : W5_completeness = 1
    axiom count : axioms_count = 5
}

structure OSAxioms {
    element OS0_tempered : ℝ
    element OS1_covariance : ℝ
    element OS2_reflection_pos : ℝ
    element OS3_symmetry : ℝ
    element OS4_cluster : ℝ

    axiom os0 : OS0_tempered = 1
    axiom os1 : OS1_covariance = 1
    axiom os2 : OS2_reflection_pos = 1
    axiom os3 : OS3_symmetry = 1
    axiom os4 : OS4_cluster = 1
}

example "§3.1: Wightman axioms — five conditions (Z3)" {
    assert(axioms_count = 5)
    assert(W1_hilbert = 1)
    assert(W3_spectral = 1)
    assert(W4_locality = 1)
}

example "§3.2: OS axioms — Euclidean counterpart (Z3)" {
    assert(OS2_reflection_pos = 1)
    assert(OS4_cluster = 1)
}


// ─────────────────────────────────────────────────────────────────────────────
// §4  E2: CONSISTENCY (Gauge Invariance + Hilbert Space)
// ─────────────────────────────────────────────────────────────────────────────
//
// The Wightman axioms assume a Hilbert space H with positive-definite
// inner product.  In non-abelian gauge theory, this is non-trivial
// because:
//
//   PROBLEM 1 (GRIBOV):
//     The Landau gauge condition ∂·A = 0 does not uniquely fix the
//     gauge — there are Gribov copies.  Different copies give
//     different functional integrals.  The path integral is therefore
//     not well-defined without restriction to a fundamental modular
//     domain (Gribov region or its refinement, the first Gribov
//     horizon).
//
//   PROBLEM 2 (BRST):
//     Perturbative gauge invariance is encoded by BRST symmetry:
//     physical states are BRST cohomology classes.  But:
//     - BRST symmetry may be BROKEN non-perturbatively (Neuberger, 1987)
//     - The Kugo–Ojima confinement criterion (which assumes unbroken
//       BRST) is not proven in the non-perturbative regime
//     - Without BRST, the construction of H_phys is unclear
//
//   PROBLEM 3 (POSITIVITY):
//     The Euclidean correlators must satisfy reflection positivity (OS2)
//     to reconstruct a Hilbert space.  But: lattice measurements show
//     the gluon propagator VIOLATES positivity (Cucchieri et al., 2004),
//     suggesting confined gluons are NOT physical particles.  This is
//     consistent with confinement but complicates the axiom framework.
//
// WHAT E2 REQUIRES:
//   A rigorous construction of H_phys for 4D YM, with the Hamiltonian
//   self-adjoint on H_phys.  The physical spectrum lives in H_phys.
//
// ─────────────────────────────────────────────────────────────────────────────

structure GaugeConsistency {
    element gribov_resolved : ℝ       // 0 = not resolved
    element brst_nonpert : ℝ          // 0 = not proven non-perturbatively
    element positivity_physical : ℝ   // 0 = not established for physical states
    element H_phys_constructed : ℝ    // 0 = physical Hilbert space not built

    axiom g : gribov_resolved = 0
    axiom b : brst_nonpert = 0
    axiom p : positivity_physical = 0
    axiom h : H_phys_constructed = 0
}

example "§4.1: gauge consistency — all sub-problems open (Z3)" {
    assert(gribov_resolved = 0)
    assert(brst_nonpert = 0)
    assert(H_phys_constructed = 0)
}


// ─────────────────────────────────────────────────────────────────────────────
// §5  E3: RENORMALIZABILITY (Non-perturbative Continuum Limit)
// ─────────────────────────────────────────────────────────────────────────────
//
// PERTURBATIVE RENORMALIZABILITY:
//   Proven by 't Hooft–Veltman (1971, Nobel Prize 1999).
//   YM is perturbatively renormalizable to all orders in g.
//   This is Level A (theorem).
//
// ASYMPTOTIC FREEDOM:
//   Proven by Gross–Wilczek and Politzer (1973, Nobel Prize 2004).
//   The YM coupling g(μ) → 0 as μ → ∞ (UV).
//   Consequence: the UV behavior is under perturbative control.
//   This is Level A (theorem).
//
// NON-PERTURBATIVE CONTINUUM LIMIT:
//   The Wilson lattice action (1974) provides a RIGOROUS definition
//   of YM on a finite lattice Λ with spacing a.
//   The theory is well-defined for any finite Λ and a > 0.
//
//   The continuum limit requires:
//     (i)   a → 0 (continuum)
//     (ii)  L → ∞ (infinite volume)
//     (iii) the limit satisfies Wightman/OS axioms
//
//   What is known:
//     Balaban (1984–89): constructed the continuum limit for 3D YM
//     on a torus, with rigorous functional integral bounds.
//     This is the deepest existing constructive result.
//
//     4D: no analogous construction exists.
//     The difficulty is controlling the IR (strong coupling) regime
//     while taking a → 0.  Asymptotic freedom helps in UV but
//     says nothing about IR.
//
// WHAT E3 REQUIRES:
//   The lattice YM theory has a non-perturbative continuum limit
//   that defines a Euclidean QFT satisfying OS axioms.
//
// ─────────────────────────────────────────────────────────────────────────────

structure Renormalizability {
    // Proven results (Level A)
    element pert_renorm : ℝ         // 1 = perturbative renormalizability
    element asymptotic_free : ℝ     // 1 = asymptotic freedom
    element lattice_defined : ℝ     // 1 = well-defined on finite lattice

    // Open problems
    element continuum_4d : ℝ        // 0 = 4D continuum limit not proven
    element infinite_volume : ℝ     // 0 = infinite-volume limit not proven

    axiom pr : pert_renorm = 1
    axiom af : asymptotic_free = 1
    axiom ld : lattice_defined = 1
    axiom c4 : continuum_4d = 0
    axiom iv : infinite_volume = 0
}

structure ConstructiveResults {
    element dim_solved_2d : ℝ       // 2D: exactly solvable (trivial)
    element dim_solved_3d : ℝ       // 3D: Balaban's construction (partial)
    element dim_solved_4d : ℝ       // 4D: open

    axiom d2 : dim_solved_2d = 1
    axiom d3 : dim_solved_3d = 1
    axiom d4 : dim_solved_4d = 0
}

example "§5.1: perturbative results — Level A (Z3)" {
    assert(pert_renorm = 1)
    assert(asymptotic_free = 1)
    assert(lattice_defined = 1)
}

example "§5.2: non-perturbative 4D — open (Z3)" {
    assert(continuum_4d = 0)
    assert(infinite_volume = 0)
}

example "§5.3: constructive QFT frontier — 2D,3D done, 4D open (Z3)" {
    assert(dim_solved_2d = 1)
    assert(dim_solved_3d = 1)
    assert(dim_solved_4d = 0)
}


// ─────────────────────────────────────────────────────────────────────────────
// §6  E4: DIMENSIONAL BRIDGE (4D → 1D Radial Sector)
// ─────────────────────────────────────────────────────────────────────────────
//
// Even assuming E1–E3, the connection between the 4D mass gap m and
// the 1D SL spectral gap Δ is non-trivial.
//
// THE PHYSICAL PICTURE:
//   The gauge-invariant two-point function of the lowest-dimension
//   scalar operator (e.g., Tr F²(x) or the glueball interpolator)
//   has a Källén–Lehmann spectral representation:
//
//       ⟨Tr F²(x) Tr F²(0)⟩ = ∫ ρ(m²) D_m(x) dm²
//
//   where D_m(x) is the free scalar propagator of mass m, and
//   ρ(m²) is the spectral density.  The mass gap is:
//
//       m₀ = inf{ m : ρ(m²) ≠ 0 }
//
// THE BRIDGE:
//   Step 1: Decompose the 4D correlator into radial and angular parts
//           using O(4) partial waves (Euclidean rotation group).
//   Step 2: The s-wave (ℓ=0) radial part involves a Hankel-type
//           transform kernel.
//   Step 3: Identify this radial kernel with the ITCM kernel K(x,y;z).
//   Step 4: The mass gap m₀ is determined by the lowest eigenvalue
//           of the operator L extracted from K.
//
// WHAT E4 REQUIRES:
//   The identification in Step 3 is rigorous: the radial part of the
//   4D two-point function IS the ITCM kernel constructed from the
//   YM weight w_YM(k).
//
// WHY THIS IS NON-TRIVIAL:
//   1. The partial-wave decomposition assumes rotational symmetry,
//      which holds in Euclidean space but requires analytic
//      continuation to Minkowski space.
//   2. The ITCM kernel involves TWO different Hankel orders (μ ≠ ν),
//      which encodes the mismatch between the free and interacting
//      angular structure.  This mismatch must be derived, not assumed.
//   3. The mass gap appears in the LOWEST partial wave.  Higher
//      partial waves contribute to excited states.  The identification
//      of the s-wave gap with the mass gap requires that no lower
//      state appears in other sectors.
//
// ─────────────────────────────────────────────────────────────────────────────

structure DimensionalBridge {
    element dim_source : ℝ       // 4D theory
    element dim_target : ℝ       // 1D SL operator

    element step1_decomposition : ℝ   // partial-wave decomposition
    element step2_radial : ℝ          // s-wave extraction
    element step3_identification : ℝ  // radial kernel = ITCM kernel
    element step4_gap : ℝ             // lowest eigenvalue = mass gap

    axiom ds : dim_source = 4
    axiom dt : dim_target = 1
    axiom s1 : step1_decomposition = 1
    axiom s2 : step2_radial = 1
    axiom s3 : step3_identification = 1
    axiom s4 : step4_gap = 1
}

structure BridgeDifficulties {
    // Three specific difficulties in E4
    element analytic_continuation : ℝ    // Euclidean → Minkowski rotation
    element hankel_order_mismatch : ℝ    // μ ≠ ν must be derived
    element swave_dominance : ℝ          // lowest partial wave = gap

    // All three are open
    axiom ac : analytic_continuation = 0
    axiom hom : hankel_order_mismatch = 0
    axiom sw : swave_dominance = 0
}

example "§6.1: the dimensional bridge — four steps (Z3)" {
    assert(dim_source = 4)
    assert(dim_target = 1)
    assert(minus(dim_source, dim_target) = 3)
}

example "§6.2: bridge difficulties — all three open (Z3)" {
    assert(analytic_continuation = 0)
    assert(hankel_order_mismatch = 0)
    assert(swave_dominance = 0)
}


