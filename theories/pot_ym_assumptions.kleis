    out("  UPGRADE TO A: apply Gel'fand-Levitan to the specific spectral measure")
    out("")
    out("Assumption E (QFT construction):")
    out("  FALSIFIED BY: proof that 4D YM cannot satisfy Wightman axioms")
    out("  UPGRADE TO A: construct 4D YM rigorously (= solve Clay problem)")
    out("  ASSESSMENT: hardest assumption, outside our program's scope")
}

