// D6d: S² ≤ Ω · P  (a+b = 2.0 — critical threshold from Paper 1)
// Expect: UNSAT (Paper 1 proved this is the global basin collapse threshold)

structure NS_Depletion_Exp20 {
    element Omega : ℝ
    element P : ℝ
    element S : ℝ
    element dOmega_dt : ℝ

    axiom Omega_pos : Omega > 0
    axiom P_pos : P > 0
    axiom S_nonneg : S ≥ 0

    axiom stretch_bound : times(S, S) ≤ times(Omega, P)

    axiom poincare : P ≥ Omega
    axiom enstrophy_eq : dOmega_dt = plus(S, negate(times(2, P)))
    axiom large_omega : Omega > 10
    axiom growth : dOmega_dt > 0
}

example "D6d: S² ≤ Ω·P (a+b=2, expect UNSAT)" {
    assert(dOmega_dt > 0)
}
