// =============================================================================
// Kernel Factorization Theory
// =============================================================================
//
// The POT papers use two distinct kernel factorization architectures:
//
//   Architecture 1 (Entanglement, Electrodynamics):
//     K = K_univ ∘ K_dyn ∘ K_rep
//     Three admissible factors: universal geometry, dynamics, representation.
//
//   Architecture 2 (GR Projection Kernel, QFT):
//     Pipeline = K → Q
//     Production kernel K followed by observable projection Q.
//
// Both architectures describe the same process (configuration → observable)
// but decompose it differently. This is non-unique factorization.
//
// Key result: Non-admissibility is an obstruction to factorization into
// admissible components. If the total pipeline is non-admissible,
// it contains an irreducible non-admissible atom. This atom is invariant
// across formulations, but its location in the factorization is not ---
// connecting to the "formulation fiber" from the GR paper.
//
// Literature connections:
//   - Geroldinger & Halter-Koch: non-unique factorization in monoids
//   - Landau example: same LPDO factored into 2 or 3 factors
//   - Categorical (E,M)-factorization: orthogonal → unique, weak → non-unique
//   - Smertnig: transfer homomorphisms in noncommutative rings
//   - Wiener-Hopf: uniqueness conditions for operator factorization
//
// =============================================================================

import "pot_admissible_kernels_v2.kleis"


// =============================================================================
// PART 1: THE KERNEL COMPOSITION MONOID
// =============================================================================
//
// Admissible kernels under composition form a monoid:
//   - Associativity: (K1 ∘ K2) ∘ K3 = K1 ∘ (K2 ∘ K3)
//   - Identity: K ∘ id = id ∘ K = K
//   - Closure: is_admissible(K1) ∧ is_admissible(K2) ⟹ is_admissible(K1 ∘ K2)
//
// The full kernel space (including non-admissible kernels) also forms a monoid
// under composition, but without the admissibility closure property.

structure KernelMonoid {
    element kernel_identity : GreenKernel

    axiom identity_left : ∀(K : GreenKernel).
        compose_kernel(kernel_identity, K) = K

    axiom identity_right : ∀(K : GreenKernel).
        compose_kernel(K, kernel_identity) = K

    axiom compose_assoc : ∀(K1 K2 K3 : GreenKernel).
        compose_kernel(compose_kernel(K1, K2), K3) =
            compose_kernel(K1, compose_kernel(K2, K3))

    axiom identity_admissible : is_admissible(kernel_identity)
}


// =============================================================================
// PART 2: FACTORIZATION STRUCTURES
// =============================================================================
//
// A factorization of kernel K is a decomposition K = K_1 ∘ ... ∘ K_n.
// The factorization length is n. An atom is a kernel that admits no
// non-trivial factorization (no decomposition into non-identity factors).

operation is_atom : GreenKernel -> Bool
operation factorization_length : GreenKernel -> ℤ

structure Factorization {
    axiom identity_not_atom : not(is_atom(kernel_identity))

    axiom atom_def : ∀(K : GreenKernel).
        is_atom(K) ⟹ factorization_length(K) = 1

    axiom identity_length : factorization_length(kernel_identity) = 0

    axiom compose_length : ∀(K1 K2 : GreenKernel).
        factorization_length(compose_kernel(K1, K2)) <=
            factorization_length(K1) + factorization_length(K2)
}

// Two-factor factorization: K = A ∘ B
operation has_two_factorization : GreenKernel -> Bool
operation left_factor : GreenKernel -> GreenKernel
operation right_factor : GreenKernel -> GreenKernel

// Three-factor factorization: K = A ∘ B ∘ C
operation has_three_factorization : GreenKernel -> Bool
operation factor_1 : GreenKernel -> GreenKernel
operation factor_2 : GreenKernel -> GreenKernel
operation factor_3 : GreenKernel -> GreenKernel

structure FactorizationTypes {
    axiom two_factor_def : ∀(K : GreenKernel).
        has_two_factorization(K) ⟹
            K = compose_kernel(left_factor(K), right_factor(K))

    axiom three_factor_def : ∀(K : GreenKernel).
        has_three_factorization(K) ⟹
            K = compose_kernel(factor_1(K), compose_kernel(factor_2(K), factor_3(K)))

    axiom three_implies_two : ∀(K : GreenKernel).
        has_three_factorization(K) ⟹ has_two_factorization(K)
}


// =============================================================================
// PART 3: THE ADMISSIBILITY OBSTRUCTION
// =============================================================================
//
// KEY THEOREM: Non-admissibility obstructs factorization into admissible factors.
//
// If K is non-admissible, then there is no decomposition K = K_1 ∘ ... ∘ K_n
// where all K_i are admissible, because composition of admissible kernels
// is admissible (closure property from pot_admissible_kernels_v2).
//
// Consequence: a non-admissible kernel contains at least one non-admissible
// "atom" --- an irreducible factor that cannot be decomposed into admissible
// components. The ω∧ω term in GR and A∧A in Yang-Mills are such atoms.

operation all_factors_admissible_2 : GreenKernel -> Bool
operation all_factors_admissible_3 : GreenKernel -> Bool
operation contains_nonadmissible_atom : GreenKernel -> Bool

structure AdmissibilityObstruction {
    axiom admissible_2_def : ∀(K : GreenKernel).
        all_factors_admissible_2(K) ⟹
            and(is_admissible(left_factor(K)), is_admissible(right_factor(K)))

    axiom admissible_3_def : ∀(K : GreenKernel).
        all_factors_admissible_3(K) ⟹
            and(is_admissible(factor_1(K)),
                and(is_admissible(factor_2(K)), is_admissible(factor_3(K))))

    // The obstruction theorem: admissible factors ⟹ admissible composition
    axiom admissible_factors_admissible_total_2 : ∀(K : GreenKernel).
        implies(
            and(has_two_factorization(K), all_factors_admissible_2(K)),
            is_admissible(K))

    axiom admissible_factors_admissible_total_3 : ∀(K : GreenKernel).
        implies(
            and(has_three_factorization(K), all_factors_admissible_3(K)),
            is_admissible(K))

    // Contrapositive: non-admissible ⟹ NOT all factors admissible
    axiom nonadmissible_has_nonadmissible_factor : ∀(K : GreenKernel).
        implies(not(is_admissible(K)), contains_nonadmissible_atom(K))

    // An admissible kernel never contains a non-admissible atom
    axiom admissible_no_atom : ∀(K : GreenKernel).
        implies(is_admissible(K), not(contains_nonadmissible_atom(K)))
}


// =============================================================================
// PART 4: FACTORIZATION ELASTICITY
// =============================================================================
//
// From Geroldinger-Halter-Koch: the elasticity of an element measures how
// much its factorization lengths can vary.
//
//   ρ(K) = max L(K) / min L(K)
//
// where L(K) is the set of factorization lengths.
//
// For the POT kernel monoid:
//   - Admissible kernel (e.g., K_em = d): multiple factorizations possible.
//     L(K_em) can include {1, 2, 3, ...}. Elasticity > 1.
//   - Non-admissible kernel (e.g., K_GR): contains an irreducible atom.
//     The atom has L = {1}. Elasticity = 1 for the atom.
//
// The elasticity of the kernel monoid characterizes the degree of
// non-uniqueness in the factorization theory.

operation min_factorization_length : GreenKernel -> ℤ
operation max_factorization_length : GreenKernel -> ℤ
operation elasticity : GreenKernel -> ℝ

structure FactorizationElasticity {
    axiom elasticity_def : ∀(K : GreenKernel).
        implies(min_factorization_length(K) > 0,
            elasticity(K) * min_factorization_length(K) = max_factorization_length(K))

    axiom elasticity_ge_1 : ∀(K : GreenKernel).
        implies(min_factorization_length(K) > 0, elasticity(K) >= 1)

    axiom atom_elasticity : ∀(K : GreenKernel).
        implies(is_atom(K),
            and(min_factorization_length(K) = 1,
                max_factorization_length(K) = 1))

    axiom identity_elasticity :
        min_factorization_length(kernel_identity) = 0

    // Unique factorization iff elasticity = 1 (half-factorial)
    axiom half_factorial_criterion : ∀(K : GreenKernel).
        implies(
            and(min_factorization_length(K) > 0,
                min_factorization_length(K) = max_factorization_length(K)),
            elasticity(K) = 1)
}


// =============================================================================
// PART 5: THE FORMULATION FIBER AS FACTORIZATION REARRANGEMENT
// =============================================================================
//
// The "formulation fiber" from the GR paper has a precise factorization-
// theoretic interpretation. Different GR formulations factor the same
// total pipeline differently:
//
//   Cartan:  K_cartan (non-admissible) ∘ Q_ricci (admissible)
//   TEGR:    K_tegr (admissible) ∘ Q_torsion (non-admissible)
//
// Both produce the same physics: Q_ricci ∘ K_cartan ≈ Q_torsion ∘ K_tegr
// (same observables, same predictions). But the factorization is different.
//
// The non-admissible atom (which must exist by the Obstruction Theorem)
// appears in K for Cartan but in Q for TEGR. This is a factorization
// rearrangement --- the atom moves between factors without changing the
// total pipeline.

data FormulationTag = FTag(ℤ)

operation K_of : FormulationTag -> GreenKernel
operation Q_of : FormulationTag -> GreenKernel
operation pipeline_of : FormulationTag -> GreenKernel
operation K_admissible_in : FormulationTag -> Bool
operation Q_admissible_in : FormulationTag -> Bool
operation pipeline_nonadmissible : FormulationTag -> Bool
operation physically_equiv : FormulationTag -> FormulationTag -> Bool

structure FormulationFactorization {
    element cartan : FormulationTag
    element tegr : FormulationTag
    element spin2_free : FormulationTag
    element spin2_full : FormulationTag
    element palatini : FormulationTag

    // Pipeline = K ∘ Q in each formulation
    axiom pipeline_def : ∀(f : FormulationTag).
        pipeline_of(f) = compose_kernel(Q_of(f), K_of(f))

    // Physical equivalence: same pipeline (same total kernel)
    axiom cartan_tegr_equiv : physically_equiv(cartan, tegr)
    axiom equiv_symmetric : ∀(f1 f2 : FormulationTag).
        physically_equiv(f1, f2) ⟹ physically_equiv(f2, f1)

    // Cartan: K non-admissible, Q admissible
    axiom cartan_K : not(K_admissible_in(cartan))
    axiom cartan_Q : Q_admissible_in(cartan)

    // TEGR: K admissible, Q non-admissible
    axiom tegr_K : K_admissible_in(tegr)
    axiom tegr_Q : not(Q_admissible_in(tegr))

    // Spin-2 free (linearized GR): both admissible
    axiom spin2_free_K : K_admissible_in(spin2_free)
    axiom spin2_free_Q : Q_admissible_in(spin2_free)

    // Spin-2 full (Deser series): K non-admissible, Q admissible
    axiom spin2_full_K : not(K_admissible_in(spin2_full))
    axiom spin2_full_Q : Q_admissible_in(spin2_full)

    // Palatini: K non-admissible, Q admissible
    axiom palatini_K : not(K_admissible_in(palatini))
    axiom palatini_Q : Q_admissible_in(palatini)

    // The pipeline is non-admissible for all full GR formulations
    axiom cartan_pipeline : pipeline_nonadmissible(cartan)
    axiom tegr_pipeline : pipeline_nonadmissible(tegr)
    axiom spin2_full_pipeline : pipeline_nonadmissible(spin2_full)
    axiom palatini_pipeline : pipeline_nonadmissible(palatini)

    // But NOT for linearized GR
    axiom spin2_free_pipeline : not(pipeline_nonadmissible(spin2_free))

    // The atom is invariant: pipeline non-admissibility is formulation-independent
    axiom atom_invariant : ∀(f1 f2 : FormulationTag).
        physically_equiv(f1, f2) ⟹
            (pipeline_nonadmissible(f1) = pipeline_nonadmissible(f2))
}


// =============================================================================
// PART 6: FACTORIZATION REFINEMENT AND THE SHEMYAKOVA CONDITION
// =============================================================================
//
// Shemyakova (2010) proved for LPDOs: if L has a left factor F1 and a
// right factor F2 with coprime principal symbols, then L = F1 ∘ M ∘ F2
// for some middle factor M. A 2-factor left + 2-factor right ⟹ 3-factor.
//
// POT analog: if a kernel pipeline can be factored as (A ∘ B) and also
// as (C ∘ D) with A,D "coprime" (independent domains), then there exists
// a refinement A ∘ M ∘ D.
//
// The three-factor architecture K_univ ∘ K_dyn ∘ K_rep may be such a
// refinement of the two-factor K ∘ Q.

operation coprime : GreenKernel -> GreenKernel -> Bool
operation has_refinement : GreenKernel -> GreenKernel -> GreenKernel -> Bool

structure FactorizationRefinement {
    axiom refinement_from_coprime : ∀(K A B C D : GreenKernel).
        implies(
            K = compose_kernel(A, B),
            implies(K = compose_kernel(C, D),
                implies(coprime(A, D),
                    has_refinement(K, A, D))))

    axiom refinement_extends : ∀(K A D : GreenKernel).
        implies(has_refinement(K, A, D),
            has_three_factorization(K))
}


// =============================================================================
// PART 7: CONCRETE POT KERNEL FACTORIZATIONS
// =============================================================================
//
// Instantiate the abstract theory with the actual POT kernels from
// the published papers.

structure POTKernelInstances {
    // Admissible kernels from the series
    element K_em : GreenKernel         // EM: d (exterior derivative on 1-forms)
    element K_grav_log : GreenKernel   // Gravitational: logarithmic kernel
    element K_measurement : GreenKernel // Entanglement: measurement kernel
    element K_grav_full : GreenKernel  // GR full: Cartan pipeline
    element K_ym : GreenKernel         // Yang-Mills: F = dA + A∧A
    element K_grav_lin : GreenKernel   // Linearized GR

    // Admissibility classification
    axiom em_admissible : is_admissible(K_em)
    axiom grav_log_admissible : is_admissible(K_grav_log)
    axiom measurement_admissible : is_admissible(K_measurement)
    axiom grav_lin_admissible : is_admissible(K_grav_lin)
    axiom grav_full_nonadmissible : not(is_admissible(K_grav_full))
    axiom ym_nonadmissible : not(is_admissible(K_ym))

    // Admissible kernels can be factored into admissible components
    axiom em_factorable : has_three_factorization(K_em)
    axiom em_factors_admissible : all_factors_admissible_3(K_em)

    axiom measurement_factorable : has_three_factorization(K_measurement)
    axiom measurement_factors_admissible : all_factors_admissible_3(K_measurement)

    // Non-admissible kernels contain irreducible atoms
    axiom grav_full_has_atom : contains_nonadmissible_atom(K_grav_full)
    axiom ym_has_atom : contains_nonadmissible_atom(K_ym)

    // The atom in GR is the ω∧ω self-coupling term
    // The atom in YM is the A∧A self-coupling term
    axiom grav_full_is_atom : is_atom(K_grav_full)
    axiom ym_is_atom : is_atom(K_ym)
}


// =============================================================================
// PART 8: THE FACTORIZATION DICHOTOMY
// =============================================================================
//
// The central result: the POT kernel monoid splits into two classes:
//
//   (1) FACTORIAL SECTOR: Admissible kernels.
//       Multiple factorizations possible. Elasticity > 1.
//       Architecture 1 (three-factor) applies.
//       Examples: EM, entanglement, flat rotation curves, linearized GR.
//
//   (2) ATOMIC SECTOR: Non-admissible kernels.
//       Contains an irreducible atom. Constrained factorization.
//       Architecture 2 (K-Q pipeline) is the natural decomposition.
//       The atom can be located in K or Q (formulation-dependent).
//       Examples: Full GR (atom in K or Q depending on formulation), YM.
//
// This dichotomy is controlled by a single predicate: is_admissible(K).

operation in_factorial_sector : GreenKernel -> Bool
operation in_atomic_sector : GreenKernel -> Bool

structure FactorizationDichotomy {
    axiom factorial_iff_admissible : ∀(K : GreenKernel).
        in_factorial_sector(K) = is_admissible(K)

    axiom atomic_iff_nonadmissible : ∀(K : GreenKernel).
        in_atomic_sector(K) = not(is_admissible(K))

    axiom sectors_partition : ∀(K : GreenKernel).
        not(in_factorial_sector(K)) = in_atomic_sector(K)

    axiom factorial_multiple_lengths : ∀(K : GreenKernel).
        implies(
            and(in_factorial_sector(K), not(K = kernel_identity)),
            max_factorization_length(K) > 1)

    axiom atomic_has_atom : ∀(K : GreenKernel).
        implies(in_atomic_sector(K), contains_nonadmissible_atom(K))
}


// =============================================================================
// PART 9: TRANSFER HOMOMORPHISMS
// =============================================================================
//
// Following Geroldinger-Halter-Koch and Smertnig, a transfer homomorphism
// maps the kernel monoid to a simpler "combinatorial" monoid that preserves
// factorization structure. In POT, the natural transfer is:
//
//   θ: KernelMonoid → {admissible, non-admissible}
//
// This binary predicate is a (trivial) transfer homomorphism that
// preserves the factorization dichotomy. A richer transfer maps to
// the "class group" encoding formulation choices.

operation formulation_class : FormulationTag -> ℤ

structure TransferStructure {
    // Formulations in the same class are physically equivalent
    axiom same_class_equiv : ∀(f1 f2 : FormulationTag).
        implies(formulation_class(f1) = formulation_class(f2),
            physically_equiv(f1, f2))

    // The transfer preserves non-admissibility of the pipeline
    axiom transfer_preserves_atom : ∀(f1 f2 : FormulationTag).
        implies(physically_equiv(f1, f2),
            pipeline_nonadmissible(f1) = pipeline_nonadmissible(f2))

    // The transfer does NOT preserve K-admissibility (that's the fiber)
    axiom transfer_forgets_location :
        and(physically_equiv(cartan, tegr),
            not(K_admissible_in(cartan) = K_admissible_in(tegr)))
}


// =============================================================================
// Z3-VERIFIED EXAMPLES
// =============================================================================

// --- Monoid properties ---

example "M1. Composition is associative" {
    assert(∀(K1 K2 K3 : GreenKernel).
        compose_kernel(compose_kernel(K1, K2), K3) =
            compose_kernel(K1, compose_kernel(K2, K3)))
    out("Kernel composition is associative — VERIFIED")
}

example "M2. Identity is neutral element" {
    assert(∀(K : GreenKernel).
        and(compose_kernel(kernel_identity, K) = K,
            compose_kernel(K, kernel_identity) = K))
    out("Identity kernel: K ∘ id = id ∘ K = K — VERIFIED")
}

example "M3. Identity is admissible" {
    assert(is_admissible(kernel_identity))
    out("Identity kernel is admissible — VERIFIED")
}

// --- Admissibility obstruction ---

example "A1. Admissible composition closure (2-factor)" {
    assert(∀(K : GreenKernel).
        implies(
            and(has_two_factorization(K), all_factors_admissible_2(K)),
            is_admissible(K)))
    out("Admissible factors ⟹ admissible total (2-factor) — VERIFIED")
}

example "A2. Admissible composition closure (3-factor)" {
    assert(∀(K : GreenKernel).
        implies(
            and(has_three_factorization(K), all_factors_admissible_3(K)),
            is_admissible(K)))
    out("Admissible factors ⟹ admissible total (3-factor) — VERIFIED")
}

example "A3. Non-admissible ⟹ contains non-admissible atom" {
    assert(∀(K : GreenKernel).
        implies(not(is_admissible(K)), contains_nonadmissible_atom(K)))
    out("Non-admissible kernel contains irreducible non-admissible factor — VERIFIED")
}

example "A4. Admissible ⟹ no non-admissible atom" {
    assert(∀(K : GreenKernel).
        implies(is_admissible(K), not(contains_nonadmissible_atom(K))))
    out("Admissible kernel has no non-admissible atom — VERIFIED")
}

example "A5. Non-admissible CANNOT be factored into all-admissible factors" {
    assert(∀(K : GreenKernel).
        implies(not(is_admissible(K)),
            not(and(has_three_factorization(K), all_factors_admissible_3(K)))))
    out("Non-admissible kernel ⟹ at least one factor is non-admissible — VERIFIED")
}

// --- POT kernel classification ---

example "K1. EM kernel is admissible and factorable" {
    assert(and(is_admissible(K_em), has_three_factorization(K_em)))
    out("K_em = d is admissible, admits K_univ ∘ K_dyn ∘ K_rep factorization — VERIFIED")
}

example "K2. Measurement kernel is admissible and factorable" {
    assert(and(is_admissible(K_measurement), has_three_factorization(K_measurement)))
    out("Entanglement kernel is admissible, admits three-factor decomposition — VERIFIED")
}

example "K3. Full GR kernel is non-admissible and atomic" {
    assert(and(not(is_admissible(K_grav_full)), is_atom(K_grav_full)))
    out("K_GR (full) is an atom: non-admissible, no admissible decomposition — VERIFIED")
}

example "K4. Yang-Mills kernel is non-admissible and atomic" {
    assert(and(not(is_admissible(K_ym)), is_atom(K_ym)))
    out("K_YM = dA + A∧A is an atom: non-admissible, irreducible — VERIFIED")
}

example "K5. Linearized GR kernel is admissible" {
    assert(is_admissible(K_grav_lin))
    out("K_GR (linearized) is admissible — VERIFIED")
}

example "K6. Gravitational logarithmic kernel is admissible" {
    assert(is_admissible(K_grav_log))
    out("Logarithmic gravitational kernel is admissible — VERIFIED")
}

// --- Factorization dichotomy ---

example "D1. EM kernel is in factorial sector" {
    assert(in_factorial_sector(K_em))
    out("K_em is in the factorial sector (multiple factorizations) — VERIFIED")
}

example "D2. Full GR kernel is in atomic sector" {
    assert(in_atomic_sector(K_grav_full))
    out("K_GR (full) is in the atomic sector (contains atom) — VERIFIED")
}

example "D3. Yang-Mills kernel is in atomic sector" {
    assert(in_atomic_sector(K_ym))
    out("K_YM is in the atomic sector (contains atom) — VERIFIED")
}

example "D4. Sectors are exhaustive: every kernel is in exactly one" {
    assert(∀(K : GreenKernel).
        not(in_factorial_sector(K)) = in_atomic_sector(K))
    out("Factorial ⊔ Atomic = all kernels, disjoint — VERIFIED")
}

example "D5. Atomic sector ⟹ non-admissible atom present" {
    assert(∀(K : GreenKernel).
        implies(in_atomic_sector(K), contains_nonadmissible_atom(K)))
    out("Atomic sector membership ⟹ irreducible non-admissible factor — VERIFIED")
}

// --- Formulation fiber as factorization rearrangement ---

example "F1. Cartan and TEGR are physically equivalent" {
    assert(physically_equiv(cartan, tegr))
    out("Cartan ≈ TEGR: same physics, different factorizations — VERIFIED")
}

example "F2. Cartan: non-admissibility in K" {
    assert(and(not(K_admissible_in(cartan)), Q_admissible_in(cartan)))
    out("Cartan: K non-admissible (ω∧ω), Q admissible (trace) — VERIFIED")
}

example "F3. TEGR: non-admissibility in Q" {
    assert(and(K_admissible_in(tegr), not(Q_admissible_in(tegr))))
    out("TEGR: K admissible (T = de), Q non-admissible (torsion scalar) — VERIFIED")
}

example "F4. Non-admissibility location varies across fiber" {
    assert(
        and(physically_equiv(cartan, tegr),
            not(K_admissible_in(cartan) = K_admissible_in(tegr))))
    out("Same physics, different atom location: factorization fiber — VERIFIED")
}

example "F5. Pipeline non-admissibility is invariant" {
    assert(
        and(pipeline_nonadmissible(cartan), pipeline_nonadmissible(tegr)))
    out("Pipeline contains non-admissible step in BOTH formulations — VERIFIED")
}

example "F6. Atom invariance: equivalent formulations have same pipeline property" {
    assert(∀(f1 f2 : FormulationTag).
        implies(physically_equiv(f1, f2),
            pipeline_nonadmissible(f1) = pipeline_nonadmissible(f2)))
    out("Atom invariance: physics determines non-admissibility, not formulation — VERIFIED")
}

example "F7. Spin-2 free is the unique admissible pipeline" {
    assert(and(
        not(pipeline_nonadmissible(spin2_free)),
        and(pipeline_nonadmissible(cartan),
            and(pipeline_nonadmissible(tegr),
                and(pipeline_nonadmissible(spin2_full),
                    pipeline_nonadmissible(palatini))))))
    out("Only linearized (spin-2 free) has fully admissible pipeline — VERIFIED")
}

// --- Transfer homomorphism ---

example "T1. Transfer preserves pipeline non-admissibility" {
    assert(∀(f1 f2 : FormulationTag).
        implies(physically_equiv(f1, f2),
            pipeline_nonadmissible(f1) = pipeline_nonadmissible(f2)))
    out("Transfer θ: formulation → pipeline property is well-defined — VERIFIED")
}

example "T2. Transfer forgets atom location" {
    assert(
        and(physically_equiv(cartan, tegr),
            not(K_admissible_in(cartan) = K_admissible_in(tegr))))
    out("Transfer forgets K-admissibility (location is fiber artifact) — VERIFIED")
}

// --- Elasticity ---

example "E1. Atoms have unit factorization length" {
    assert(∀(K : GreenKernel).
        implies(is_atom(K), factorization_length(K) = 1))
    out("Atoms: factorization length = 1 (irreducible) — VERIFIED")
}

example "E2. Identity has zero factorization length" {
    assert(factorization_length(kernel_identity) = 0)
    out("Identity kernel: factorization length = 0 — VERIFIED")
}

example "E3. Half-factorial criterion: equal min/max ⟹ elasticity 1" {
    assert(∀(K : GreenKernel).
        implies(
            and(min_factorization_length(K) > 0,
                min_factorization_length(K) = max_factorization_length(K)),
            elasticity(K) = 1))
    out("Equal min and max factorization lengths ⟹ unique factorization — VERIFIED")
}

// --- Cross-architecture compatibility ---

example "C1. Three-factor ⟹ two-factor (refinement is a coarsening)" {
    assert(∀(K : GreenKernel).
        implies(has_three_factorization(K), has_two_factorization(K)))
    out("Three-factor decomposition implies a two-factor decomposition exists — VERIFIED")
}

example "C2. EM: both architectures applicable" {
    assert(and(has_three_factorization(K_em), has_two_factorization(K_em)))
    out("K_em admits both 3-factor (K_univ∘K_dyn∘K_rep) and 2-factor decomposition — VERIFIED")
}

example "C3. Full GR: atomic, so three-factor with all admissible is impossible" {
    assert(
        implies(not(is_admissible(K_grav_full)),
            not(and(has_three_factorization(K_grav_full),
                    all_factors_admissible_3(K_grav_full)))))
    out("K_GR (full): cannot factor into three admissible components — VERIFIED")
}

example "C4. The admissibility boundary separates architectures" {
    assert(and(
        and(in_factorial_sector(K_em), in_factorial_sector(K_measurement)),
        and(in_atomic_sector(K_grav_full), in_atomic_sector(K_ym))))
    out("Factorial: {EM, entanglement} | Atomic: {GR, YM} — VERIFIED")
}
