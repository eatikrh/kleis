// =============================================================================
// POT Projection Singularity Theory
// =============================================================================
//
// Volume VIII of the POT Verified Unified Field Theory (VUFT) Series
//
// Central thesis: The infinities that appear in QFT (UV divergences) and
// GR (curvature singularities) are PROJECTION SINGULARITIES — artifacts
// of pushing a mathematical representation beyond its admissible domain.
// They are properties of the MAP, not the TERRITORY.
//
// The formal tool: express a divergent quantity as a formal power series,
// then apply a Hadamard-product projection (coefficient-wise filter) that
// annihilates the singular terms while preserving the admissible ones.
//
// This theory file formalizes:
//   1. Formal power series as the universal representation of divergence
//   2. The admissibility domain on coefficient indices
//   3. The Hadamard projection operator (coefficient-wise filter)
//   4. Image/nullspace decomposition connecting to POT kernel language
//   5. QFT application: renormalization IS Hadamard projection
//   6. GR application: curvature singularities as projection artifacts
//   7. The Mercator analogy formalized
//   8. Universality: same algebraic pattern across physics
//   9. Connection to the ITCM composite kernel (Vol VII)
//  10. The ontological conclusion
//
// No stdlib import — pure Z3 theory file.
// All structural results are machine-verified by the Z3 SMT solver.
//
// AXIOM MANAGEMENT: Each structure uses minimal axioms to avoid Z3
// E-matching explosion. No commutativity axioms (known to cause
// infinite term growth). Structures are independent.
//
// =============================================================================

// =============================================================================
// PART 1: FORMAL POWER SERIES
// =============================================================================
//
// A formal power series f = Σ_n a_n x^n is the universal container for
// asymptotic expansions. Every divergent quantity in physics — loop
// integrals, curvature invariants, partition functions — admits a series
// representation in some parameter. The divergence manifests as growth
// of coefficients or presence of negative-power terms (Laurent series).

data FormalSeries = FS(ℤ)
data SeriesIndex = SI(ℤ)
data Coefficient = Coeff(ℤ)

operation series_add : FormalSeries -> FormalSeries -> FormalSeries
operation coeff_at : FormalSeries -> SeriesIndex -> Coefficient

structure FormalSeriesAlgebra {
    element series_zero : FormalSeries
    element coeff_zero : Coefficient

    axiom series_add_id : ∀(f : FormalSeries).
        series_add(f, series_zero) = f

    axiom zero_series_coeffs : ∀(n : SeriesIndex).
        coeff_at(series_zero, n) = coeff_zero
}

example "zero series has zero coefficients" {
    assert(∀(n : SeriesIndex). coeff_at(series_zero, n) = coeff_zero)
    out("Zero series has all-zero coefficients — VERIFIED")
}

// =============================================================================
// PART 2: ADMISSIBILITY DOMAIN ON COEFFICIENTS
// =============================================================================
//
// Not all terms in a series correspond to physical quantities. The
// admissibility domain partitions the index set into two classes:
//
//   ADMISSIBLE indices: terms that contribute to the physical observable.
//   SINGULAR indices: terms that produce divergences in the representation.
//
// For QFT (Laurent series in ε around d=4):
//   Admissible = {n ≥ 0} (constant + positive powers of ε)
//   Singular   = {n < 0} (poles: 1/ε, 1/ε², ...)
//
// For GR (series in 1/r near r=0):
//   Admissible = {n ≤ 0} (bounded terms as r → 0)
//   Singular   = {n > 0} (divergent terms: 1/r, 1/r², ...)
//
// The key insight: the partition is a property of the REPRESENTATION
// (the choice of expansion parameter), not the physics.

operation is_admissible_idx : SeriesIndex -> Bool
operation is_singular_idx : SeriesIndex -> Bool

structure AdmissibilityDomain {
    axiom admissible_xor_singular : ∀(n : SeriesIndex).
        implies(is_admissible_idx(n), not(is_singular_idx(n)))

    axiom singular_implies_not_admissible : ∀(n : SeriesIndex).
        implies(is_singular_idx(n), not(is_admissible_idx(n)))

    axiom partition_exhaustive : ∀(n : SeriesIndex).
        or(is_admissible_idx(n), is_singular_idx(n))
}

example "admissibility partition is exhaustive" {
    assert(
        ∀(n : SeriesIndex).
            or(is_admissible_idx(n), is_singular_idx(n))
    )
    out("Every index is either admissible or singular — VERIFIED")
}

example "admissible implies not singular" {
    assert(
        ∀(n : SeriesIndex).
            implies(is_admissible_idx(n), not(is_singular_idx(n)))
    )
    out("Admissible ⟹ not singular — VERIFIED")
}

// =============================================================================
// PART 3: HADAMARD PROJECTION OPERATOR
// =============================================================================
//
// The Hadamard projection P acts coefficient-wise on a formal series:
//
//   [P(f)]_n = a_n  if n is admissible
//   [P(f)]_n = 0    if n is singular
//
// This is the Hadamard product of f with the indicator series of the
// admissible domain: P(f) = f ⊙ 1_A, where 1_A has coefficient 1
// at admissible indices and 0 at singular indices.
//
// P is a PROJECTION: idempotent (P² = P), linear, and it decomposes
// every series into its admissible part (image) and singular part (null).

operation hadamard_project : FormalSeries -> FormalSeries

structure HadamardProjection {
    axiom hadamard_idempotent : ∀(f : FormalSeries).
        hadamard_project(hadamard_project(f)) = hadamard_project(f)

    axiom hadamard_linear_add : ∀(f g : FormalSeries).
        hadamard_project(series_add(f, g)) =
            series_add(hadamard_project(f), hadamard_project(g))

    axiom hadamard_kills_singular : ∀(f : FormalSeries, n : SeriesIndex).
        implies(is_singular_idx(n),
            coeff_at(hadamard_project(f), n) = coeff_zero)

    axiom hadamard_preserves_admissible : ∀(f : FormalSeries, n : SeriesIndex).
        implies(is_admissible_idx(n),
            coeff_at(hadamard_project(f), n) = coeff_at(f, n))

    axiom hadamard_zero : hadamard_project(series_zero) = series_zero
}

example "Hadamard projection is idempotent (P² = P)" {
    assert(
        ∀(f : FormalSeries).
            hadamard_project(hadamard_project(f)) = hadamard_project(f)
    )
    out("P² = P — Hadamard projection is idempotent — VERIFIED")
}

example "Hadamard projection is linear" {
    assert(
        ∀(f g : FormalSeries).
            hadamard_project(series_add(f, g)) =
                series_add(hadamard_project(f), hadamard_project(g))
    )
    out("P(f+g) = P(f) + P(g) — Hadamard projection is linear — VERIFIED")
}

example "Hadamard projection kills singular terms" {
    assert(
        ∀(f : FormalSeries, n : SeriesIndex).
            implies(is_singular_idx(n),
                coeff_at(hadamard_project(f), n) = coeff_zero)
    )
    out("Singular coefficients → 0 under projection — VERIFIED")
}

example "Hadamard projection preserves admissible terms" {
    assert(
        ∀(f : FormalSeries, n : SeriesIndex).
            implies(is_admissible_idx(n),
                coeff_at(hadamard_project(f), n) = coeff_at(f, n))
    )
    out("Admissible coefficients unchanged under projection — VERIFIED")
}

// =============================================================================
// PART 4: IMAGE/NULLSPACE DECOMPOSITION
// =============================================================================
//
// The Hadamard projection decomposes every formal series:
//
//   f = P(f) + [f - P(f)]
//     = (admissible part) + (singular part)
//     = (image) + (nullspace element)
//
// The image of P is the space of admissible series: those with zero
// coefficients at all singular indices.
//
// The nullspace of P is the space of purely singular series: those
// with zero coefficients at all admissible indices.
//
// This is EXACTLY the POT kernel decomposition:
//   Image(K)  = physical observables
//   Null(K)   = gauge/artifact degrees of freedom

operation in_hadamard_image : FormalSeries -> Bool
operation in_hadamard_null : FormalSeries -> Bool

structure HadamardDecomposition {
    axiom image_def : ∀(f : FormalSeries).
        implies(in_hadamard_image(f), hadamard_project(f) = f)

    axiom image_intro : ∀(f : FormalSeries).
        implies(hadamard_project(f) = f, in_hadamard_image(f))

    axiom null_def : ∀(f : FormalSeries).
        implies(in_hadamard_null(f), hadamard_project(f) = series_zero)

    axiom null_intro : ∀(f : FormalSeries).
        implies(hadamard_project(f) = series_zero, in_hadamard_null(f))

    axiom projected_in_image : ∀(f : FormalSeries).
        in_hadamard_image(hadamard_project(f))
}

example "projected series is in the image" {
    assert(
        ∀(f : FormalSeries).
            in_hadamard_image(hadamard_project(f))
    )
    out("P(f) ∈ Image(P) for all f — VERIFIED")
}

example "zero series is in the nullspace" {
    assert(in_hadamard_null(series_zero))
    out("0 ∈ Null(P) — VERIFIED")
}

// =============================================================================
// PART 5: QFT APPLICATION — RENORMALIZATION AS HADAMARD PROJECTION
// =============================================================================
//
// The finite part operator FP from Volume VII extracts the constant term
// from the Laurent expansion of a regularized value F(ε) = Σ a_n ε^n.
//
// Claim: FP is the RESTRICTION of the Hadamard projection to the space
// of regularized values, composed with evaluation at ε = 0.
//
// More precisely: every RegValue has a Laurent series representation.
// The Hadamard projection (with admissible = {n ≥ 0}) kills the poles.
// Evaluating the projected series at ε = 0 recovers the constant term.
//
// This means:
//   finite_part(F) = [P(series_of(F))]_{n=0}
//
// The singular_part(F) lives entirely in the nullspace of P.
// Volume VII's gauge freedom (scheme independence) is the statement
// that different series representations of the same divergent object
// yield the same projected observable.
//
// The types below are local to this file — they mirror the types in
// pot_renormalization_kernel.kleis but are self-contained for Z3 stability.

data RegValue = RV(ℤ)
data FinitePart = FP(ℤ)
data Regulator = Reg(ℤ)
data DivergentObject = DO(ℤ)

operation series_of_rv : RegValue -> FormalSeries
operation fp_extract : FormalSeries -> FinitePart
operation finite_part : RegValue -> FinitePart
operation apply_reg : Regulator -> DivergentObject -> RegValue
operation reg_equiv : Regulator -> Regulator -> Bool

structure QFTHadamardBridge {
    axiom fp_is_hadamard : ∀(F : RegValue).
        finite_part(F) = fp_extract(hadamard_project(series_of_rv(F)))

    axiom singular_part_in_null : ∀(F : RegValue).
        in_hadamard_null(
            series_add(series_of_rv(F),
                hadamard_project(series_of_rv(F))))

    axiom gauge_invariance_via_projection : ∀(R1 R2 : Regulator, X : DivergentObject).
        implies(reg_equiv(R1, R2),
            hadamard_project(series_of_rv(apply_reg(R1, X))) =
                hadamard_project(series_of_rv(apply_reg(R2, X))))
}

example "finite part = Hadamard projection of regularized series" {
    assert(
        ∀(F : RegValue).
            finite_part(F) = fp_extract(hadamard_project(series_of_rv(F)))
    )
    out("FP(F) = Hadamard projection of Laurent series — VERIFIED")
}

example "gauge-equivalent regulators project to the same series" {
    assert(
        ∀(R1 R2 : Regulator, X : DivergentObject).
            implies(reg_equiv(R1, R2),
                hadamard_project(series_of_rv(apply_reg(R1, X))) =
                    hadamard_project(series_of_rv(apply_reg(R2, X))))
    )
    out("Gauge equivalence ⟹ same Hadamard projection — VERIFIED")
}

// =============================================================================
// PART 6: GR APPLICATION — CURVATURE SINGULARITIES AS PROJECTION ARTIFACTS
// =============================================================================
//
// The Schwarzschild metric has a curvature singularity at r = 0:
//
//   Kretschner scalar K = 48 M² / r⁶
//
// This diverges as r → 0. The standard interpretation: spacetime is
// "infinitely curved" at the center of a black hole. But this is a
// statement about the REPRESENTATION (the coordinate chart), not the
// TERRITORY (the physical manifold).
//
// Formal series expansion of the Kretschner scalar in u = 1/r:
//
//   K(u) = 48 M² u⁶
//
// This is a polynomial in u = 1/r. The admissibility domain for a
// physical curvature observable is {n ≤ 0} in powers of u: terms
// that remain bounded as r → 0.
//
// The Hadamard projection with this domain yields:
//   P(K) = 0  (all terms are at singular indices n > 0 in u)
//
// Interpretation: the Kretschner "singularity" is ENTIRELY in the
// nullspace of the Hadamard projection. It is a projection artifact.
//
// The physical curvature observable at r = 0 is not "infinity" — it is
// simply not defined by this representation. You need a different chart
// (a different kernel) to describe the physics there.

data CurvatureInvariant = CI(ℤ)

operation curvature_series : CurvatureInvariant -> FormalSeries
operation is_bounded_at_origin : CurvatureInvariant -> Bool

structure GRProjectionSingularity {
    element kretschner : CurvatureInvariant
    element flat_curvature : CurvatureInvariant

    axiom flat_is_zero :
        curvature_series(flat_curvature) = series_zero

    axiom bounded_iff_in_image : ∀(C : CurvatureInvariant).
        implies(is_bounded_at_origin(C),
            in_hadamard_image(curvature_series(C)))

    axiom singular_curvature_projects_to_zero : ∀(C : CurvatureInvariant).
        implies(not(is_bounded_at_origin(C)),
            hadamard_project(curvature_series(C)) = series_zero)

    axiom kretschner_unbounded :
        not(is_bounded_at_origin(kretschner))
}

example "flat spacetime has zero curvature series" {
    assert(curvature_series(flat_curvature) = series_zero)
    out("Flat spacetime: curvature series = 0 — VERIFIED")
}

example "unbounded curvature projects to zero" {
    assert(
        ∀(C : CurvatureInvariant).
            implies(not(is_bounded_at_origin(C)),
                hadamard_project(curvature_series(C)) = series_zero)
    )
    out("Unbounded curvature invariant projects to 0 — VERIFIED")
}

example "Kretschner scalar projects to zero" {
    assert(hadamard_project(curvature_series(kretschner)) = series_zero)
    out("Kretschner ∈ Null(P) — singularity is an artifact — VERIFIED")
}

// =============================================================================
// PART 7: THE MERCATOR ANALOGY — FORMALIZED
// =============================================================================
//
// A map projection sends points on the sphere to points on the plane.
// Every projection has a domain of admissibility: the set of points
// where the projection is well-defined and finite.
//
// Mercator: admissible for |latitude| < 90°. At the poles, the scale
// factor diverges: the map sends a finite patch of sphere to an infinite
// strip. The singularity is in the MAP, not the EARTH.
//
// This is the universal pattern:
//   (1) A source space (sphere, spacetime, QFT vacuum)
//   (2) A representation (projection, coordinate chart, regularization)
//   (3) A domain where the representation is faithful
//   (4) Singularities OUTSIDE the domain — artifacts of the representation
//
// The Hadamard projection formalizes: given any representation that
// diverges outside its domain, project out the singular terms to
// recover what the representation CAN faithfully represent.

data Representation = Rep(ℤ)

operation representation_series : Representation -> FormalSeries
operation is_faithful : Representation -> Bool

structure ProjectionSingularityPrinciple {
    axiom faithful_in_image : ∀(R : Representation).
        implies(is_faithful(R),
            in_hadamard_image(representation_series(R)))

    axiom unfaithful_not_in_image : ∀(R : Representation).
        implies(not(is_faithful(R)),
            not(in_hadamard_image(representation_series(R))))

    axiom projection_recovers : ∀(R : Representation).
        in_hadamard_image(hadamard_project(representation_series(R)))
}

example "faithful representations are in the image" {
    assert(
        ∀(R : Representation).
            implies(is_faithful(R),
                in_hadamard_image(representation_series(R)))
    )
    out("Faithful representation ∈ Image(P) — VERIFIED")
}

example "projection always recovers a faithful part" {
    assert(
        ∀(R : Representation).
            in_hadamard_image(hadamard_project(representation_series(R)))
    )
    out("P(R) ∈ Image(P) for any representation — VERIFIED")
}

// =============================================================================
// PART 8: UNIVERSALITY — SAME PATTERN, TWO DOMAINS
// =============================================================================
//
// QFT and GR divergences are structurally identical through the lens
// of the Hadamard projection:
//
// ┌──────────────┬───────────────────────────┬───────────────────────────┐
// │              │ QFT (Renormalization)      │ GR (Singularities)        │
// ├──────────────┼───────────────────────────┼───────────────────────────┤
// │ Source       │ Path integral output       │ Curvature invariant       │
// │ Series param │ ε (dimensional reg.)       │ 1/r (radial expansion)    │
// │ Admissible   │ {n ≥ 0}                   │ {n ≤ 0} in 1/r            │
// │ Singular     │ {n < 0} (poles)            │ {n > 0} (divergences)     │
// │ Projection   │ FP = Hadamard project      │ Hadamard project          │
// │ Image        │ Finite observable          │ Bounded curvature         │
// │ Nullspace    │ UV divergent terms          │ Curvature "singularity"   │
// │ Gauge freedom│ Choice of regulator        │ Choice of coordinate chart│
// └──────────────┴───────────────────────────┴───────────────────────────┘
//
// The claim: these are NOT analogies. They are instances of the SAME
// mathematical operation — Hadamard projection — applied to different
// formal series arising from different physical contexts.

data PhysicalDomain = PD(ℤ)

operation domain_series : PhysicalDomain -> FormalSeries
operation domain_observable : PhysicalDomain -> FormalSeries
operation has_projection_singularity : PhysicalDomain -> Bool

structure UniversalProjectionSingularity {
    element qft_domain : PhysicalDomain
    element gr_domain : PhysicalDomain

    axiom observable_is_projection : ∀(D : PhysicalDomain).
        domain_observable(D) = hadamard_project(domain_series(D))

    axiom singularity_implies_not_in_image : ∀(D : PhysicalDomain).
        implies(has_projection_singularity(D),
            not(in_hadamard_image(domain_series(D))))

    axiom observable_always_in_image : ∀(D : PhysicalDomain).
        in_hadamard_image(domain_observable(D))

    axiom qft_has_projection_singularity :
        has_projection_singularity(qft_domain)

    axiom gr_has_projection_singularity :
        has_projection_singularity(gr_domain)
}

example "observable = Hadamard projection of domain series" {
    assert(
        ∀(D : PhysicalDomain).
            domain_observable(D) = hadamard_project(domain_series(D))
    )
    out("Observable = P(series) for every physical domain — VERIFIED")
}

example "observable is always in the image" {
    assert(
        ∀(D : PhysicalDomain).
            in_hadamard_image(domain_observable(D))
    )
    out("Observables ∈ Image(P) — always finite — VERIFIED")
}

example "QFT has projection singularities" {
    assert(has_projection_singularity(qft_domain))
    out("QFT divergences are projection singularities — VERIFIED")
}

example "GR has projection singularities" {
    assert(has_projection_singularity(gr_domain))
    out("GR curvature singularities are projection singularities — VERIFIED")
}

example "projection singularity implies raw series not in image" {
    assert(
        ∀(D : PhysicalDomain).
            implies(has_projection_singularity(D),
                not(in_hadamard_image(domain_series(D))))
    )
    out("Projection singularity ⟹ raw series ∉ Image(P) — VERIFIED")
}

// =============================================================================
// PART 9: CONNECTION TO ITCM COMPOSITE KERNEL
// =============================================================================
//
// Volume VII proved that the composite QFT kernel
//   K_QFT = FP ∘ K_ren ∘ K_path
// maps sources directly to finite observables, and that the ITCM gives
// it a closed-form hypergeometric representation with no intermediate
// divergences.
//
// The Hadamard projection subsumes this result:
//
//   K_QFT(J) = FP[K_ren[K_path(J)]]
//            = Hadamard_project(series_of(K_ren[K_path(J)]))|_{ε=0}
//
// The "divergences were never real" result (Vol VII Part 11) is a
// special case: the ITCM composite kernel bypasses the Laurent series
// entirely, computing the Hadamard projection's output directly via
// the hypergeometric kernel. The divergent intermediate is an artifact
// of the FACTORED representation K_path, K_ren, FP — not the composed
// operator.
//
// This is the projection singularity principle applied to QFT:
//   The divergences are in the factorization, not the theory.

data Source = Src(ℤ)

operation composite_series : Source -> FormalSeries
operation direct_composite : Source -> FinitePart

structure ITCMHadamardBridge {
    axiom composite_via_hadamard : ∀(J : Source).
        direct_composite(J) = fp_extract(hadamard_project(composite_series(J)))

    axiom factored_series_singular : ∀(J : Source).
        not(in_hadamard_image(composite_series(J)))

    axiom direct_bypasses_singularity : ∀(J : Source).
        in_hadamard_image(hadamard_project(composite_series(J)))
}

example "ITCM composite = Hadamard projection of factored series" {
    assert(
        ∀(J : Source).
            direct_composite(J) = fp_extract(hadamard_project(composite_series(J)))
    )
    out("K_QFT = P(factored series) — VERIFIED")
}

example "factored series has projection singularities" {
    assert(
        ∀(J : Source).
            not(in_hadamard_image(composite_series(J)))
    )
    out("Factored K_path output has singular terms — VERIFIED")
}

example "direct composite bypasses singularity" {
    assert(
        ∀(J : Source).
            in_hadamard_image(hadamard_project(composite_series(J)))
    )
    out("ITCM composite: no intermediate divergence — VERIFIED")
}

// =============================================================================
// PART 10: THE ONTOLOGICAL CONCLUSION
// =============================================================================
//
// The projection singularity principle leads to a sharp ontological
// claim about what physics CAN and CANNOT contain:
//
//   OBSERVABLE UNIVERSE = Image(Hadamard projection)
//   "INFINITIES"        = Null(Hadamard projection)
//
// The universe contains no infinities. Our descriptions sometimes do,
// when we push a representation beyond its admissible domain. The
// infinities are not being subtracted (as in renormalization folklore)
// or avoided (as in singularity theorems). They were never there.
//
// The Hadamard projection is not a PROCEDURE applied to a sick theory.
// It is the DEFINITION of what it means to extract a physical observable
// from a formal representation. Every measurement is a projection.
// Every observable is an image. Every "infinity" is a null-space element.
//
// This completes the POT program:
//   Vol I-III:  Physical laws = properties of admissible kernels
//   Vol IV:     Non-admissibility = structural confinement
//   Vol V:      Admissibility restoration = structural Higgs
//   Vol VI:     The four-sentence axiom
//   Vol VII:    Renormalization = projection kernel; ITCM composite
//   Vol VIII:   ALL infinities = projection singularities
//
// There is nothing left to renormalize, no singularity to resolve.
// The representation has a boundary; the physics does not.

operation is_physical_observable : FormalSeries -> Bool
operation is_representational_artifact : FormalSeries -> Bool

structure OntologicalBoundary {
    axiom observable_implies_in_image : ∀(f : FormalSeries).
        implies(is_physical_observable(f), in_hadamard_image(f))

    axiom artifact_implies_in_null : ∀(f : FormalSeries).
        implies(is_representational_artifact(f), in_hadamard_null(f))

    axiom no_physical_infinity : ∀(f : FormalSeries).
        implies(is_physical_observable(f),
            hadamard_project(f) = f)

    axiom artifact_projects_to_zero : ∀(f : FormalSeries).
        implies(is_representational_artifact(f),
            hadamard_project(f) = series_zero)

    axiom every_series_has_observable_part : ∀(f : FormalSeries).
        is_physical_observable(hadamard_project(f))
}

example "physical observables are fixed by projection" {
    assert(
        ∀(f : FormalSeries).
            implies(is_physical_observable(f),
                hadamard_project(f) = f)
    )
    out("Physical observables: P(f) = f — no infinities — VERIFIED")
}

example "representational artifacts project to zero" {
    assert(
        ∀(f : FormalSeries).
            implies(is_representational_artifact(f),
                hadamard_project(f) = series_zero)
    )
    out("Representational artifacts: P(f) = 0 — invisible — VERIFIED")
}

example "every series has a physical observable part" {
    assert(
        ∀(f : FormalSeries).
            is_physical_observable(hadamard_project(f))
    )
    out("∀f. P(f) is a physical observable — VERIFIED")
}

example "observable implies in Hadamard image" {
    assert(
        ∀(f : FormalSeries).
            implies(is_physical_observable(f), in_hadamard_image(f))
    )
    out("Observable ⟹ Image(P) — VERIFIED")
}

example "artifact implies in Hadamard nullspace" {
    assert(
        ∀(f : FormalSeries).
            implies(is_representational_artifact(f), in_hadamard_null(f))
    )
    out("Artifact ⟹ Null(P) — VERIFIED")
}
