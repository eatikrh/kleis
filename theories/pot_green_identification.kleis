    out("  4. Euler exponent -1 = simple pole singularity")
    out("")
    out("LEVEL B (structural):")
    out("  5. ITCM parameters continuously deform from free to interacting")
    out("  6. Euler factorization matches Green's function singularity")
    out("  7. Dressing R(z) consistent with Born series structure")
    out("  8. Power-law weight w → centrifugal barrier V (explicit)")
    out("")
    out("LEVEL C (conjectural):")
    out("  9. General w determines V_w (inverse spectral conjecture)")
    out(" 10. IR regularity induces long-range growth in V_w")
    out(" 11. Long-range growth produces spectral gap")
    out("")
    out("The Millennium Problem reduces to proving step 9:")
    out("  The ITCM weight function w_YM determines a unique potential V_YM")
    out("  whose Sturm-Liouville operator has the ITCM kernel as its resolvent.")
}

