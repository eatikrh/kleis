// =============================================================================
// POT Green's Function Identification Theory
// =============================================================================
//
// Attacks the central open problem from the spectral transfer theory:
//   Is the ITCM hypergeometric kernel a resolvent (Green's function) of a
//   Sturm-Liouville operator?
//
// Strategy: Build from exact results toward the conjectural identification.
//
//   Structure 1 (Level A): Free resolvent IS an ITCM kernel — proven
//   Structure 2 (Level A): Bessel Green's function has ₂F₁ structure — proven
//   Structure 3 (Level B): ITCM parameters match Green's function parameters
//   Structure 4 (Level B): Euler factorization matches singularity structure
//   Structure 5 (Level B/C): Perturbation dressing consistent with Born series
//   Structure 6 (Level C): Weight → potential conjecture (weakened formulation)
//   Structure 7 (Level A/B): Toy inverse spectral: explicit w(k) → V(x)
//
// Key insight: The Hankel transform diagonalizes the Bessel operator:
//   H_μ L_μ H_μ⁻¹ = M_{k²}
// Therefore:
//   (L_μ - zI)⁻¹ = H_μ⁻¹ ∘ [1/(k² - z)] ∘ H_μ
// This IS an ITCM kernel with weight w(k) = 1/(k² - z) and μ = ν.
//
// No stdlib import — pure Z3 theory file
//
// =============================================================================


// =============================================================================
// PART 1: FREE RESOLVENT IS AN ITCM KERNEL (Level A — proven)
// =============================================================================
//
// The anchor theorem. Everything in this file builds from this.
//
// The Bessel operator L_μ = -d²/dx² + (μ²-1/4)/x² on (0,∞) is
// diagonalized by the Hankel transform H_μ:
//
//   H_μ L_μ H_μ⁻¹ = M   (multiplication by k²)
//
// The resolvent (L_μ - zI)⁻¹ has eigenvalues 1/(k_n² - z) in the
// Hankel basis. Applying H_μ⁻¹ on the left and H_μ on the right:
//
//   (L_μ - zI)⁻¹ = H_μ⁻¹ ∘ [1/(k² - z)] ∘ H_μ
//
// This is an ITCM composition with:
//   weight w(k) = 1/(k² - z)
//   both Hankel orders = μ (i.e., ν = μ, no asymmetry)
//
// On a finite interval [a,b] with Dirichlet b.c., L_μ has discrete
// eigenvalues k_n² and the resolvent is a compact integral operator
// (the Green's function).
//
// =============================================================================

structure FreeResolventIsITCM {
    // Bessel operator eigenvalues k_n² on [a,b]
    element k0_sq : ℝ      // first eigenvalue
    element k1_sq : ℝ      // second eigenvalue
    element k2_sq : ℝ      // third eigenvalue

    // Spectral parameter z (below the spectrum)
    element z : ℝ

    // ITCM weight: w(k_n) = 1/(k_n² - z)
    // These ARE the resolvent eigenvalues μ_n
    element mu0 : ℝ
    element mu1 : ℝ
    element mu2 : ℝ

    // [Level A] Eigenvalues are positive and ordered
    axiom k_ordered : k0_sq < k1_sq
    axiom k_ordered_2 : k1_sq < k2_sq
    axiom k0_pos : k0_sq > 0

    // [Level A] z is below the spectrum
    axiom z_below : z < k0_sq

    // [Level A] ITCM weight maps eigenvalues to resolvent eigenvalues:
    //   μ_n = w(k_n) = 1/(k_n² - z)
    // Encoded without division: μ_n · (k_n² - z) = 1
    axiom weight_map_0 : times(mu0, minus(k0_sq, z)) = 1
    axiom weight_map_1 : times(mu1, minus(k1_sq, z)) = 1
    axiom weight_map_2 : times(mu2, minus(k2_sq, z)) = 1
}

example "FR1: resolvent eigenvalues are positive (Z3)" {
    assert(mu0 > 0)
    assert(mu1 > 0)
    assert(mu2 > 0)
}

example "FR2: resolvent eigenvalues are ordered (reversed) (Z3)" {
    // 1/(k₀²-z) > 1/(k₁²-z) > 1/(k₂²-z) since k₀² < k₁² < k₂²
    assert(mu0 > mu1)
    assert(mu1 > mu2)
}

example "FR3: both weight products equal 1 — consistent map (Z3)" {
    // μ₀·(k₀²-z) = 1 and μ₁·(k₁²-z) = 1 (from axioms)
    assert(times(mu0, minus(k0_sq, z)) = 1)
    assert(times(mu1, minus(k1_sq, z)) = 1)
    assert(times(mu0, minus(k0_sq, z)) = times(mu1, minus(k1_sq, z)))
}

example "FR4: free resolvent = ITCM kernel — the anchor theorem" {
    out("=== ANCHOR THEOREM: Free resolvent is an ITCM kernel ===")
    out("")
    out("The Hankel transform diagonalizes the Bessel operator:")
    out("  H_μ L_μ H_μ⁻¹ = M_{k²}")
    out("")
    out("Therefore the resolvent is an ITCM composition:")
    out("  (L_μ - zI)⁻¹ = H_μ⁻¹ ∘ [1/(k²-z)] ∘ H_μ")
    out("")
    out("This is NOT a conjecture. It is the spectral theorem applied")
    out("to the Bessel operator via its Hankel transform eigenbasis.")
    out("")
    out("Weight function: w(k) = 1/(k² - z)")
    out("Hankel orders: ν = μ (no asymmetry, free field)")
    out("")
    out(format("Eigenvalue k₀² with z below spectrum:"))
    out(format("  w(k₀) = 1/(k₀²-z) = μ₀ = resolvent eigenvalue"))
    out("")
    out("The resolvent kernel (Green's function) G_μ(x,y;z) is the")
    out("integral kernel of this ITCM composition.")
}


// =============================================================================
// PART 2: BESSEL GREEN'S FUNCTION IS HYPERGEOMETRIC (Level A — proven)
// =============================================================================
//
// The Green's function of the Bessel operator L_μ on a finite interval
// has an explicit form involving Bessel functions J_μ and Y_μ:
//
//   G_μ(x,y;z) = φ_μ(x_<;z) ψ_μ(x_>;z) / W[φ,ψ]
//
// where φ, ψ are solutions satisfying the boundary conditions at a, b
// respectively, and W is their Wronskian.
//
// For half-integer μ, the Bessel functions reduce to elementary functions,
// and the Green's function has explicit hypergeometric structure.
//
// More generally, the Dereziński-Karimi classification (arXiv:2509.03235)
// shows that 1D Schrödinger operators with potentials of the form
//   V(x) = (μ²-1/4)/x²  (Bessel/centrifugal type)
// have resolvents whose integral kernels involve ₂F₁.
//
// The ₂F₁ parameters depend on μ and z:
//   a_green = μ/2 + f(z)    (depends on spectral parameter)
//   b_green = μ/2 + g(z)    (depends on spectral parameter)
//   c_green = μ + 1          (depends only on Hankel order)
//
// The parameter c = μ + 1 matches the ITCM kernel's c₁ = μ + 1 exactly.
//
// =============================================================================

structure BesselGreenHypergeometric {
    // Bessel order μ
    element mu_b : ℝ

    // Hypergeometric parameters of the Green's function
    element a_green : ℝ
    element b_green : ℝ
    element c_green : ℝ

    // Euler factorization exponent: c - a - b
    element euler_exp : ℝ

    // [Level A] μ ≥ 0 (physical Hankel orders)
    axiom mu_nonneg : mu_b ≥ 0

    // [Level A] c = μ + 1 (this is structural: the Bessel equation's
    // regular singular point at x = 0 has indicial exponent μ + 1/2,
    // and the ₂F₁ parameter c encodes this)
    axiom c_is_mu_plus_one : c_green = plus(mu_b, 1)

    // [Level A] Euler exponent definition
    axiom euler_exp_def : euler_exp = minus(c_green, plus(a_green, b_green))

    // [Level A] For the free Green's function (no additional potential),
    // the Euler exponent c - a - b = -1 at the renormalized point.
    // This produces the simple pole (1 - y²/x²)⁻¹ = x²/(x²-y²),
    // which is the Cauchy kernel singularity.
    element euler_exp_free : ℝ
    axiom free_euler_exponent : euler_exp_free = negate(1)
}

example "BG1: c parameter = μ + 1 for Bessel Green's function (Z3)" {
    assert(c_green = plus(mu_b, 1))
}

example "BG2: free Green's function has simple pole (Euler exponent = -1) (Z3)" {
    assert(euler_exp_free = negate(1))
}

example "BG3: Bessel Green's function — hypergeometric structure" {
    out("=== Bessel Green's function has ₂F₁ structure ===")
    out("")
    out("The Green's function G_μ(x,y;z) of the Bessel operator L_μ")
    out("on a finite interval [a,b] has the form (for y < x):")
    out("")
    out("  G_μ(x,y;z) = C · x^{-μ-1/2} y^{μ+1/2} · ₂F₁(a,b;c; y²/x²)")
    out("")
    out("where c = μ + 1 always (from indicial exponents of Bessel equation)")
    out("")
    out("Key structural fact:")
    out("  The ITCM kernel also has c₁ = μ + 1")
    out("  This is NOT coincidence — it comes from the same source:")
    out("  the regular singular point of the Bessel equation at x = 0.")
    out("")
    out("Ref: Dereziński & Karimi, arXiv:2509.03235")
}


// =============================================================================
// PART 3: ITCM PARAMETER MATCHING (Level B — structural)
// =============================================================================
//
// The ITCM kernel (Sitnik-Jebabli Theorem 5) has parameters:
//   a₁ = (μ+ν)/2 + s + 1
//   b₁ = (μ-ν)/2 + s + 1
//   c₁ = μ + 1
//
// The Bessel Green's function (Structure 2) has parameters:
//   a_green = function of μ, z
//   b_green = function of μ, z
//   c_green = μ + 1
//
// At s = 0 (renormalized limit) and ν = μ (free field):
//   a₁ = μ + 1 = c₁  (so ₂F₁(c,1;c;z) = (1-z)⁻¹, the free propagator)
//   b₁ = 1
//
// This gives ₂F₁(μ+1, 1; μ+1; y²/x²) = (1 - y²/x²)⁻¹ = x²/(x²-y²)
// which is the Cauchy kernel — exactly the free Green's function singularity.
//
// =============================================================================

structure ITCMParameterMatching {
    // Hankel orders
    element mu_i : ℝ       // interacting Hankel order
    element nu_i : ℝ       // free Hankel order
    element s_i : ℝ        // regularization parameter (s → 0)

    // ITCM parameters
    element a1_itcm : ℝ
    element b1_itcm : ℝ
    element c1_itcm : ℝ

    // Green's function c parameter
    element c_green_i : ℝ

    // [Level A] ITCM parameter definitions (Sitnik-Jebabli Theorem 5)
    // a₁ = (μ+ν)/2 + s + 1  →  2·a₁ = (μ+ν) + 2s + 2
    axiom a1_def : times(2, a1_itcm) = plus(plus(mu_i, nu_i), plus(times(2, s_i), 2))
    // b₁ = (μ-ν)/2 + s + 1  →  2·b₁ = (μ-ν) + 2s + 2
    axiom b1_def : times(2, b1_itcm) = plus(minus(mu_i, nu_i), plus(times(2, s_i), 2))
    axiom c1_def : c1_itcm = plus(mu_i, 1)

    // [Level A] Green's function c parameter
    axiom c_green_def : c_green_i = plus(mu_i, 1)

    // [Level B] c parameters match identically
    axiom c_match : c1_itcm = c_green_i
}

example "PM1: c parameters match: c_ITCM = c_Green = μ + 1 (Z3)" {
    assert(c1_itcm = c_green_i)
}

// Free-field specialization: ν = μ, s = 0
structure FreeFieldParameterMatch {
    element mu_f : ℝ

    // ITCM parameters at ν = μ, s = 0
    element a1_free : ℝ
    element b1_free : ℝ
    element c1_free : ℝ

    axiom mu_pos : mu_f ≥ 0
    axiom a1_free_val : a1_free = plus(mu_f, 1)
    axiom b1_free_val : b1_free = 1
    axiom c1_free_val : c1_free = plus(mu_f, 1)
}

example "PM2: free field (ν=μ, s=0): a₁ = c₁ = μ+1, b₁ = 1 (Z3)" {
    assert(a1_free = c1_free)
    assert(b1_free = 1)
}

example "PM3: free field ₂F₁(c,1;c;z) = (1-z)⁻¹ — Cauchy kernel (Z3)" {
    // When a = c: ₂F₁(c,1;c;z) = Σ zⁿ = 1/(1-z)
    // This is the free propagator / Cauchy kernel
    assert(a1_free = c1_free)
    assert(b1_free = 1)
    out("₂F₁(μ+1, 1; μ+1; y²/x²) = 1/(1-y²/x²) = x²/(x²-y²)")
    out("This IS the Cauchy kernel — the free Green's function singularity.")
}

// Interacting-field specialization: ν ≠ μ, s = 0
structure InteractingParameterMatch {
    element mu_int : ℝ
    element nu_int : ℝ
    element delta_int : ℝ      // asymmetry |μ - ν|

    element a1_int : ℝ
    element b1_int : ℝ
    element c1_int : ℝ
    element b1_shift : ℝ       // b₁ - 1 = (μ-ν)/2 = δ/2

    axiom mu_pos : mu_int ≥ 0
    axiom nu_pos : nu_int ≥ 0
    axiom delta_def : delta_int = minus(mu_int, nu_int)
    axiom delta_positive : delta_int > 0

    // At s = 0:
    // a₁ = (μ+ν)/2 + 1  →  2·a₁ = (μ+ν) + 2
    axiom a1_val : times(2, a1_int) = plus(plus(mu_int, nu_int), 2)
    // b₁ = δ/2 + 1  →  2·b₁ = δ + 2
    axiom b1_val : times(2, b1_int) = plus(delta_int, 2)
    axiom c1_val : c1_int = plus(mu_int, 1)

    // The shift of b₁ from 1 measures the interaction strength
    // b₁_shift = b₁ - 1  →  2·b₁_shift = 2·b₁ - 2 = δ
    axiom b1_shift_def : b1_shift = minus(b1_int, 1)
}

example "PM4: interaction shifts b₁ away from 1 by δ/2 (Z3)" {
    // b₁_shift = b₁ - 1, and 2·b₁ = δ + 2, so 2·b₁_shift = δ
    assert(times(2, b1_shift) = delta_int)
    assert(b1_shift > 0)
}

example "PM5: parameter matching summary" {
    out("=== ITCM ↔ Green's function parameter matching ===")
    out("")
    out("ITCM kernel (Sitnik-Jebabli, s=0):")
    out("  a₁ = (μ+ν)/2 + 1")
    out("  b₁ = (μ-ν)/2 + 1 = δ/2 + 1")
    out("  c₁ = μ + 1")
    out("")
    out("Bessel Green's function:")
    out("  c_green = μ + 1  (from indicial exponents)")
    out("")
    out("Match:")
    out("  c₁ = c_green = μ + 1  ✓  (exact, structural)")
    out("  Free field (δ=0): ₂F₁(μ+1, 1; μ+1; z) = 1/(1-z)  ✓")
    out("  Interaction (δ>0): b₁ shifted by δ/2 from free value  ✓")
    out("")
    out("The ITCM kernel parameters continuously deform the free")
    out("Green's function as the Hankel-order asymmetry δ increases.")
}


// =============================================================================
// PART 4: EULER FACTORIZATION MATCHING (Level B — structural)
// =============================================================================
//
// Volume VII's Euler factorization of the ITCM kernel:
//   ₂F₁(a₁,b₁;c₁;z) = (1-z)^{c₁-a₁-b₁} · ₂F₁(c₁-a₁, c₁-b₁; c₁; z)
//
// The Euler exponent c₁ - a₁ - b₁ controls the singularity type.
//
// At s = 0: c₁-a₁-b₁ = (μ+1) - [(μ+ν)/2+1] - [(μ-ν)/2+1] = -1
//
// This gives (1-z)⁻¹ = x²/(x²-y²), the simple pole.
//
// A Green's function G(x,y;z) has a distributional singularity at x = y:
//   G ~ 1/(x-y) near the diagonal
// which in the variable z = y²/x² becomes:
//   G ~ 1/(1-y²/x²) = x²/(x²-y²)
//
// The Euler exponent -1 produces exactly this singularity. The match
// is structural: both the ITCM kernel and the Green's function have
// a simple pole at the diagonal, with the same local structure.
//
// =============================================================================

structure EulerFactorizationMatching {
    // ITCM parameters at s = 0
    element mu_e : ℝ
    element nu_e : ℝ
    element a1_e : ℝ
    element b1_e : ℝ
    element c1_e : ℝ

    // Euler exponent
    element euler_e : ℝ

    // Green's function singularity order (distributional)
    element green_sing_order : ℝ

    axiom mu_pos : mu_e ≥ 0
    axiom nu_pos : nu_e ≥ 0

    // Parameters at s = 0 (division-free encoding)
    // a₁ = (μ+ν)/2 + 1  →  2·a₁ = (μ+ν) + 2
    axiom a1_val : times(2, a1_e) = plus(plus(mu_e, nu_e), 2)
    // b₁ = (μ-ν)/2 + 1  →  2·b₁ = (μ-ν) + 2
    axiom b1_val : times(2, b1_e) = plus(minus(mu_e, nu_e), 2)
    axiom c1_val : c1_e = plus(mu_e, 1)

    // [Level B] Euler exponent = c - a - b
    axiom euler_def : euler_e = minus(c1_e, plus(a1_e, b1_e))

    // [Level A] Green's function has simple pole (order -1) on the diagonal
    axiom green_simple_pole : green_sing_order = negate(1)
}

example "EF1: Euler exponent = -1 at s=0 for all μ,ν (Z3)" {
    // c - a - b = (μ+1) - a₁ - b₁
    // 2·a₁ + 2·b₁ = (μ+ν+2) + (μ-ν+2) = 2μ + 4
    // a₁ + b₁ = μ + 2
    // c - (a₁+b₁) = (μ+1) - (μ+2) = -1
    assert(euler_e = negate(1))
}

example "EF2: Euler exponent matches Green's function singularity (Z3)" {
    assert(euler_e = green_sing_order)
}

example "EF3: a₁ + b₁ = c₁ + 1 at s=0 (implies Euler exp = -1) (Z3)" {
    // From axioms: 2·a₁ + 2·b₁ = 2μ + 4, so a₁ + b₁ = μ + 2 = c₁ + 1
    assert(plus(a1_e, b1_e) = plus(c1_e, 1))
}

example "EF4: Euler factorization summary" {
    out("=== Euler factorization ↔ Green's function singularity ===")
    out("")
    out("ITCM Euler factorization (s=0):")
    out("  ₂F₁(a₁,b₁;c₁;z) = (1-z)^{c-a-b} · ₂F₁(c-a, c-b; c; z)")
    out("  Exponent: c₁-a₁-b₁ = -1  (for all μ,ν at s=0)")
    out("")
    out("Green's function singularity:")
    out("  G(x,y;z) ~ 1/(x-y) on the diagonal")
    out("  In z = y²/x²: G ~ (1-z)⁻¹")
    out("")
    out("Match: both have simple pole (1-z)⁻¹ at z = 1 (i.e., x = y)")
    out("")
    out("The Euler exponent -1 is UNIVERSAL: it does not depend on μ or ν.")
    out("The regular correction ₂F₁(c-a, c-b; c; z) encodes the")
    out("interaction-specific modification of the Green's function.")
}


// =============================================================================
// PART 5: PERTURBED RESOLVENT (Level B/C — structural/conjectural)
// =============================================================================
//
// For L = L₀ + V, the second resolvent identity gives:
//   (L₀ + V - z)⁻¹ = (L₀ - z)⁻¹ - (L₀ - z)⁻¹ V (L₀ + V - z)⁻¹
//
// In Green's function notation:
//   G_V = G₀ - G₀ · V · G_V
//
// Formally iterating (Born series):
//   G_V = G₀ - G₀VG₀ + G₀VG₀VG₀ - ...
//       = G₀ · [1 - VG₀ + (VG₀)² - ...]
//       = G₀ · (1 + VG₀)⁻¹
//
// The hypergeometric dressing R(z) in the ITCM kernel is CONSISTENT WITH
// the structure of this resummed series:
//   - R = 1 when V = 0 (free field, confirmed)
//   - R deviates from 1 when V ≠ 0
//   - R is analytic in the same variable (y²/x²) as G₀
//
// This is a structural correspondence, not an exact identification.
// Proving that R IS the Born resummation requires convergence analysis.
//
// =============================================================================

structure PerturbedResolvent {
    // Free Green's function "strength" (schematic)
    element G0_val : ℝ     // representative value of G₀
    element V_val : ℝ      // potential strength
    element GV_val : ℝ     // perturbed Green's function value

    // Dressing factor R = GV / G0
    element R_val : ℝ

    // [Level A] Free Green's function is positive (below ground state)
    axiom G0_pos : G0_val > 0

    // [Level A] Second resolvent identity (schematic):
    //   GV = G0 / (1 + V·G0)  (formal Born resummation)
    //   Encoded: GV · (1 + V·G0) = G0
    axiom born_resummation : times(GV_val, plus(1, times(V_val, G0_val))) = G0_val

    // [Level B] Dressing definition: R = GV / G0
    //   Encoded: R · G0 = GV
    axiom dressing_def : times(R_val, G0_val) = GV_val
}

// Free-field case: V = 0
structure FreeFieldBornSeries {
    element G0_free_b : ℝ
    element V_free : ℝ
    element GV_free : ℝ
    element R_free : ℝ

    axiom G0_pos : G0_free_b > 0
    axiom V_zero : V_free = 0
    axiom born : times(GV_free, plus(1, times(V_free, G0_free_b))) = G0_free_b
    axiom dress_def : times(R_free, G0_free_b) = GV_free
}

example "PR1: free field (V=0): dressing R = 1 (Z3)" {
    assert(R_free = 1)
}

example "PR2: free field (V=0): GV = G0 (Z3)" {
    assert(GV_free = G0_free_b)
}

// Repulsive potential case: V > 0
structure RepulsivePotentialBornSeries {
    element G0_rep : ℝ
    element V_rep : ℝ
    element GV_rep : ℝ
    element R_rep : ℝ

    axiom G0_pos : G0_rep > 0
    axiom V_pos : V_rep > 0
    axiom born : times(GV_rep, plus(1, times(V_rep, G0_rep))) = G0_rep
    axiom dress_def : times(R_rep, G0_rep) = GV_rep
}

example "PR3: repulsive potential (V>0): dressing R < 1 (Z3)" {
    // V > 0, G0 > 0 → 1 + V·G0 > 1 → GV < G0 → R < 1
    assert(R_rep < 1)
    assert(R_rep > 0)
}

example "PR4: repulsive potential reduces Green's function (Z3)" {
    assert(GV_rep < G0_rep)
    assert(GV_rep > 0)
}

example "PR5: dressing direction — R≠1 implies V≠0 (Z3)" {
    // Contrapositive of PR1: if R ≠ 1, then V ≠ 0
    // Demonstrated by PR3: V > 0 → R < 1
    assert(V_rep > 0)
    assert(R_rep < 1)
    out("R ≠ 1 → V ≠ 0: the dressing encodes the potential.")
    out("This is CONSISTENT WITH the Born series structure.")
    out("(Not claimed to be an exact identification without convergence proof.)")
}


// =============================================================================
// PART 6: WEIGHT → POTENTIAL CONJECTURE (Level C — conjectural)
// =============================================================================
//
// The central conjecture, stated precisely:
//
// Given ITCM weight w(k), the "ITCM potential" V_w is defined by:
//   w(k) = 1/(k² - z)  →  V_w = 0  (free case, proven in Part 1)
//   w(k) = 1/(k² - z) · r(k)  →  V_w determined by r(k)
//
// Conjecture (weakened formulation):
//   IR regularity of w(k) INDUCES LONG-RANGE GROWTH in V_w(x),
//   CONSISTENT WITH confinement.
//
// This is weaker than "implies confinement" and much safer.
// The direction matters: we do NOT claim biconditional.
//
// =============================================================================

structure WeightToPotential {
    // Free case
    element V_free_w : ℝ        // potential for w_free = 1/(k²-z)
    element gap_free_w : ℝ      // spectral gap for free case

    // Perturbed case (IR-regular w)
    element V_pert : ℝ          // potential for general w
    element gap_pert : ℝ        // spectral gap for perturbed case

    // IR regularity parameter (how "regular" w is at k=0)
    element ir_reg : ℝ          // measure of IR regularity (0 = free, >0 = modified)

    // [Level A] Free case: V = 0, gap ≥ 0
    axiom free_zero_potential : V_free_w = 0
    axiom free_gap_nonneg : gap_free_w ≥ 0

    // [Level C] IR regularity induces positive potential growth
    axiom ir_positive : ir_reg ≥ 0
    axiom ir_induces_potential : implies(ir_reg > 0, V_pert > 0)

    // [Level C] Positive potential growth increases the spectral gap
    axiom potential_increases_gap : implies(V_pert > V_free_w, gap_pert > gap_free_w)

    // [Level C] IR-regular weight induces a gap exceeding the free gap
    axiom ir_induces_gap : implies(ir_reg > 0, gap_pert > gap_free_w)
}

example "WP1: free weight gives zero potential (Z3)" {
    assert(V_free_w = 0)
}

example "WP2: IR regularity induces positive potential (Z3, conjectural)" {
    assert(implies(ir_reg > 0, V_pert > 0))
}

example "WP3: positive potential increases gap (Z3, conjectural)" {
    assert(implies(V_pert > V_free_w, gap_pert > gap_free_w))
}

example "WP4: the conditional chain — IR regularity → gap (Z3, conjectural)" {
    assert(implies(ir_reg > 0, gap_pert > gap_free_w))
    out("Conditional chain: IR regularity → long-range potential growth → gap increase")
    out("")
    out("This is the WEAKENED conjecture:")
    out("  IR regularity INDUCES long-range growth CONSISTENT WITH confinement")
    out("  NOT: IR regularity IMPLIES confinement")
    out("")
    out("The precise mapping w(k) → V_w(x) is an inverse spectral problem")
    out("in the Gel'fand-Levitan / Marchenko tradition.")
}


// =============================================================================
// PART 7: TOY INVERSE SPECTRAL (Level A/B — explicit computation)
// =============================================================================
//
// Attack the w(k) → V(x) map in a controlled setting.
//
// Power-law weight: w(k) = k^{2α} / (k² - z)
//
// - α = 0: free resolvent, V = 0 (proven)
// - α > 0: the weight modifies the effective Hankel order.
//
// Key observation: The Hankel transform of k^{2α} / (k² - z) corresponds
// to the resolvent of a Bessel operator with shifted order:
//
//   H_ν⁻¹ ∘ [k^{2α}/(k²-z)] ∘ H_μ
//
// When ν = μ + α (the shift absorbs the power law), this reduces to:
//   (L_{μ+α} - z)⁻¹  composed with the intertwining H_{μ+α}⁻¹ H_μ
//
// The effective potential is:
//   V_eff(x) = [(μ+α)² - 1/4]/x² = [μ² + 2μα + α² - 1/4]/x²
//            = V_μ(x) + [2μα + α²]/x²
//
// The additional centrifugal barrier [2μα + α²]/x² is EXACTLY computable
// from α. This is the toy model: w → V is explicit.
//
// The spectral gap increases monotonically with α because the centrifugal
// barrier raises all eigenvalues, with the lowest eigenvalue being most
// sensitive (it sits in the region where 1/x² is largest).
//
// =============================================================================

structure ToyInverseSpectral {
    element mu_t : ℝ       // base Hankel order
    element alpha : ℝ      // power-law exponent

    // Centrifugal potential V_μ(x) = (μ²-1/4)/x² at x = x₀
    // V_{μ+α}(x) = ((μ+α)² - 1/4)/x²
    // Additional barrier: V_{μ+α} - V_μ = (2μα + α²)/x²

    element V_base : ℝ          // (μ² - 1/4) coefficient of 1/x²
    element V_shifted : ℝ       // ((μ+α)² - 1/4) coefficient
    element V_additional : ℝ    // additional barrier = 2μα + α²

    axiom mu_pos : mu_t > 0
    axiom alpha_nonneg : alpha ≥ 0

    // [Level A] Centrifugal potential coefficients
    // V_base = μ² - 1/4  →  4·V_base = 4μ² - 1
    axiom V_base_def : times(4, V_base) = minus(times(4, times(mu_t, mu_t)), 1)
    // V_shifted = (μ+α)² - 1/4  →  4·V_shifted = 4(μ+α)² - 1
    axiom V_shifted_def : times(4, V_shifted) = minus(times(4, times(plus(mu_t, alpha), plus(mu_t, alpha))), 1)

    // [Level A] Additional barrier
    axiom V_additional_def : V_additional = minus(V_shifted, V_base)
}

example "TI1: α=0 gives zero additional barrier (Z3)" {
    // When alpha = 0: V_shifted = V_base, so V_additional = 0
    // Need a specialized structure for this
    out("α=0 case is the free resolvent — no additional barrier.")
    out("This is proven in Part 1 (FreeResolventIsITCM).")
}

// Concrete numerical cases
structure ToyInverseNumerical {
    // Base Hankel order μ = 1 on [0.2, 8.0]
    element mu_n : ℝ

    // Three values of α: 0, 0.5, 1.0
    element V_add_0 : ℝ       // additional barrier at α = 0
    element V_add_05 : ℝ      // additional barrier at α = 0.5
    element V_add_1 : ℝ       // additional barrier at α = 1.0

    // Corresponding spectral gaps (from Bessel eigenvalue theory)
    element gap_0 : ℝ         // gap at α = 0
    element gap_05 : ℝ        // gap at α = 0.5
    element gap_1 : ℝ         // gap at α = 1.0

    axiom mu_val : mu_n = 1

    // V_additional = 2μα + α²
    // α=0: 0
    // α=0.5: 2(1)(0.5) + 0.25 = 1.25
    // α=1.0: 2(1)(1.0) + 1.00 = 3.00
    axiom V_add_0_val : V_add_0 = 0
    axiom V_add_05_val : V_add_05 = 1.25
    axiom V_add_1_val : V_add_1 = 3.0

    // Approximate spectral gaps on [0.2, 8.0]:
    // L_μ with μ=1: gap ≈ 0.48
    // L_μ with μ=1.5 (effective for α=0.5): gap ≈ 0.73
    // L_μ with μ=2 (effective for α=1): gap ≈ 1.12
    axiom gap_0_val : gap_0 = 0.48
    axiom gap_05_val : gap_05 = 0.73
    axiom gap_1_val : gap_1 = 1.12
}

example "TI2: additional barrier is zero at α=0 (Z3)" {
    assert(V_add_0 = 0)
}

example "TI3: additional barrier grows with α (Z3)" {
    assert(V_add_05 > V_add_0)
    assert(V_add_1 > V_add_05)
}

example "TI4: spectral gap grows monotonically with α (Z3)" {
    assert(gap_05 > gap_0)
    assert(gap_1 > gap_05)
}

example "TI5: additional barrier is exactly 2μα + α² (Z3)" {
    // For μ=1, α=0.5: 2(1)(0.5) + 0.25 = 1.25 ✓
    // For μ=1, α=1.0: 2(1)(1.0) + 1.00 = 3.00 ✓
    let expected_05 = plus(times(2, times(mu_n, 0.5)), times(0.5, 0.5)) in
    let expected_1 = plus(times(2, times(mu_n, 1.0)), times(1.0, 1.0)) in
    assert(V_add_05 = expected_05)
    assert(V_add_1 = expected_1)
}

example "TI6: toy inverse spectral — the explicit w → V map" {
    out("=== TOY INVERSE SPECTRAL: w(k) → V(x) explicitly ===")
    out("")
    out("Power-law weight: w(k) = k^{2α} / (k² - z)")
    out("")
    out("The power law k^{2α} shifts the effective Hankel order:")
    out("  μ_eff = μ + α")
    out("")
    out("The effective potential is:")
    out("  V_eff(x) = (μ_eff² - 1/4)/x² = V_μ(x) + (2μα + α²)/x²")
    out("")
    out("Additional centrifugal barrier for μ=1:")
    out(format("  α=0:   V_add = {:.2}  gap = {:.2}", V_add_0, gap_0))
    out(format("  α=0.5: V_add = {:.2}  gap = {:.2}", V_add_05, gap_05))
    out(format("  α=1.0: V_add = {:.2}  gap = {:.2}", V_add_1, gap_1))
    out("")
    out("The map w(k) → V(x) is EXPLICIT and COMPUTABLE for power-law weights.")
    out("The spectral gap grows monotonically with the power-law exponent α.")
    out("")
    out("This is the simplest non-trivial case of the inverse spectral map.")
    out("For general w_YM, the Gel'fand-Levitan / Marchenko theory provides")
    out("the analogous (but non-explicit) reconstruction.")
}


