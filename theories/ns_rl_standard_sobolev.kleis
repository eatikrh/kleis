// Standard NS (α=1) with same structure as hyperviscous test
// BUT with the weaker Sobolev: grad_v_inf ≤ H32 (NOT ≤ √P54)
//
// This is the CONTROL: same axioms except the Sobolev bound
// comes from H^{3/2}, which is NOT the dissipation.
// Growth should be SAT (the gap remains).

structure NS_Standard_Sobolev {
    element Omega : ℝ
    element H32 : ℝ
    element P : ℝ
    element S : ℝ
    element grad_v_inf : ℝ
    element dOmega_dt : ℝ

    axiom Omega_pos : Omega > 0
    axiom H32_pos : H32 > 0
    axiom P_pos : P > 0
    axiom S_nonneg : S ≥ 0
    axiom grad_nonneg : grad_v_inf ≥ 0

    // enstrophy eq with ν=1: dΩ/dt = S - 2·P
    axiom enstrophy_eq : dOmega_dt = plus(S, negate(times(2, P)))

    // Stretching
    axiom stretching : S ≤ times(grad_v_inf, Omega)

    // Standard Sobolev (α=1): grad_v_inf ≤ H32
    // H32 is NOT the dissipation (P is)
    axiom sobolev_standard : grad_v_inf ≤ H32

    // Interpolation: H32² ≤ Ω·P
    axiom interpolation : times(H32, H32) ≤ times(Omega, P)

    // Norm ordering
    axiom norm_low : Omega ≤ H32
    axiom norm_high : H32 ≤ P
    axiom poincare : P ≥ Omega

    // Large enstrophy
    axiom large_omega : Omega > 10

    // TEST: growth possible? (expect SAT — the gap is real)
    axiom growth : dOmega_dt > 0
}

example "Standard α=1: growth still possible? (expect SAT)" {
    assert(dOmega_dt > 0)
}
