// =============================================================================
// POT YM-Darboux IR Matching
// =============================================================================
//
// Generalizes the Darboux superpotential to a one-parameter family:
//
//   W_α(x) = (μ+1/2)/x + c · x^α     (α > 0, c > 0)
//
// The partner potential has dominant large-x behavior:
//
//   V_+(x) ~ c² · x^{2α}
//
// Connection to the IR classification:
//   p = 2α  (potential growth power)
//   β = α + 1  (IR singularity exponent)
//
// So the Darboux family spans ALL confining IR classes β > 1:
//   α = 1/2  →  β = 3/2, V ~ x    (linear confinement, QCD string)
//   α = 1    →  β = 2,   V ~ x²   (harmonic confinement)
//   α = 3/2  →  β = 5/2, V ~ x³   (super-confining)
//
// The Yang-Mills IR regime: lattice data gives γ ≈ 0.5, so β = 1.5,
// which corresponds to α = 0.5 — EXACTLY the linear confinement member.
//
// Important caveat: W_α is algebraically well-defined as a superpotential
// for all α > 0, and the V_+ formula + spectral consequences are Level A.
// The full SUSY partner relationship (isospectrality, intertwining) is
// rigorously established for α = 1 (exact factorization) and structural
// for general α (Level B).
//
// No stdlib import — pure Z3 theory file.
//
// =============================================================================


// =============================================================================
// PART 1: GENERAL SUPERPOTENTIAL FAMILY (Level A)
// =============================================================================
//
// W_α(x) = (μ+1/2)/x + c · x^α     (α > 0, c > 0)
//
// For large x, the dominant term in V_+ = W² + W' is:
//   V_+(x) ~ c² · x^{2α}
//
// The growth power p = 2α connects to the IR classification:
//   β = p/2 + 1 = α + 1
//
// Therefore:
//   α > 0  ⟺  β > 1  ⟺  confining
//
// The family continuously parameterizes all confining classes.
//
// =============================================================================

structure GeneralSuperpotentialFamily {
    element alpha_g : ℝ       // superpotential exponent
    element beta_g : ℝ        // corresponding IR exponent
    element p_g : ℝ            // potential growth power

    // [Level A] α > 0 (confining regime)
    axiom alpha_pos : alpha_g > 0

    // [Level A] p = 2α (dominant large-x behavior of V_+)
    axiom p_def : p_g = times(2, alpha_g)

    // [Level A] β = α + 1 (connection to IR classification)
    axiom beta_def : beta_g = plus(alpha_g, 1)
}

structure SuperpotentialNumerical {
    // Specific (α, β, p) triples
    element alpha_half : ℝ
    element beta_half : ℝ
    element p_half : ℝ

    element alpha_one : ℝ
    element beta_one : ℝ
    element p_one : ℝ

    element alpha_15 : ℝ
    element beta_15 : ℝ
    element p_15 : ℝ

    axiom a_half : alpha_half = 0.5
    axiom b_half : beta_half = plus(alpha_half, 1)
    axiom p_half_def : p_half = times(2, alpha_half)

    axiom a_one : alpha_one = 1
    axiom b_one : beta_one = plus(alpha_one, 1)
    axiom p_one_def : p_one = times(2, alpha_one)

    axiom a_15 : alpha_15 = 1.5
    axiom b_15 : beta_15 = plus(alpha_15, 1)
    axiom p_15_def : p_15 = times(2, alpha_15)
}

example "GF1: α > 0 iff β > 1 — the confining equivalence (Z3)" {
    assert(alpha_g > 0)
    assert(beta_g > 1)
}

example "GF2: α = 0.5 gives β = 1.5, p = 1 (linear) (Z3)" {
    assert(alpha_half = 0.5)
    assert(beta_half = 1.5)
    assert(p_half = 1)
}

example "GF3: α = 1 gives β = 2, p = 2 (harmonic) (Z3)" {
    assert(alpha_one = 1)
    assert(beta_one = 2)
    assert(p_one = 2)
}

example "GF4: larger α gives stronger confinement (Z3)" {
    assert(p_15 > p_one)
    assert(p_one > p_half)
    assert(beta_15 > beta_one)
    assert(beta_one > beta_half)
}

example "GF5: the general superpotential family" {
    out("=== GENERAL SUPERPOTENTIAL FAMILY (Level A) ===")
    out("")
    out("W_α(x) = (μ+1/2)/x + c · x^α     (α > 0, c > 0)")
    out("")
    out("Dominant large-x behavior: V_+(x) ~ c² · x^{2α}")
    out("")
    out("Connection to IR classification:")
    out("  p = 2α  (growth power)")
    out("  β = α + 1  (IR exponent)")
    out("")
    out(format("  α = {:.1}  →  β = {:.1}, p = {:.0}  (linear, QCD string)", alpha_half, beta_half, p_half))
    out(format("  α = {:.0}    →  β = {:.0},   p = {:.0}  (harmonic)", alpha_one, beta_one, p_one))
    out(format("  α = {:.1}  →  β = {:.1}, p = {:.0}  (super-confining)", alpha_15, beta_15, p_15))
    out("")
    out("The family spans ALL confining IR classes β > 1.")
    out("This is a universality class generator.")
}


// =============================================================================
// PART 2: LINEAR CONFINING DARBOUX (Level A/B — the QCD member)
// =============================================================================
//
// Specialization: α = 1/2
//
//   W_{1/2}(x) = (μ+1/2)/x + c·√x
//
// For large x:
//   V_+(x) ~ c² · x   (linear confinement)
//
// The eigenvalues follow the Airy scaling:
//   E_n = σ^{2/3} · |a_n|    where σ = c² (effective string tension)
//
// Gap = σ^{2/3} · (a₂ - a₁) ≈ σ^{2/3} · 1.750
//
// This is the QCD string model: quarks connected by a flux tube with
// tension σ, producing linear confinement and a gap proportional to σ^{2/3}.
//
// The SUSY connection for α = 1/2 is structural (Level B):
//   - The superpotential W = (μ+1/2)/x + c√x is well-defined
//   - The potential formula V_+ is algebraically correct (Level A)
//   - The SUSY partner relationship is model-dependent for non-integer α
//   - The spectral consequences (Rellich-Molchanov, Airy scaling) are Level A
//
// =============================================================================

structure LinearConfiningDarboux {
    element c_lc : ℝ           // superpotential parameter
    element sigma_lc : ℝ       // effective string tension = c²
    element alpha_lc : ℝ       // = 1/2
    element beta_lc : ℝ        // = 3/2
    element p_lc : ℝ           // = 1

    // Airy zeros
    element a1_lc : ℝ
    element a2_lc : ℝ

    element E0_lc : ℝ
    element E1_lc : ℝ
    element gap_lc : ℝ

    // [Level A] Parameters
    axiom c_pos : c_lc > 0
    axiom alpha_val : alpha_lc = 0.5
    axiom beta_val : beta_lc = plus(alpha_lc, 1)
    axiom p_val : p_lc = times(2, alpha_lc)

    // [Level A] String tension: σ = c²
    axiom sigma_def : sigma_lc = times(c_lc, c_lc)

    // [Level A] Airy zeros
    axiom a1_val : a1_lc = 2.3381
    axiom a2_val : a2_lc = 4.0879

    // [Level A] Eigenvalue Airy scaling: E_n = σ^{2/3} · a_n
    // For σ = 1 (c = 1): E_n = a_n directly
    // General σ: need σ^{2/3} factor

    // [Level A] Gap for σ = 1: gap = a₂ - a₁ ≈ 1.750
    axiom gap_airy : gap_lc = minus(a2_lc, a1_lc)
}

structure LinearDarbouxNumerical_c1 {
    // c = 1, σ = 1, σ^{2/3} = 1
    element E0_c1 : ℝ
    element E1_c1 : ℝ
    element gap_c1 : ℝ

    axiom E0_val : E0_c1 = 2.3381
    axiom E1_val : E1_c1 = 4.0879
    axiom gap_val : gap_c1 = 1.7498
    axiom gap_check : gap_c1 = minus(E1_c1, E0_c1)
}

example "LD1: α = 1/2 gives linear confinement (Z3)" {
    assert(alpha_lc = 0.5)
    assert(beta_lc = 1.5)
    assert(p_lc = 1)
}

example "LD2: gap from Airy zeros (Z3)" {
    assert(gap_lc = minus(a2_lc, a1_lc))
    assert(gap_lc > 1.7)
    assert(gap_lc < 1.8)
}

example "LD3: numerical c = 1, gap ≈ 1.750 (Z3)" {
    assert(gap_c1 = minus(E1_c1, E0_c1))
    assert(gap_c1 > 1.74)
    assert(gap_c1 < 1.76)
}

example "LD4: string tension σ = c² (Z3)" {
    assert(sigma_lc = times(c_lc, c_lc))
    assert(sigma_lc > 0)
}

example "LD5: linear confinement — the QCD string member" {
    out("=== LINEAR CONFINING DARBOUX (α = 1/2, Level A/B) ===")
    out("")
    out("W_{1/2}(x) = (μ+1/2)/x + c·√x")
    out("")
    out("Dominant behavior: V_+(x) ~ c²·x = σ·x  (linear confinement)")
    out("")
    out("Airy scaling: E_n = σ^{2/3} · |a_n|")
    out(format("  a₁ = {:.4}, a₂ = {:.4}", a1_lc, a2_lc))
    out(format("  σ = 1: gap = {:.4}", gap_c1))
    out("")
    out("This is the QCD string model:")
    out("  Quarks connected by flux tube with tension σ")
    out("  Gap ~ σ^{2/3} · 1.750")
    out("")
    out("The SUSY connection for α = 1/2 is structural (Level B).")
    out("The spectral consequences are rigorous (Level A).")
}


// =============================================================================
// PART 3: HARMONIC DARBOUX RECOVERED (Level A — cross-check)
// =============================================================================
//
// Specialization: α = 1 (recovers the existing DarbouxConfining from
// pot_weight_families.kleis)
//
//   W_1(x) = (μ+1/2)/x + c·x   (with c = ω)
//
// V_+(x) = (μ²-1/4)/x² + (2μ+2)c + c²x²
//
// Gap = 4c (exact harmonic oscillator formula)
//
// This cross-checks that the general family is consistent with the
// established exact result.
//
// =============================================================================

structure HarmonicDarbouxRecovered {
    element c_hr : ℝ          // = ω in the original DarbouxConfining
    element alpha_hr : ℝ      // = 1
    element beta_hr : ℝ       // = 2
    element gap_hr : ℝ        // = 4c

    axiom c_pos : c_hr > 0
    axiom alpha_val : alpha_hr = 1
    axiom beta_val : beta_hr = plus(alpha_hr, 1)

    // [Level A] Gap = 4c (exact, from radial harmonic oscillator)
    axiom gap_exact : gap_hr = times(4, c_hr)
}

structure HarmonicRecoveredNumerical {
    // c = 0.5 (matching ω = 0.5 from DarbouxConfining)
    element c_hrn : ℝ
    element gap_hrn : ℝ

    axiom c_val : c_hrn = 0.5
    axiom gap_val : gap_hrn = times(4, c_hrn)
}

example "HR1: α = 1 gives β = 2 (harmonic) (Z3)" {
    assert(alpha_hr = 1)
    assert(beta_hr = 2)
}

example "HR2: gap = 4c (exact harmonic formula) (Z3)" {
    assert(gap_hr = times(4, c_hr))
    assert(gap_hr > 0)
}

example "HR3: numerical c = 0.5, gap = 2.0 (cross-check) (Z3)" {
    assert(c_hrn = 0.5)
    assert(gap_hrn = 2.0)
}


// =============================================================================
// PART 4: GAP SCALING (Level A/B)
// =============================================================================
//
// For power-law confinement V ~ A · x^p, the spectral gap scales as:
//
//   gap ~ A^{2/(p+2)} · const(p)
//
// In the Darboux family, V_+ ~ c² · x^{2α}, so A = c², p = 2α:
//
//   gap ~ (c²)^{2/(2α+2)} · const(α) = c^{2/(α+1)} · const(α)
//
// The gap exponent 2/(α+1) encodes how the gap depends on the
// coupling strength c:
//
//   α = 1/2: exponent = 2/(3/2) = 4/3  (linear, gap ~ c^{4/3})
//   α = 1:   exponent = 2/2     = 1    (harmonic, gap ~ c = gap = 4c)
//   α = 3/2: exponent = 2/(5/2) = 4/5  (super-confining, gap ~ c^{4/5})
//
// Stronger confinement (larger α) makes the gap LESS sensitive to c.
//
// =============================================================================

structure GapScalingExponent {
    element alpha_gs : ℝ       // Darboux exponent
    element exponent : ℝ       // gap scaling exponent = 2/(α+1)

    axiom alpha_pos : alpha_gs > 0

    // [Level A/B] Gap exponent: exp = 2/(α+1)
    //   Encoded: exp · (α + 1) = 2
    axiom exp_def : times(exponent, plus(alpha_gs, 1)) = 2
}

structure GapScalingNumerical {
    // Three specific cases
    element exp_half : ℝ       // α = 1/2: exponent = 4/3
    element exp_one : ℝ        // α = 1: exponent = 1
    element exp_15 : ℝ         // α = 3/2: exponent = 4/5

    // exp · (α + 1) = 2
    axiom exp_half_def : times(exp_half, 1.5) = 2
    axiom exp_one_def : times(exp_one, 2) = 2
    axiom exp_15_def : times(exp_15, 2.5) = 2
}

structure GapScalingVerification {
    // Verify gap = const · c^{exponent} for known cases
    element c_ver : ℝ
    element gap_linear_ver : ℝ     // α = 1/2, const ≈ 1.750
    element gap_harmonic_ver : ℝ   // α = 1, const = 4

    axiom c_val : c_ver = 1

    // For c = 1: gap = const · 1^{anything} = const
    axiom gap_lin_val : gap_linear_ver = 1.7498
    axiom gap_harm_val : gap_harmonic_ver = 4.0
}

example "GS1: gap exponent decreases with α (Z3)" {
    assert(exp_half > exp_one)
    assert(exp_one > exp_15)
}

example "GS2: α = 1/2, exponent = 4/3 (Z3)" {
    // 4/3 · 3/2 = 2 ✓
    assert(times(exp_half, 1.5) = 2)
    assert(exp_half > 1)
}

example "GS3: α = 1, exponent = 1 (Z3)" {
    assert(exp_one = 1)
}

example "GS4: gap constants match known results (Z3)" {
    // For c = 1: linear gap ≈ 1.750, harmonic gap = 4.0
    assert(gap_harmonic_ver > gap_linear_ver)
    assert(gap_linear_ver > 1.7)
    assert(gap_harmonic_ver = 4.0)
}

example "GS5: the gap scaling law" {
    out("=== GAP SCALING (Level A/B) ===")
    out("")
    out("For V ~ c²·x^{2α}: gap ~ c^{2/(α+1)} · const(α)")
    out("")
    out(format("  α = 0.5: exponent = {:.4}, const ≈ 1.750  (linear)", exp_half))
    out(format("  α = 1.0: exponent = {:.0},     const = 4.0    (harmonic)", exp_one))
    out(format("  α = 1.5: exponent = {:.4}, const = ?      (super-confining)", exp_15))
    out("")
    out("Stronger confinement (larger α) makes the gap")
    out("LESS sensitive to the coupling c.")
    out("")
    out("At c = 1:")
    out(format("  linear gap  = {:.4}", gap_linear_ver))
    out(format("  harmonic gap = {:.1}", gap_harmonic_ver))
}


// =============================================================================
// PART 5: YANG-MILLS IR MATCHING (Level B/C)
// =============================================================================
//
// The central matching argument.
//
// From lattice QCD (Level C input):
//   Anomalous dimension: γ ≈ 0.5
//   IR exponent: β_YM = 1 + γ ≈ 1.5
//   Growth power: p_YM = 2γ ≈ 1
//
// From the Darboux family (Level A):
//   α = β - 1 = 0.5
//   V_+(x) ~ c²·x  (linear confinement)
//   Gap ~ σ^{2/3} · 1.750  where σ = c²
//
// The matching:
//   The YM IR exponent β = 1.5 places it at EXACTLY the α = 1/2
//   member of the Darboux family — the linear confinement regime.
//
// This is:
//   - Verified at the level of IR asymptotics (Level B)
//   - Not a rigorous identification of w_YM with a specific Darboux
//     transformation (Level C for the full claim)
//
// Falsifiable prediction:
//   If the matching holds, the YM mass gap scales as σ^{2/3} · 1.750
//   where σ is the QCD string tension.
//
// =============================================================================

structure YMIRMatching {
    // Lattice input (Level C)
    element gamma_ym : ℝ       // anomalous dimension
    element beta_ym : ℝ        // IR exponent

    // Darboux family parameter (Level A)
    element alpha_ym : ℝ       // Darboux exponent matching YM

    // Potential and gap (Level A once α is fixed)
    element p_ym : ℝ           // growth power
    element sigma_ym : ℝ       // effective string tension
    element gap_ym : ℝ         // predicted gap

    // Airy constant
    element airy_const : ℝ

    // [Level C] Lattice input: γ ≈ 0.5
    axiom gamma_val : gamma_ym = 0.5

    // [Level C] β = 1 + γ
    axiom beta_def : beta_ym = plus(1, gamma_ym)

    // [Level B] Darboux matching: α = β - 1 = γ
    axiom alpha_def : alpha_ym = minus(beta_ym, 1)

    // [Level A] Growth power: p = 2α
    axiom p_def : p_ym = times(2, alpha_ym)

    // [Level A] Airy gap constant
    axiom airy_val : airy_const = 1.7498

    // [Level C] String tension (free parameter from QCD)
    axiom sigma_pos : sigma_ym > 0

    // [Level B/C] Gap prediction: gap = σ^{2/3} · 1.750
    //   For σ = 1: gap = 1.750
    //   Encoded for σ = 1 case:
    axiom gap_prediction : gap_ym = airy_const
}

structure YMMatchingComparison {
    // Compare α = 0.5 Darboux with α = 1 Darboux
    element gap_ym_pred : ℝ    // predicted YM gap at σ = 1
    element gap_harmonic : ℝ   // harmonic gap at c = 1

    axiom ym_val : gap_ym_pred = 1.7498
    axiom harm_val : gap_harmonic = 4.0

    // YM gap is smaller than harmonic (less confining)
    axiom ym_less : gap_ym_pred < gap_harmonic
}

example "YM1: lattice γ = 0.5 gives α = 0.5 (Z3)" {
    assert(gamma_ym = 0.5)
    assert(alpha_ym = 0.5)
}

example "YM2: YM matches linear confinement β = 1.5 (Z3)" {
    assert(beta_ym = 1.5)
    assert(p_ym = 1)
}

example "YM3: gap prediction at σ = 1 (Z3)" {
    assert(gap_ym = 1.7498)
    assert(gap_ym > 0)
}

example "YM4: YM gap < harmonic gap (less confining) (Z3)" {
    assert(gap_ym_pred < gap_harmonic)
}

example "YM5: Yang-Mills IR matching — the central result" {
    out("=== YANG-MILLS IR MATCHING (Level B/C) ===")
    out("")
    out("LATTICE INPUT (Level C):")
    out(format("  Anomalous dimension: γ = {:.1}", gamma_ym))
    out(format("  IR exponent: β = 1 + γ = {:.1}", beta_ym))
    out("")
    out("DARBOUX MATCHING (Level B):")
    out(format("  α = β - 1 = {:.1}", alpha_ym))
    out(format("  p = 2α = {:.0} (linear confinement)", p_ym))
    out("")
    out("PREDICTION (Level C):")
    out(format("  V_+(x) ~ σ·x  where σ = string tension"))
    out(format("  Gap = σ^{{2/3}} · {:.4}", airy_const))
    out("")
    out("The YM IR exponent places it at EXACTLY the α = 1/2 member")
    out("of the Darboux family — the linear confinement regime.")
    out("")
    out("This is CONSISTENT WITH:")
    out("  - QCD string picture (flux tube between quarks)")
    out("  - Lattice gluon propagator IR behavior")
    out("  - Cornell potential (V ~ σr) phenomenology")
    out("")
    out("This is NOT a proof that w_YM IS in the Darboux class.")
    out("It is an IR asymptotics matching.")
}


