// NS + Alignment with sub-threshold viscosity
//
// Same alignment axiom S² ≤ Ω·P, but now viscosity is below the
// critical threshold ν = 1/2.
//
// With ν free (just ν > 0), growth requires 1 > 4ν². For small ν,
// this is satisfiable. So the alignment axiom alone does not close
// the gap for all viscosities — it creates a viscosity-dependent
// threshold, analogous to the Lions threshold for hyperviscosity.
//
// We encode this by leaving ν free with ν > 0.

structure NS_Alignment_FreeNu {
    element Omega : ℝ
    element P : ℝ
    element S : ℝ
    element nu : ℝ
    element dOmega_dt : ℝ

    axiom Omega_pos : Omega > 0
    axiom P_pos : P > 0
    axiom S_nonneg : S ≥ 0
    axiom nu_pos : nu > 0

    // enstrophy equation: dΩ/dt = S - 2ν·P
    axiom enstrophy_eq : dOmega_dt = plus(S, negate(times(times(2, nu), P)))

    axiom poincare : P ≥ Omega

    // SAME alignment axiom
    axiom alignment : times(S, S) ≤ times(Omega, P)

    axiom large_omega : Omega > 10

    // TEST: growth with free ν (expect SAT — Z3 picks small ν)
    axiom growth : dOmega_dt > 0
}

example "Alignment S²≤Ω·P with free ν: growth? (expect SAT)" {
    assert(dOmega_dt > 0)
}
