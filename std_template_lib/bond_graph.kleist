    graph_width: "48"
    graph_height: "48"
}

// ============ 2-PORT ELEMENTS ============

@template bg_transformer {
    pattern: "bg_transformer()"
    typst: "#box(image(\"static/svg/bond_graph/TF.svg\", width: 1.5em, height: 1em, fit: \"contain\"))"
    unicode: "TF"
    category: "bond_2port"
    glyph: "TF"
    mode: "content"
    svg: "static/svg/bond_graph/TF.svg"
    component_type: "Transformer"
    causality_type: "constrained_tf"
    ports: "left:0,0.5;right:1,0.5"
    graph_width: "64"
    graph_height: "48"
}

@template bg_gyrator {
    pattern: "bg_gyrator()"
    typst: "#box(image(\"static/svg/bond_graph/GY.svg\", width: 1.5em, height: 1em, fit: \"contain\"))"
