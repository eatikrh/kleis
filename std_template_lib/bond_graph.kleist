    category: "bond_1port"
    glyph: "R"
    mode: "content"
    svg: "static/svg/bond_graph/R.svg"
    component_type: "Resistor"
    causality_type: "indifferent"
    ports: "port:0.5,0.5"
    graph_width: "48"
    graph_height: "48"
}

@template bg_capacitor {
