// ============ JUNCTIONS ============

@template bg_junction_0 {
    pattern: "bg_junction_0()"
    typst: "#box(image(\"static/svg/bond_graph/junction_0.svg\", width: 1em, height: 1em, fit: \"contain\"))"
    unicode: "0"
    category: "bond_junction"
    glyph: "0"
    mode: "content"
    svg: "static/svg/bond_graph/junction_0.svg"
    component_type: "Junction0"
    causality_type: "constrained_0junc"
    ports: "top:0.5,0;right:1,0.5;bottom:0.5,1;left:0,0.5"
    graph_width: "48"
    graph_height: "48"
}

@template bg_junction_1 {
    pattern: "bg_junction_1()"
    typst: "#box(image(\"static/svg/bond_graph/junction_1.svg\", width: 1em, height: 1em, fit: \"contain\"))"
