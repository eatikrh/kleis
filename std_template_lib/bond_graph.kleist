    glyph: "C"
    mode: "content"
    svg: "static/svg/bond_graph/C.svg"
    component_type: "Capacitor"
    causality_type: "preferred_effort_out"
    ports: "port:0.5,0.5"
    graph_width: "48"
    graph_height: "48"
}

@template bg_inertia {
    pattern: "bg_inertia()"
