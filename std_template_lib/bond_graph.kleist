// Bond Graph Templates for Kleis Graph Editor
//
// Bond graphs model energy flow across physical domains (mechanical, electrical,
// hydraulic, thermal) using nine fundamental elements connected by power bonds.
//
// Visual notation:
//   - Half-arrow on bond: assumed positive energy flow direction
//   - Causal stroke (perpendicular bar): which port imposes effort vs flow
//
// Metadata fields:
//   component_type: unique per element for Z3 verification
//     "EffortSource" | "FlowSource" | "Resistor" | "Capacitor" | "Inertia"
//     "Transformer" | "Gyrator" | "Junction0" | "Junction1"
//   causality_type: SCAP constraint category for future automatic assignment
//     - "fixed_effort_out"     (Se: stroke always away)
//     - "fixed_flow_out"       (Sf: stroke always towards)
//     - "preferred_effort_out" (C: integral causality preference)
//     - "preferred_flow_out"   (I: integral causality preference)
//     - "indifferent"          (R: either direction)
//     - "constrained_tf"       (TF: one port effort-out, other flow-out)
//     - "constrained_gy"       (GY: both ports same causality)
//     - "constrained_0junc"    (0-junction: exactly one bond has stroke at junction side)
//     - "constrained_1junc"    (1-junction: exactly one bond has stroke away from junction)
//   ports: "name:relX,relY;..." (relative 0-1 coords within component bounding box)

// ============ DOMAIN CONFIGURATION ============

@template __domain_bond_graph {
    pattern: "__domain_bond_graph()"
    category: "__domain"
    routing_mode: "direct"
    junction_style: "dot"
    multi_port_strategy: "star"
    edge_decoration: "half_arrow"
    edge_direction: "directed"
    verify_causality: "true"
    verify_no_isolated: "true"
    verify_theory: "bond_graph"
}

// ============ SOURCES ============

@template bg_effort_source {
    pattern: "bg_effort_source()"
    typst: "#box(image(\"static/svg/bond_graph/Se.svg\", width: 1em, height: 1em, fit: \"contain\"))"
    unicode: "Se"
    category: "bond_source"
    glyph: "Se"
    mode: "content"
    svg: "static/svg/bond_graph/Se.svg"
    component_type: "EffortSource"
    causality_type: "fixed_effort_out"
    ports: "port:0.5,0.5"
    graph_width: "48"
    graph_height: "48"
}

@template bg_flow_source {
    pattern: "bg_flow_source()"
    typst: "#box(image(\"static/svg/bond_graph/Sf.svg\", width: 1em, height: 1em, fit: \"contain\"))"
    unicode: "Sf"
    category: "bond_source"
    glyph: "Sf"
    mode: "content"
    svg: "static/svg/bond_graph/Sf.svg"
    component_type: "FlowSource"
    causality_type: "fixed_flow_out"
    ports: "port:0.5,0.5"
    graph_width: "48"
    graph_height: "48"
}

