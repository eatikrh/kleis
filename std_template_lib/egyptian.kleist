// ============================================================================
// Egyptian Hieroglyphs - Gardiner Sign List (Core Set)
// ============================================================================
// Part of Kleis Standard Template Library
// File: std_template_lib/egyptian.kleist
// Source: PharaLex (MIT License) - https://github.com/cursedcoder/pharalex
//
// Each hieroglyph is a zero-argument template that renders as an inline SVG
// image via Typst. Gardiner codes are used as template names.

// ============ A: MAN ============

@template A1 {
    pattern: "A1()"
    typst: "#box(image(\"static/glyphs/egyptian/A1.svg\", height: 1.5em))"
    unicode: "A1"
    category: "egyptian_A_man"
    glyph: "A1"
    svg: "static/glyphs/egyptian/A1.svg"
}

