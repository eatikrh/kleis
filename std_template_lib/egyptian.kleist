// ============ QUADRAT COMPOSITION ============

@template quadrat_h {
    pattern: "quadrat_h(left, right)"
    typst: "#grid(columns: 2, gutter: 1pt, {left}, {right})"
    unicode: "{left}{right}"
    category: "egyptian_composition"
    glyph: "H-pair"
}

@template quadrat_v {
    pattern: "quadrat_v(top, bottom)"
    typst: "#stack(dir: ttb, spacing: 1pt, {top}, {bottom})"
    unicode: "{top}/{bottom}"
    category: "egyptian_composition"
    glyph: "V-pair"
}

@template quadrat_2x2 {
    pattern: "quadrat_2x2(tl, tr, bl, br)"
    typst: "#grid(columns: 2, gutter: 1pt, {tl}, {tr}, {bl}, {br})"
    unicode: "{tl}{tr}/{bl}{br}"
    category: "egyptian_composition"
    glyph: "2x2"
}

