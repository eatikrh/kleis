    typst: "#box(image(\"static/glyphs/egyptian/Z5.svg\", height: 1.5em))"
    unicode: "Z5"
    category: "egyptian_Z_stroke"
    glyph: "Z5"
    svg: "static/glyphs/egyptian/Z5.svg"
}

