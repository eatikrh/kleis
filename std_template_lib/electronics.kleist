// ============================================================================
// Electronic Components - IEC Standard Symbols
// ============================================================================
// Part of Kleis Standard Template Library
// File: std_template_lib/electronics.kleist
//
// Each component is a zero-argument template that renders as an inline SVG
// image via Typst. Components are organized by functional category.
//
// Metadata fields:
//   component_type: "Passive" | "Active" | "Source" | "Connector" | "Measurement"
//   package:        "Through-hole" | "SMD" | "Module" | "Symbol"
//   symbol_standard: "IEC" | "ANSI"
//   ports:          "name:relX,relY;name:relX,relY;..." (relative 0-1 coords)
//   graph_width:    display width on graph canvas (px)
//   graph_height:   display height on graph canvas (px)

// ============ GRAPH DOMAIN CONFIG ============
// Tells the Graph Editor how to route wires and render edges for this domain.

@template __domain_electronics {
    pattern: "__domain_electronics()"
    category: "__domain"
    routing_mode: "orthogonal"
    junction_style: "dot"
    multi_port_strategy: "trunk_branch"
    edge_decoration: "none"
    edge_direction: "undirected"
    verify_requires_type: "VoltageSource"
    verify_no_isolated: "true"
    verify_theory: "electronics"
}

// ============ PASSIVE COMPONENTS ============

@template resistor {
    pattern: "resistor()"
    typst: "#box(image(\"static/svg/electronics/resistor.svg\", width: 2em, height: 1em, fit: \"contain\"))"
    unicode: "R"
    category: "electronics_passive"
    glyph: "R"
    mode: "content"
    svg: "static/svg/electronics/resistor.svg"
    component_type: "Passive"
    package: "Through-hole"
    symbol_standard: "IEC"
    params: "R:real:1000"
    ports: "left:0,0.5;right:1,0.5"
    graph_width: "64"
    graph_height: "32"
}

@template capacitor {
    pattern: "capacitor()"
    typst: "#box(image(\"static/svg/electronics/capacitor.svg\", width: 2em, height: 1em, fit: \"contain\"))"
