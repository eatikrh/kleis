// ============ MEASUREMENT ============

@template oscilloscope {
    pattern: "oscilloscope(signal)"
    typst: "#grid(columns: (1.5em, 1.5em), gutter: 0.1em, align(center + horizon, [#box(image(\"static/svg/electronics/oscilloscope.svg\", width: 1.5em, height: 1.2em, fit: \"contain\"))]), align(center + horizon, [{signal}]))"
    unicode: "OSC({signal})"
    category: "electronics_measurement"
    glyph: "OSC"
    mode: "content"
    svg: "static/svg/electronics/oscilloscope.svg"
    component_type: "Measurement"
    package: "Module"
    symbol_standard: "IEC"
    ports: "probe_pos:0,0.3;probe_neg:0,0.7"
    graph_width: "48"
    graph_height: "48"
}

@template multimeter {
    pattern: "multimeter(signal)"
    typst: "#grid(columns: (1.5em, 1.5em), gutter: 0.1em, align(center + horizon, [#box(image(\"static/svg/electronics/multimeter.svg\", width: 1.2em, height: 1.5em, fit: \"contain\"))]), align(center + horizon, [{signal}]))"
    unicode: "DMM({signal})"
    category: "electronics_measurement"
    glyph: "DMM"
    mode: "content"
    svg: "static/svg/electronics/multimeter.svg"
    component_type: "Measurement"
    package: "Module"
    symbol_standard: "IEC"
    ports: "probe_pos:0,0.3;probe_neg:0,0.7"
    graph_width: "48"
    graph_height: "48"
}

// ============ COMPOSITION ============

@template series {
    pattern: "series(left, right)"
    typst: "#box(baseline: 50%, grid(columns: (auto, 1em, auto), rows: auto, align: center + horizon, [{left}], [#line(length: 1em, stroke: 0.5pt + black)], [{right}]))"
    unicode: "{left}—{right}"
    category: "electronics_composition"
    glyph: "Series"
    mode: "content"
}

@template parallel {
    pattern: "parallel(left, right)"
    typst: "#box(baseline: 50%, stack(dir: ttb, spacing: 0.3em, [{left}], [{right}]))"
    unicode: "{left}‖{right}"
    category: "electronics_composition"
    glyph: "Parallel"
    mode: "content"
}
