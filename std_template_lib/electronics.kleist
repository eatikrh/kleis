    unicode: "V_DC"
    category: "electronics_source"
    glyph: "V+"
    mode: "content"
    svg: "static/svg/electronics/dc_voltage.svg"
    component_type: "VoltageSource"
    package: "Symbol"
    symbol_standard: "IEC"
    params: "V:real:5"
    ports: "pos:0.5,0;neg:0.5,1"
    graph_width: "48"
    graph_height: "48"
}

