    svg: "static/svg/electronics/capacitor.svg"
    component_type: "Passive"
    package: "Through-hole"
    symbol_standard: "IEC"
    params: "C:real:1e-6"
    ports: "left:0,0.5;right:1,0.5"
    graph_width: "64"
    graph_height: "32"
}

