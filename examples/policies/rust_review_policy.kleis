// Rust Code Review Policy — Formal Coding Standards
//
// String-based checks: pattern matching for clippy, style, and error handling.
// Structural checks: AST-based analysis via rust_parser.kleis for context-aware
//   safety, cleanliness, security, SQL injection, naming, docs, and more.
// Z3 structures: formal axioms (SafeCode, CleanCode, SecureCode, SqlSafe).
//
// Each check_* function receives source code as a string and returns
// "pass" or "fail: <reason>".
//
// Usage: kleis review-mcp --policy examples/policies/rust_review_policy.kleis

import "../meta-programming/rust_parser.kleis"

// --- Style ---

define check_no_allow_unused(source) =
    if contains(source, "#[allow(unused)]") then "fail: #[allow(unused)] — remove dead code instead"
    else if contains(source, "#[allow(dead_code)]") then "fail: #[allow(dead_code)] — remove dead code instead"
    else "pass"

// --- Error handling ---

define check_no_result_string(source) =
    if contains(source, "Result<Self, String>") then "fail: Result<_, String> — use thiserror for typed errors"
    else if contains(source, "Result<(), String>") then "fail: Result<(), String> — use thiserror for typed errors"
    else if contains(source, ", String>") then "fail: possible Result<_, String> — prefer thiserror or anyhow"
    else "pass"

// --- Clippy discipline ---

define check_no_clippy_suppression(source) =
    if contains(source, "#[allow(clippy::") then "fail: clippy suppression — fix the lint instead of suppressing it"
    else if contains(source, "#![allow(clippy::") then "fail: module-wide clippy suppression — fix the lints"
    else "pass"

define check_no_too_many_arguments(source) =
    if contains(source, "too_many_arguments") then "fail: too many function arguments — refactor into a config struct"
    else "pass"

define check_no_type_complexity(source) =
    if contains(source, "type_complexity") then "fail: type complexity suppressed — introduce a type alias"
    else "pass"

// --- Clippy -D warnings patterns ---
// These catch code that `cargo clippy -- -D warnings` would reject.

define check_clippy_ptr_arg(source) =
    if contains(source, "&String") then "fail: clippy::ptr_arg — use &str instead of &String"
    else if contains(source, "&Vec<") then "fail: clippy::ptr_arg — use &[T] instead of &Vec<T>"
    else "pass"

define check_clippy_len_zero(source) =
    if contains(source, ".len() == 0") then "fail: clippy::len_zero — use .is_empty() instead"
    else if contains(source, ".len() > 0") then "fail: clippy::len_zero — use !.is_empty() instead"
    else if contains(source, ".len() != 0") then "fail: clippy::len_zero — use !.is_empty() instead"
    else "pass"

define check_clippy_bool_comparison(source) =
    if contains(source, "== true") then "fail: clippy::bool_comparison — remove == true, use value directly"
    else if contains(source, "== false") then "fail: clippy::bool_comparison — use !value instead of == false"
    else if contains(source, "!= true") then "fail: clippy::bool_comparison — use !value instead"
    else "pass"

define check_clippy_redundant_clone(source) =
    if contains(source, ".to_string().as_str()") then "fail: clippy — needless .to_string().as_str(), use &str directly"
    else if contains(source, ".to_owned().as_str()") then "fail: clippy — needless .to_owned().as_str()"
    else if contains(source, ".clone().as_ref()") then "fail: clippy — needless .clone().as_ref()"
    else "pass"

define check_clippy_manual_is_ascii(source) =
    if contains(source, ">= 'a' && ") then "fail: clippy::manual_is_ascii_check — use .is_ascii_lowercase()"
    else if contains(source, ">= 'A' && ") then "fail: clippy::manual_is_ascii_check — use .is_ascii_uppercase()"
    else if contains(source, ">= '0' && ") then "fail: clippy::manual_is_ascii_check — use .is_ascii_digit()"
    else "pass"

define check_clippy_single_char_pattern(source) =
    if contains(source, ".split(\"\n\")") then "fail: clippy::single_char_pattern — use .split('\\n') with a char"
    else if contains(source, ".contains(\"\n\")") then "fail: clippy::single_char_pattern — use .contains('\\n') with a char"
    else if contains(source, ".starts_with(\"/\")") then "fail: clippy::single_char_pattern — use .starts_with('/') with a char"
    else if contains(source, ".ends_with(\"/\")") then "fail: clippy::single_char_pattern — use .ends_with('/') with a char"
    else "pass"

define check_clippy_expect_fun_call(source) =
    if contains(source, ".expect(&format!(") then "fail: clippy::expect_fun_call — use .unwrap_or_else or build msg lazily"
    else "pass"

// --- No color emoji or decorative icons in Rust source ---
// Unicode strings are fine; decorative emoji are not.

define check_no_emoji(source) =
    if contains(source, "✅") then "fail: color emoji in source — use plain text"
    else if contains(source, "❌") then "fail: color emoji in source — use plain text"
    else if contains(source, "🔥") then "fail: color emoji in source — use plain text"
    else if contains(source, "🚀") then "fail: color emoji in source — use plain text"
    else if contains(source, "🎉") then "fail: color emoji in source — use plain text"
    else if contains(source, "🐛") then "fail: color emoji in source — use plain text"
    else if contains(source, "💡") then "fail: color emoji in source — use plain text"
    else if contains(source, "✨") then "fail: color emoji in source — use plain text"
    else if contains(source, "👍") then "fail: color emoji in source — use plain text"
    else if contains(source, "📝") then "fail: color emoji in source — use plain text"
    else if contains(source, "🔧") then "fail: color emoji in source — use plain text"
    else if contains(source, "📦") then "fail: color emoji in source — use plain text"
    else if contains(source, "🔒") then "fail: color emoji in source — use plain text"
    else if contains(source, "🔑") then "fail: color emoji in source — use plain text"
    else if contains(source, "💥") then "fail: color emoji in source — use plain text"
    else if contains(source, "🤖") then "fail: color emoji in source — use plain text"
    else if contains(source, "🔴") then "fail: color emoji in source — use plain text"
    else if contains(source, "🟢") then "fail: color emoji in source — use plain text"
    else if contains(source, "🟡") then "fail: color emoji in source — use plain text"
    else if contains(source, "⚠️") then "fail: color emoji in source — use plain text"
    else if contains(source, "⬆️") then "fail: color emoji in source — use plain text"
    else if contains(source, "⬇️") then "fail: color emoji in source — use plain text"
    else if contains(source, "➡️") then "fail: color emoji in source — use plain text"
    else "pass"

define check_no_separator_comments(source) =
    if contains(source, "// ====") then "fail: decorative separator comment — use blank lines instead"
    else if contains(source, "// ----") then "fail: decorative separator comment — use blank lines instead"
    else if contains(source, "// ****") then "fail: decorative separator comment — use blank lines instead"
    else if contains(source, "// ####") then "fail: decorative separator comment — use blank lines instead"
    else if contains(source, "// ~~~~") then "fail: decorative separator comment — use blank lines instead"
    else "pass"

define check_no_transmute(source) =
    if contains(source, "transmute(") then "fail: std::mem::transmute — use safe conversions (From/Into, as, bytemuck)"
    else if contains(source, "transmute_copy(") then "fail: std::mem::transmute_copy — use safe conversions"
    else "pass"

define check_no_deprecated_syntax(source) =
    if contains(source, "try!(") then "fail: try!() macro is deprecated — use ? operator"
    else if contains(source, "extern crate ") then "fail: extern crate is unnecessary since Rust 2018 — use 'use' imports"
    else "pass"

define check_no_hardcoded_urls(source) =
    if contains(source, "http://") then "fail: hardcoded HTTP URL — use configuration or constants"
    else if contains(source, "https://") then "fail: hardcoded HTTPS URL — use configuration or constants"
    else "pass"

define check_no_ignored_tests(source) =
    if contains(source, "#[ignore]") then "fail: #[ignore] test — provide a reason or remove the test"
    else "pass"

define check_no_needless_collect(source) =
    if contains(source, ".collect::<Vec<") then "fail: possible needless .collect() — consider using iterator directly"
    else "pass"

// --- STRIDE threat model coverage ---

define check_no_tls_bypass(source) =
    if contains(source, "insecure") then "fail: STRIDE/Spoofing — 'insecure' in code, review TLS/auth configuration"
    else if contains(source, "no_verify") then "fail: STRIDE/Spoofing — 'no_verify' pattern, TLS verification may be disabled"
    else if contains(source, "skip_verify") then "fail: STRIDE/Spoofing — 'skip_verify' pattern, TLS verification may be disabled"
    else if contains(source, "allow_invalid") then "fail: STRIDE/Spoofing — 'allow_invalid' pattern, invalid certs/hostnames may be accepted"
    else if contains(source, "disable_tls") then "fail: STRIDE/Spoofing — TLS explicitly disabled"
    else "pass"

define check_no_credential_logging(source) =
    let prod = production_code(source) in
    let c = scan(prod) in
    let fns = crate_functions(c) in
    let f1 = non_test_fns_containing(prod, fns, "println!(\"{}\", password") in
    let f2 = non_test_fns_containing(prod, fns, "println!(\"{}\", secret") in
    let f3 = non_test_fns_containing(prod, fns, "println!(\"{:?}\", password") in
    let f4 = non_test_fns_containing(prod, fns, "println!(\"{:?}\", secret") in
    let f5 = non_test_fns_containing(prod, fns, "debug!(password") in
    let f6 = non_test_fns_containing(prod, fns, "debug!(secret") in
    let f7 = non_test_fns_containing(prod, fns, "info!(password") in
    let f8 = non_test_fns_containing(prod, fns, "info!(secret") in
    let all = append_failure(
        if eq(f1, "") then "" else concat("STRIDE/Disclosure — printing password to stdout in: ", f1),
        append_failure(
        if eq(f2, "") then "" else concat("STRIDE/Disclosure — printing secret to stdout in: ", f2),
        append_failure(
        if eq(f3, "") then "" else concat("STRIDE/Disclosure — debug-printing password in: ", f3),
        append_failure(
        if eq(f4, "") then "" else concat("STRIDE/Disclosure — debug-printing secret in: ", f4),
        append_failure(
        if eq(f5, "") then "" else concat("STRIDE/Disclosure — debug-logging password in: ", f5),
        append_failure(
        if eq(f6, "") then "" else concat("STRIDE/Disclosure — debug-logging secret in: ", f6),
        append_failure(
        if eq(f7, "") then "" else concat("STRIDE/Disclosure — info-logging password in: ", f7),
        if eq(f8, "") then "" else concat("STRIDE/Disclosure — info-logging secret in: ", f8)
        ))))))) in
    if eq(all, "") then "pass"
    else concat("fail: ", all)

define check_no_unbounded_read(source) =
    if contains(source, "read_to_end(") then "fail: STRIDE/DoS — unbounded read_to_end, use take() or read with a size limit"
    else if contains(source, "read_to_string(") then "fail: STRIDE/DoS — unbounded read_to_string, use take() to limit input size"
    else "pass"

define check_no_command_injection(source) =
    if and(contains(source, "Command::new("), contains(source, "format!(")) then "fail: STRIDE/EoP — Command::new with format!, possible shell injection"
    else if contains(source, ".arg(format!(") then "fail: STRIDE/EoP — command arg built with format!, validate and sanitize input"
    else "pass"

// --- Team review patterns (inferred from human code reviews) ---

define check_no_debug_serialization(source) =
    if and(contains(source, "serde_json::to_string"), contains(source, "debug!("))
    then "fail: serde_json::to_string in debug! — use {:?} instead of serializing"
    else if and(contains(source, "serde_json::to_string"), contains(source, "tracing::debug"))
    then "fail: serde_json::to_string in tracing debug — use {:?} instead"
    else if and(contains(source, "serde_yml::to_string"), contains(source, "debug!("))
    then "fail: serde_yml::to_string in debug! — use {:?} instead of serializing"
    else "pass"

define check_no_ambiguous_status_match(source) =
    if contains(source, "| StatusCode::")
    then "fail: OR'd status codes in match — each endpoint returns one status code, verify which one"
    else "pass"

define check_no_client_layer_filtering(source) =
    if and(contains(source, "fn find_by_name"), contains(source, ".iter()"))
    then "fail: find_by_name with .iter() — client should use API search, not filter in code"
    else if and(contains(source, "fn list_"), contains(source, ".filter("))
    then "fail: list_ method with .filter() — filtering belongs in application layer, not client"
    else if and(contains(source, "fn get_used_"), contains(source, ".filter("))
    then "fail: get_used_ with .filter() — derived views belong in application layer"
    else "pass"

// --- AI-generated artifacts (gpt-5.3-codex style signatures) ---

define check_no_step_comments(source) =
    if contains(source, "// Step 1")
    then "fail: numbered step comments — AI artifact, refactor into named functions"
    else if contains(source, "// Step 2")
    then "fail: numbered step comments — AI artifact, refactor into named functions"
    else if contains(source, "// Step 3")
    then "fail: numbered step comments — AI artifact, refactor into named functions"
    else "pass"

define check_no_region_comments(source) =
    if contains(source, "// region")
    then "fail: IDE region marker — AI artifact, use modules/blank lines for organization"
    else if contains(source, "// endregion")
    then "fail: IDE region marker — AI artifact, use modules/blank lines for organization"
    else "pass"

define check_no_ai_breadcrumbs(source) =
    if contains(source, "AI-generated")
    then "fail: AI breadcrumb in source — remove generation attribution comments"
    else if contains(source, "Generated by ChatGPT")
    then "fail: AI breadcrumb in source — remove generation attribution comments"
    else if contains(source, "Generated by Copilot")
    then "fail: AI breadcrumb in source — remove generation attribution comments"
    else if contains(source, "Generated by Claude")
    then "fail: AI breadcrumb in source — remove generation attribution comments"
    else "pass"

define check_no_self_referential_docs(source) =
    if contains(source, "/// This function")
    then "fail: self-referential doc comment — describe intent/behavior, not boilerplate"
    else if contains(source, "/// This method")
    then "fail: self-referential doc comment — describe intent/behavior, not boilerplate"
    else if contains(source, "/// Helper function")
    then "fail: generic helper doc comment — use a domain-specific description"
    else if contains(source, "/// Utility function")
    then "fail: generic utility doc comment — use a domain-specific description"
    else "pass"

// =============================================================================
// Context-Aware Structural Checks (AST-based)
// =============================================================================

// --- Sub-checks: named rule_* so the engine doesn't auto-discover them ---

define rule_wildcard_imports(c: Crate) : String =
    let bad = non_test_wildcard_uses(c) in
    let names = wildcard_use_names(bad) in
    if eq(names, "") then ""
    else concat("wildcard import outside test module: ", names)

define rule_narrating_line_comments(c: Crate) : String =
    let bad = has_narrating_line_comment(crate_comments(c)) in
    if eq(bad, "") then ""
    else concat("narrating comment on ", bad)

define rule_pub_fn_docs(c: Crate) : String =
    let fns = filter_non_test_fns(crate_functions(c)) in
    let missing = pub_fns_missing_docs(fns, crate_comments(c)) in
    if eq(missing, "") then ""
    else concat("pub fn missing doc comment: ", missing)

define rule_param_count(c: Crate) : String =
    let fns = filter_non_test_fns(crate_functions(c)) in
    let bad = fns_with_too_many_params(fns, 5) in
    if eq(bad, "") then ""
    else concat("too many parameters (>5): ", bad)

define rule_function_count(c: Crate) : String =
    if gt(count_functions(c), 50)
    then concat("file has ", concat(intToStr(count_functions(c)), " functions (>50) — consider splitting"))
    else ""

define rule_test_presence(c: Crate) : String =
    let fns = crate_functions(c) in
    let non_test = filter_non_test_fns(fns) in
    let test_count = count_test_fns(fns) in
    let fn_count = count_fn_list(non_test) in
    if and(gt(fn_count, 3), eq(test_count, 0))
    then concat(intToStr(fn_count), " functions but no tests — consider adding test coverage")
    else ""

define rule_fn_naming(c: Crate) : String =
    let fns = crate_functions(c) in
    let bad = fns_with_bad_names(fns) in
    if eq(bad, "") then ""
    else concat("function names should be snake_case: ", bad)

define rule_struct_naming(c: Crate) : String =
    let structs = crate_structs(c) in
    let bad = structs_with_bad_names(structs) in
    if eq(bad, "") then ""
    else concat("struct names should be PascalCase: ", bad)

define rule_use_in_fn_body(source: String, c: Crate) : String =
    let fns = crate_functions(c) in
    let bad = non_test_fns_containing(source, fns, "use ") in
    if eq(bad, "") then ""
    else concat("use statement inside function body — move to top of file: ", bad)

define rule_string_translation(source: String, c: Crate) : String =
    let fns = crate_functions(c) in
    let out_match = non_test_fns_containing(source, fns, "=> \"") in
    let in_match = non_test_fns_containing(source, fns, "\" =>") in
    let bad = append_failure(out_match, in_match) in
    if eq(bad, "") then ""
    else concat("string matching or string translation via match — consider an enum with #[serde(rename/alias)]: ", bad)

define check_structural(source) =
    let c = scan(source) in
    let f1 = rule_wildcard_imports(c) in
    let f2 = rule_narrating_line_comments(c) in
    let f3 = rule_pub_fn_docs(c) in
    let f4 = rule_param_count(c) in
    let f5 = rule_function_count(c) in
    let f6 = rule_test_presence(c) in
    let f7 = rule_fn_naming(c) in
    let f8 = rule_struct_naming(c) in
    let f9 = rule_use_in_fn_body(source, c) in
    let f10 = rule_string_translation(source, c) in
    let all = append_failure(f1,
              append_failure(f2,
              append_failure(f3,
              append_failure(f4,
              append_failure(f5,
              append_failure(f6,
              append_failure(f7,
              append_failure(f8,
              append_failure(f9, f10))))))))) in
    if eq(all, "") then "pass"
    else concat("fail: ", all)

// =============================================================================
// Context-Aware Safety & Cleanliness Checks (skip test code)
// =============================================================================

define check_safe_structural(source) =
    let prod = production_code(source) in
    let c = scan(source) in
    let fns = crate_functions(c) in
    let unwrap_fns  = non_test_fns_containing(source, fns, ".unwrap()") in
    let panic_fns   = non_test_fns_containing(source, fns, "panic!(") in
    let unsafe_hits = if contains(prod, "unsafe {") then "unsafe block in production code" else "" in
    let f1 = if eq(unwrap_fns, "") then "" else concat(".unwrap() in production fn: ", unwrap_fns) in
    let f2 = if eq(panic_fns, "") then "" else concat("panic!() in production fn: ", panic_fns) in
    let all = append_failure(f1, append_failure(f2, unsafe_hits)) in
    if eq(all, "") then "pass"
    else concat("fail: ", all)

define check_clean_structural(source) =
    let prod = production_code(source) in
    let c = scan(source) in
    let fns = crate_functions(c) in
    let println_fns = non_test_fns_containing(source, fns, "println!(") in
    let todo_fns    = non_test_fns_containing(source, fns, "todo!(") in
    let dbg_fns     = non_test_fns_containing(source, fns, "dbg!(") in
    let f1 = if eq(println_fns, "") then "" else concat("println! in production fn: ", println_fns) in
    let f2 = if eq(todo_fns, "") then "" else concat("todo! in production fn: ", todo_fns) in
    let f3 = if eq(dbg_fns, "") then "" else concat("dbg! in production fn: ", dbg_fns) in
    let all = append_failure(f1, append_failure(f2, f3)) in
    if eq(all, "") then "pass"
    else concat("fail: ", all)

define check_secure_structural(source) =
    let prod = production_code(source) in
    let f1 = if contains(prod, "password = \"") then "hardcoded password literal in production code" else "" in
    let f2 = if contains(prod, "secret = \"") then "hardcoded secret literal in production code" else "" in
    let f3 = if contains(prod, "api_key = \"") then "hardcoded api_key literal in production code" else "" in
    let f4 = if contains(prod, "password: \"") then "hardcoded password literal in struct init" else "" in
    let f5 = if contains(prod, "secret: \"") then "hardcoded secret literal in struct init" else "" in
    let all = append_failure(f1, append_failure(f2, append_failure(f3, append_failure(f4, f5)))) in
    if eq(all, "") then "pass"
    else concat("fail: ", all)

define check_sql_safe_structural(source) =
    let prod = production_code(source) in
    let f1 = if and(contains(prod, "format!("), contains(prod, "SELECT"))
             then "format! with SELECT in production code — use parameterized queries" else "" in
    let f2 = if and(contains(prod, "format!("), contains(prod, "INSERT"))
             then "format! with INSERT in production code — use parameterized queries" else "" in
    let f3 = if and(contains(prod, ".push_str("), contains(prod, "WHERE"))
             then ".push_str with WHERE in production code — use parameterized queries" else "" in
    let f4 = if contains(prod, "sqlx::query!")
             then "" else "" in
    let all = append_failure(f1, append_failure(f2, f3)) in
    if eq(all, "") then "pass"
    else concat("fail: ", all)

// =============================================================================
// Formal Properties (Z3-verified)
// =============================================================================
//
// These structures define formal properties of the coding standards.
// The agent can verify them via the `evaluate` tool, which routes
// propositions to Z3. String-level check_* functions above are unaffected.

structure SafeCode {
    operation is_safe : String -> Bool

    axiom safe_no_unwrap : ∀(s : String).
        implies(is_safe(s), not(contains(s, ".unwrap()")))

    axiom safe_no_panic : ∀(s : String).
        implies(is_safe(s), not(contains(s, "panic!(")))

    axiom safe_no_unsafe : ∀(s : String).
        implies(is_safe(s), not(contains(s, "unsafe {")))

    axiom safe_complete : ∀(s : String).
        implies(
            and(not(contains(s, ".unwrap()")),
                and(not(contains(s, "panic!(")),
                    not(contains(s, "unsafe {")))),
            is_safe(s))
}

structure CleanCode {
    operation is_clean : String -> Bool

    axiom clean_no_println : ∀(s : String).
        implies(is_clean(s), not(contains(s, "println!(")))

    axiom clean_no_todo : ∀(s : String).
        implies(is_clean(s), not(contains(s, "todo!(")))

    axiom clean_no_dbg : ∀(s : String).
        implies(is_clean(s), not(contains(s, "dbg!(")))

    axiom clean_complete : ∀(s : String).
        implies(
            and(not(contains(s, "println!(")),
                and(not(contains(s, "todo!(")),
                    not(contains(s, "dbg!(")))),
            is_clean(s))
}

structure SecureCode {
    operation is_secure : String -> Bool

    axiom secure_no_hardcoded_password : ∀(s : String).
        implies(is_secure(s), not(contains(s, "password =")))

    axiom secure_no_hardcoded_secret : ∀(s : String).
        implies(is_secure(s), not(contains(s, "secret =")))

    axiom secure_no_hardcoded_api_key : ∀(s : String).
        implies(is_secure(s), not(contains(s, "api_key =")))

    axiom secure_complete : ∀(s : String).
        implies(
            and(not(contains(s, "password =")),
                and(not(contains(s, "secret =")),
                    not(contains(s, "api_key =")))),
            is_secure(s))
}

structure SqlSafe {
    operation is_tainted : String -> Bool
    operation is_sanitized : String -> Bool
    operation reaches_query : String -> Bool

    axiom no_tainted_query : ∀(s : String).
        implies(and(is_tainted(s), reaches_query(s)), is_sanitized(s))

    axiom parameterized_is_sanitized : ∀(s : String).
        implies(contains(s, "sqlx::query!"), is_sanitized(s))

    axiom format_select_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "format!("), contains(s, "SELECT")),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom format_select_lower_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "format!("), contains(s, "select")),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom format_insert_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "format!("), contains(s, "INSERT")),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom format_insert_lower_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "format!("), contains(s, "insert into")),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom concat_where_is_tainted : ∀(s : String).
        implies(
            and(contains(s, ".push_str("), contains(s, "WHERE")),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom concat_where_lower_is_tainted : ∀(s : String).
        implies(
            and(contains(s, ".push_str("), contains(s, "where")),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom placeholder_is_sanitized : ∀(s : String).
        implies(contains(s, "$1"), is_sanitized(s))

    axiom question_mark_is_sanitized : ∀(s : String).
        implies(contains(s, "?"), is_sanitized(s))

    axiom select_without_placeholder_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "SELECT"), and(not(contains(s, "$")), not(contains(s, "?")))),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom select_lower_without_placeholder_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "select"), and(not(contains(s, "$")), not(contains(s, "?")))),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom insert_without_placeholder_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "INSERT"), and(not(contains(s, "$")), not(contains(s, "?")))),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom insert_lower_without_placeholder_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "insert into"), and(not(contains(s, "$")), not(contains(s, "?")))),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom update_without_placeholder_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "UPDATE"), and(not(contains(s, "$")), not(contains(s, "?")))),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom update_lower_without_placeholder_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "update"), and(not(contains(s, "$")), not(contains(s, "?")))),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom delete_without_placeholder_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "DELETE"), and(not(contains(s, "$")), not(contains(s, "?")))),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom delete_lower_without_placeholder_is_tainted : ∀(s : String).
        implies(
            and(contains(s, "delete from"), and(not(contains(s, "$")), not(contains(s, "?")))),
            and(is_tainted(s), not(is_sanitized(s)))
        )

    axiom drop_is_tainted : ∀(s : String).
        implies(contains(s, "DROP"), and(is_tainted(s), not(is_sanitized(s))))

    axiom drop_lower_is_tainted : ∀(s : String).
        implies(contains(s, "drop table"), and(is_tainted(s), not(is_sanitized(s))))

    axiom truncate_is_tainted : ∀(s : String).
        implies(contains(s, "TRUNCATE"), and(is_tainted(s), not(is_sanitized(s))))

    axiom truncate_lower_is_tainted : ∀(s : String).
        implies(contains(s, "truncate"), and(is_tainted(s), not(is_sanitized(s))))
}

// =============================================================================
// Tests for check_structural
// =============================================================================

example "structural_clean_code" {
    let source = "/// Add two numbers\npub fn add(a: i32, b: i32) -> i32 {\n    a + b\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_add() {\n        assert_eq!(add(1, 2), 3);\n    }\n}" in
    out(check_structural(source))
}

example "structural_wildcard_import" {
    let source = "use std::io::*;\npub fn process() {}" in
    out(check_structural(source))
}

example "structural_missing_pub_docs" {
    let source = "pub fn undocumented_public() {}\npub fn also_no_docs() {}" in
    out(check_structural(source))
}

example "structural_too_many_params" {
    let source = "fn too_many(a: i32, b: i32, c: i32, d: i32, e: i32, f: i32) {}" in
    out(check_structural(source))
}

example "structural_bad_naming" {
    let source = "fn badCamelCase() {}\nstruct lowercase {}" in
    out(check_structural(source))
}

example "structural_narrating_comment" {
    let source = "// Import the module\nfn helper() {}" in
    out(check_structural(source))
}

// --- Context-aware safety/cleanliness tests ---

example "safe_unwrap_in_test_is_ok" {
    let source = "fn production() {\n    let x = compute();\n}\n\n#[test]\nfn test_it() {\n    production().unwrap();\n}" in
    out(check_safe_structural(source))
}

example "safe_unwrap_in_production_flagged" {
    let source = "fn production() {\n    let x = get_value().unwrap();\n}" in
    out(check_safe_structural(source))
}

example "clean_println_in_test_is_ok" {
    let source = "fn real_fn() {\n    compute();\n}\n\n#[cfg(test)]\nmod tests {\n    #[test]\n    fn test_it() {\n        println!(\"debug\");\n    }\n}" in
    out(check_clean_structural(source))
}

example "clean_println_in_production_flagged" {
    let source = "fn real_fn() {\n    println!(\"oops\");\n}" in
    out(check_clean_structural(source))
}

example "secure_password_in_test_ok" {
    let source = "fn login() {\n    auth();\n}\n\n#[test]\nfn test_login() {\n    let password = \"test123\";\n}" in
    out(check_secure_structural(source))
}

example "sql_safe_format_in_test_ok" {
    let source = "fn query_db() {\n    sqlx::query!(\"SELECT id FROM users WHERE id = ?\");\n}\n\n#[test]\nfn test_query() {\n    let q = format!(\"SELECT * FROM test\");\n}" in
    out(check_sql_safe_structural(source))
}

// ============================================================================
// Diff-Aware Rules (CLI only, invisible to MCP)
// ============================================================================
//
// These rules compare current vs base branch content. They are discovered
// by the `diff_check_*` prefix and only run when `--base-branch` is provided.
// The MCP's `check_*` discovery filter does not match this prefix.

// Filter: only fetch base branch content for version-bearing files
define diff_file_filter(path) =
    if hasSuffix(path, "Cargo.toml") then true
    else if contains(path, "config") then true
    else if hasSuffix(path, "package.json") then true
    else false

// --- Helpers for version line extraction ---

define pick_cargo_version_line(line, acc) =
    if hasPrefix(trim(line), "version = ") then trim(line) else acc

define extract_cargo_version_line(source) =
    foldLines(pick_cargo_version_line, "", source)

define pick_image_tag(line, acc) =
    if hasPrefix(line, "IMAGE_TAG=") then substring(line, 10, 100)
    else acc

define extract_image_tag(source) =
    foldLines(pick_image_tag, "", source)

// --- Diff Rules ---

define diff_check_cargo_version(current, base, path) =
    if not(hasSuffix(path, "Cargo.toml")) then "pass"
    else
        let cur_line = extract_cargo_version_line(current) in
        let base_line = extract_cargo_version_line(base) in
        if eq(cur_line, "") then "pass"
        else if eq(base_line, "") then "pass"
        else if eq(cur_line, base_line) then
            concat("fail: Cargo.toml version not bumped (", concat(cur_line, ")"))
        else "pass"

define diff_check_version_bump(current, base, path) =
    if not(contains(path, "config")) then "pass"
    else
        let cur_ver = extract_image_tag(current) in
        let base_ver = extract_image_tag(base) in
        if eq(cur_ver, "") then "pass"
        else if eq(base_ver, "") then "pass"
        else if eq(cur_ver, base_ver) then
            concat("fail: IMAGE_TAG not bumped (still ", concat(cur_ver, ")"))
        else "pass"
