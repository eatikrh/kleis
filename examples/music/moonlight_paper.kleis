example "compile_paper" {
    let typst_output = compile_arxiv_paper(skolem_paper) in
    out(typst_raw(typst_output))
}

example "validate_paper" {
    assert(valid_arxiv_paper(skolem_paper) = true)
    out("Paper structure is valid!")
}
