// =============================================================================
// Machine-Checked Verification (mirrors paper claims)
// =============================================================================

example "theorem: tonic opening (Axiom 1)" {
    let tonic = Cons(1, Cons(4, Cons(8, Nil))) in
    assert(check_tonic_opening(accomp_measures, tonic) = true)
    out("Axiom 1 (Tonic Opening): SAT — VERIFIED")
}

example "theorem: bass smooth motion (Axiom 2)" {
    let result = check_bass_smooth(bass_measures, 12) in
    assert(eq(result, 0 - 1))
    out("Axiom 2 (Bass Smooth Motion): SAT — VERIFIED")
}

example "theorem: arpeggio triads violation (Axiom 3)" {
    let result = check_arpeggio_triads(accomp_measures) in
    assert(eq(result, 3))
    out("Axiom 3 (Arpeggio Triads): Violation at m4 — VERIFIED")
}

example "theorem: melody-harmony consonance (Axiom 4)" {
    let result = check_melody_consonance(melody_measures, accomp_measures) in
    assert(eq(result, 0 - 1))
    out("Axiom 4 (Melody-Harmony Consonance): SAT — VERIFIED")
}

example "theorem: no parallel octaves (Axiom 5)" {
    let result = check_no_parallels(melody_measures, bass_measures, 0) in
    assert(eq(result, 0 - 1))
    out("Axiom 5 (No Parallel Octaves): SAT — VERIFIED")
}

example "theorem: parallel fifths at m13 (Axiom 6)" {
    let result = check_no_parallels(melody_measures, bass_measures, 7) in
    assert(eq(result, 12))
    out("Axiom 6 (No Parallel Fifths): Violation at m13 — VERIFIED")
}

example "theorem: harmonic rhythm violations (Axiom 7)" {
    let violations = check_harmonic_rhythm(accomp_measures) in
    assert(eq(length(violations), 8))
    out("Axiom 7 (Harmonic Rhythm): 8 mid-bar changes — VERIFIED")
}

example "spot-check: bass m1 is C-sharp" {
    assert(pitch_class(first_pitch(bass1)) = 1)
    out("Bass m1 pitch class = 1 (C#) — VERIFIED")
}

example "spot-check: accomp m1 PCs" {
    let pcs = triplet_pitch_classes(acc1) in
    assert(pc_member(8, pcs) = true)
    assert(pc_member(1, pcs) = true)
    assert(pc_member(4, pcs) = true)
    out("Accomp m1 PCs = {8,1,4} (G#,C#,E) — VERIFIED")
}

example "spot-check: melody m5 is G-sharp" {
    assert(pitch_class(first_pitch(mel5)) = 8)
    out("Melody m5 first pitch class = 8 (G#) — VERIFIED")
}

