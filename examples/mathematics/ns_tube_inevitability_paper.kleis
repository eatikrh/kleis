define ref_lrt = ArxivReference(5, "Z. Lei, Z. Ren, and G. Tian, \"On the geometric regularity conditions for the 3D Navier-Stokes equations,\" arXiv:2501.01946 (2025).")
define ref_ckn = ArxivReference(6, "L. Caffarelli, R. Kohn, and L. Nirenberg, \"Partial regularity of suitable weak solutions of the Navier-Stokes equations,\" Comm. Pure Appl. Math. 35, 771 (1982).")
define ref_nrs = ArxivReference(7, "J. Necas, M. Ruzicka, and V. Sverak, \"On Leray's self-similar solutions of the Navier-Stokes equations,\" Acta Math. 176, 283 (1996).")
define ref_ess = ArxivReference(8, "L. Escauriaza, G. Seregin, and V. Sverak, \"$L_(3, infinity)$-solutions of Navier-Stokes equations and backward uniqueness,\" Uspekhi Mat. Nauk 58, 3 (2003).")
define ref_she = ArxivReference(9, "Z.-S. She, E. Jackson, and S. A. Orszag, \"Intermittent vortex structures in homogeneous isotropic turbulence,\" Nature 344, 226 (1990).")
define ref_jimenez = ArxivReference(10, "J. Jimenez, A. A. Wray, P. G. Saffman, and R. S. Rogallo, \"The structure of intense vorticity in isotropic turbulence,\" J. Fluid Mech. 255, 65 (1993).")
define ref_cf = ArxivReference(11, "P. Constantin and C. Fefferman, \"Direction of vorticity and the problem of global regularity for the Navier-Stokes equations,\" Indiana Univ. Math. J. 42, 775 (1993).")
define ref_tao = ArxivReference(12, "T. Tao, \"Finite time blowup for an averaged three-dimensional Navier-Stokes equation,\" J. Amer. Math. Soc. 29, 601 (2016).")
define ref_cz = ArxivReference(13, "A. P. Calderon and A. Zygmund, \"On the existence of certain singular integrals,\" Acta Math. 88, 85 (1952).")
define ref_kleis = ArxivReference(14, "E. Atik, \"Kleis: A formal verification language for mathematics,\" https://kleis.io (2025).")
define ref_gp = ArxivReference(15, "S. S. Girimaji and S. B. Pope, \"Material-element deformation in isotropic turbulence,\" J. Fluid Mech. 220, 427 (1990).")
define ref_ashurst = ArxivReference(16, "W. T. Ashurst, A. R. Kerstein, R. M. Kerr, and C. H. Gibson, \"Alignment of vorticity and scalar gradient with strain rate in simulated Navier-Stokes turbulence,\" Phys. Fluids 30, 2343 (1987).")

// =============================================================================
// Assemble document
// =============================================================================

define all_elements = [
    sec_intro,
    sec_stretching,
    sec_burgers,
    sec_attractor,
    sec_interaction,
    sec_lrt,
    sec_self_undermining, subsec_crossover, subsec_chain,
    sec_remaining, subsec_ckn, subsec_selfsimilar, subsec_attractor_evidence, subsec_transient, subsec_coherence, subsec_precise_gap, subsec_axiom_table,
    sec_discussion,
    sec_conclusion,
    ref_paper1, ref_paper2, ref_paper3, ref_paper4, ref_lrt, ref_ckn, ref_nrs, ref_ess, ref_she, ref_jimenez, ref_cf, ref_tao, ref_cz, ref_kleis, ref_gp, ref_ashurst
]

define my_paper = arxiv_paper(
    paper_title,
    paper_authors,
    paper_affiliations,
    paper_abstract,
    paper_keywords,
    all_elements
)

example "compile" {
    let typst_output = compile_arxiv_paper(my_paper) in
    out(typst_raw(typst_output))
}

example "validate" {
    assert(valid_arxiv_paper(my_paper) = true)
    out("Paper is valid!")
}
