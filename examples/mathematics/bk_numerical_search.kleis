// ============================================================================
// CRITICAL DISCOVERY: "SPECTRAL COMB" ARCHITECTURE
//
// The BK operator that reproduces the zeta zeros has the structure:
//   a_{2k} = ζ_k  (even positions = zeta zero magnitudes)
//   a_{2k+1} = ε   (odd positions = small coupling)
//
// As ε → 0: eigenvalues → ζ_k (isolated 2×2 blocks)
// With finite ε: eigenvalue repulsion shifts them slightly
//
// This is SELF-REFERENTIAL: the operator encodes its own spectrum
// as matrix elements. Like a fixed-point equation:
//   ζ_k = eigenvalue_k(Operator(ζ_1, ..., ζ_N))
//
// Now test: does this SCALE to more zeta zeros?
// ============================================================================

// ============================================================================
// Test 45: 20×20 with 10 zeta zeros
//
// First 10 zeta zeros:
//   ζ₁ = 14.1347,  ζ₂ = 21.0220,  ζ₃ = 25.0109,  ζ₄ = 30.4249,  ζ₅ = 32.9351
//   ζ₆ = 37.5862,  ζ₇ = 40.9187,  ζ₈ = 43.3271,  ζ₉ = 48.0052,  ζ₁₀ = 49.7738
// ============================================================================

example "45. 20×20 spectral comb, 10 zeta zeros, dip=0.5" {
    let n = 20 in
