// ============================================================================
// Test 33: FURTHER REFINED — adjust for gap matching
//
// The first gap (ζ₂-ζ₁=6.89) is the WIDEST. This needs the DEEPEST bottleneck.
// The fourth gap (ζ₅-ζ₄=2.51) is the NARROWEST. Shallowest bottleneck.
//
// Let peak = p. Bottleneck depth controls gap width.
// Empirically from Test 31: dip=6 gave gap≈4.2, dip=10 gave gap≈4.4.
// The relationship is: shallower dip → eigenvalues merge (smaller gap).
// DEEPER dip → eigenvalues separate (larger gap).
//
// Scale: p=25 for higher overall eigenvalue range.
// ============================================================================

example "33. 10×10 refined bottleneck v2 (p=25, tuned dips)" {
    let n = 10 in
    // Dip scaling: gap ∝ 1/dip roughly (deeper = bigger gap)
    // Target gaps: 6.89, 3.99, 5.41, 2.51 → ratios: 1.0, 0.58, 0.79, 0.36
    // Deepest dip = 3.0 (for gap 6.89), others proportional:
    //   dip1 = 3.0 (gap 6.89)
    //   dip2 = 3.0/0.58 ≈ 5.2 → use 8.0 (gap 3.99)
    //   dip3 = 3.0/0.79 ≈ 3.8 → use 5.0 (gap 5.41)
    //   dip4 = 3.0/0.36 ≈ 8.3 → use 14.0 (gap 2.51)
    let off_vals = [25.0, 3.0, 25.0, 8.0, 25.0, 5.0, 25.0, 14.0, 25.0] in
    let diag = list_map(lambda j . 0.5, linspace(1, n, n)) in
    let H = build_antisym_varying(n, diag, off_vals) in
    let eigs = eigenvalues(H) in
    out("Target ζ zeros: 14.1347, 21.0220, 25.0109, 30.4249, 32.9351")
    out("10×10 [25,3,25,8,25,5,25,14,25]:")
    out(eigs)
}

