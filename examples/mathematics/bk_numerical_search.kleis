// ============================================================================
// Test 24: 10×10 MULTI-BOTTLENECK (prime-gap informed)
//
// The zeta zero gaps tell us WHERE to put bottlenecks:
//   ζ₂-ζ₁ = 6.89 (big gap → strong bottleneck)
//   ζ₃-ζ₂ = 3.99 (medium gap → medium bottleneck)
//   ζ₄-ζ₃ = 5.41 (big gap → strong bottleneck)
//   ζ₅-ζ₄ = 2.51 (small gap → weak bottleneck)
//
// For a 10×10 matrix, positions 0-8 map to eigenvalue pairs.
// The 5 eigenvalue pairs are separated by 4 "gaps."
// Place SMALL off-diagonal at positions corresponding to large eigenvalue gaps.
//
// Rough mapping: position j ≈ n/2 separates lowest from highest eigenvalues.
// Positions 2,4,6 create internal bottlenecks.
//
// Pattern: high at edges (0,8), dips at 2,4,6 proportional to gaps.
// Twin-prime insight: ζ₅-ζ₄=2.51 (smallest gap, like twin primes are close)
//   → weakest bottleneck at the corresponding position
// ============================================================================

example "24. 10×10 multi-bottleneck (gap-informed)" {
    let n = 10 in
    // Eigenvalue gaps (larger gap → smaller off-diagonal):
    // Gap weights: 6.89, 3.99, 5.41, 2.51 → invert: 0.145, 0.251, 0.185, 0.398
    // Place bottlenecks at positions 2, 4, 6, with peaks at 0, 1, 3, 5, 7, 8
    // Bottleneck strength inversely proportional to gap
    //   pos 2 (gap ζ₂-ζ₁=6.89): a=8 (strongest bottleneck)
    //   pos 4 (gap ζ₃-ζ₂=3.99): a=14 (medium)
    //   pos 6 (gap ζ₄-ζ₃=5.41): a=10 (strong)
    //   pos 8 (gap ζ₅-ζ₄=2.51): a=18 (weakest, twin-like)
    // Peaks at positions 0,1,3,5,7: a=25
    let off_vals = [25.0, 25.0, 8.0, 25.0, 14.0, 25.0, 10.0, 25.0, 18.0] in
    let diag = list_map(lambda j . 0.5, linspace(1, n, n)) in
    let H = build_antisym_varying(n, diag, off_vals) in
    let eigs = eigenvalues(H) in
    out("Target ζ zeros: 14.1347, 21.0220, 25.0109, 30.4249, 32.9351")
    out("10×10 multi-bottleneck (gap-informed):")
    out(eigs)
}

// ============================================================================
// Test 25: 10×10 REFINED BOTTLENECK (twin prime = strongest coupling)
//
// Flip the perspective: instead of gaps between zeros, use PRIME structure.
// Twin primes (gap=2) → strongest coupling (large a_j)
// Large prime gap → weak coupling (small a_j)
//
// But now place the values to MATCH the eigenvalue compression needed.
// Key: we need ratio max/min ≈ 2.33 from 6.76 (uniform).
//
// Strategy: make the matrix nearly block-diagonal with weak links.
// Two blocks of size 5 connected by a weak link at position 4.
// Each block's eigenvalues are roughly ±a_local · cos(...).
// Tuned so the two blocks produce eigenvalues in the right range.
// ============================================================================

example "25. 10×10 two-block with tuned weak link" {
    let n = 10 in
    // Block 1 (positions 0-3): controls lower eigenvalues (14.13, 21.02)
    // Block 2 (positions 5-8): controls upper eigenvalues (25.01, 30.42, 32.94)
    // Weak link at position 4: determines splitting
    //
    // For block of size 5 with uniform off-diag a:
    //   eigenvalues = 2a·cos(kπ/6) = a·√3, a, 0, -a, -a√3
    //   positive: a, a√3 ≈ a, 1.73a
    // Block 1 target: 14.13, 21.02 → ratio 1.49 → need a ≈ 14.13, 1.73a ≈ 24.4
    //   → a ≈ 14.13 gives 14.13, 24.44 (too high for 21.02)
    //   → a ≈ 12.1 gives 12.1, 20.95 (closer!)
    // Block 2 target: 25.01, 30.42, 32.94 (3 values from 5-point block needs thought)
    //
    // Actually each block of 5 gives 2 positive eigenvalues.
    // Need 5 total → blocks of 5+5 give 2+2=4. The 5th comes from coupling.
    // Try: blocks of 6+4 or asymmetric setup.
    //
    // Simpler: just try different weak-link values.
    let off_vals = [18.0, 18.0, 18.0, 18.0, 3.0, 22.0, 22.0, 22.0, 22.0] in
    let diag = list_map(lambda j . 0.5, linspace(1, n, n)) in
    let H = build_antisym_varying(n, diag, off_vals) in
    let eigs = eigenvalues(H) in
    out("Target ζ zeros: 14.1347, 21.0220, 25.0109, 30.4249, 32.9351")
    out("10×10 two-block [18×4, 3, 22×4]:")
    out(eigs)
}

