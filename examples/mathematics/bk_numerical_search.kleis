// ============================================================================
// Test 49: VARIABLE COUPLING — ε_k depends on the gap between zeros
//
// Instead of uniform ε, let ε_k = c · (ζ_{k+1} - ζ_k) / mean_gap
// This encodes the zero-spacing information in the coupling.
//
// Gaps: 6.89, 3.99, 5.41, 2.51 → mean = 4.70
// ε_k = 0.5 · gap_k / 4.70:
//   ε₁ = 0.5 · 6.89/4.70 = 0.733
//   ε₂ = 0.5 · 3.99/4.70 = 0.424
//   ε₃ = 0.5 · 5.41/4.70 = 0.575
//   ε₄ = 0.5 · 2.51/4.70 = 0.267
//
// Twin-prime-like pairs (ζ₄,ζ₅ gap=2.51) → weakest coupling.
// Widest gaps → strongest coupling.
// ============================================================================

example "49. 10×10 variable coupling ε_k ∝ gap" {
    let n = 10 in
