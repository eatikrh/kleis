    let off_vals = [14.14, 0.5, 21.02, 0.5, 25.01, 0.5, 30.42, 0.5, 32.94, 0.5, 37.59, 0.5, 40.92, 0.5, 43.33, 0.5, 48.01, 0.5, 49.77] in
    let diag = list_map(lambda j . 0.5, linspace(1, n, n)) in
    let H = build_antisym_varying(n, diag, off_vals) in
    let eigs = eigenvalues(H) in
    out("Target first 10 ζ zeros: 14.135, 21.022, 25.011, 30.425, 32.935, 37.586, 40.919, 43.327, 48.005, 49.774")
    out("20×20 spectral comb, dip=0.5:")
    out(eigs)
}

