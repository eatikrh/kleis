    out(chord_len_sq(gamma, fst(ch2), snd(ch2)))
    out("||Phi||^2:")
    out(phi_norm_sq(gamma, fst(ch1), snd(ch1), fst(ch2), snd(ch2)))
    out("Midpoint gap:")
    out(midpoint_gap(gamma, center, theta_zero, n_samp))
}

example "Non-convex wobble: Fourier deformed curve" {
    out("=== WOBBLE: FOURIER N=2 (eps=0.2) ===")
    out("")

    let gamma = lambda t . curve_n2(0.2, t) in
    let n_samp = 400 in
    let center = Pair(0, 0) in

    out("Scanning W(theta):")
    let vals = list_map(lambda k .
        let theta = pi * k / 8 in
        refined_wobble(gamma, center, theta, n_samp),
        range(0, 9)) in
    out(vals)

    let lo = find_wobble_bracket(gamma, center, n_samp, 32) in
    out("")
    out("Sign change bracket starts at theta =")
    out(lo)

    let theta_zero = find_inscribed_square(gamma, center, n_samp) in
    out("Bisected W-zero at theta =")
    out(theta_zero)
    out("W(theta_zero) =")
    out(refined_wobble(gamma, center, theta_zero, n_samp))
    out("||Phi||^2:")
    let ch1 = center_chord(gamma, center, theta_zero, n_samp) in
    let ch2 = center_chord(gamma, center, theta_zero + pi/2, n_samp) in
    out(phi_norm_sq(gamma, fst(ch1), snd(ch1), fst(ch2), snd(ch2)))
}

// ============================================================================
// PART 19: THE DEGENERATION GUARD — NONDEGENERACY INVARIANT
// ============================================================================
//
// W(theta_0) = 0 gives equal-length perpendicular chords.  But they might
// collapse: both diagonals could have length 0.  This is the degeneration
// that blocks all known approaches.
//
// We define N(gamma) = min chord_len_sq at all W-zeros.
// If N > 0, the inscribed square is genuine.
//
// Strategy: compute N for a family of curves from circle to non-convex,
// showing that chord length stays bounded away from zero throughout.
// If N is continuous and N(circle) = 2, density of smooth curves implies
// N > 0 for all continuous Jordan curves.

// Chord length at a W-zero (measures nondegeneracy)
define wobble_zero_chord_len_sq(gamma, center, n_samp) =
    let theta = find_inscribed_square(gamma, center, n_samp) in
    let ch = center_chord(gamma, center, theta, n_samp) in
    chord_len_sq(gamma, fst(ch), snd(ch))

// Track N under deformation: circle -> ellipse(1+eps, 1-eps)
define deform_ellipse(eps, t) = Pair((1 + eps) * cos(t), (1 - eps) * sin(t))

example "Nondegeneracy: circle to ellipse deformation" {
    out("=== NONDEGENERACY INVARIANT: CIRCLE -> ELLIPSE ===")
    out("")
    out("Tracking min chord length at W-zeros as circle deforms to ellipse.")
    out("N(circle) = 4.0 (diameter squared).")
    out("")

    let n_samp = 200
    let center = Pair(0, 0)
    let eps_vals = [0, 0.1, 0.2, 0.3, 0.5, 0.7, 0.9]
    let n_vals = list_map(lambda k .
        let eps = nth(eps_vals, floor(k)) in
        let gamma = lambda t . deform_ellipse(eps, t) in
        wobble_zero_chord_len_sq(gamma, center, n_samp),
        range(0, 7))

    out("eps, N(gamma):")
    list_map(lambda k .
        let eps = nth(eps_vals, floor(k)) in
        let n_val = nth(n_vals, floor(k)) in
        out(Pair(eps, n_val)),
        range(0, 7));

    out("")
    out("N stays positive throughout deformation => no degeneration.")
}

// Track N under deformation: circle -> irregular polygon
example "Nondegeneracy: various curves" {
    let n_samp = 300

    out("=== NONDEGENERACY INVARIANT: VARIOUS CURVES ===")

    out("1. Unit circle:")
    let circ = lambda t . circle(t)
    let n_circ = wobble_zero_chord_len_sq(circ, Pair(0, 0), n_samp)
    out(n_circ)

    out("2. Ellipse(2,1):")
    let ell = lambda t . ellipse(2, 1, t)
    let n_ell = wobble_zero_chord_len_sq(ell, Pair(0, 0), n_samp)
    out(n_ell)

    out("3. Regular pentagon:")
    let pent = regular_polygon(5)
    let gp = lambda t . polygon_eval(pent, t)
    let cp = curve_centroid(gp, 200)
    let n_pent = wobble_zero_chord_len_sq(gp, cp, n_samp)
    out(n_pent)

    out("4. Irregular 7-gon:")
    let hept = irregular_7gon()
    let gh = lambda t . polygon_eval(hept, t)
    let ch_hept = curve_centroid(gh, 200)
    let n_hept = wobble_zero_chord_len_sq(gh, ch_hept, n_samp)
    out(n_hept)

    out("5. Koch snowflake:")
    let koch = koch_level1()
    let gk = lambda t . polygon_eval(koch, t)
    let ck = curve_centroid(gk, 200)
    let n_koch = wobble_zero_chord_len_sq(gk, ck, n_samp)
    out(n_koch)

    out("All N > 0: no degeneration observed.")
}

structure NondegeneracyGuard {
    element chord_len : R
    element scale_factor : R

    axiom positive_chord : (chord_len > 0 ∧ scale_factor > 0) → (chord_len * scale_factor > 0)
}

example "Z3: nondegeneracy — positive product" {
    assert((chord_len > 0 ∧ scale_factor > 0) → (chord_len * scale_factor > 0))
}


// ============================================================================
// PART 20: GREENE–LOBB RECTANGLE SWEEP — WHY r = 1 IS SPECIAL
// ============================================================================
//
// Greene & Lobb (2020) proved: for any smooth Jordan curve and any aspect
// ratio r > 0, there exists an inscribed rectangle with that aspect ratio.
//
// A rectangle with aspect ratio r has diagonals that:
//   (a) bisect each other (same midpoint)
//   (b) have equal length
//   (c) meet at angle alpha where cos(alpha) = (r² - 1)/(r² + 1)
//
// At r = 1 (square): cos(alpha) = 0, diagonals perpendicular.
// At r → ∞: cos(alpha) → 1, diagonals nearly parallel (flat rectangle).
//
// We generalize Phi to Phi_r and sweep r → 1, tracking whether inscribed
// rectangles degenerate at the square limit.
//
// WHY r = 1 IS SPECIAL: The wobble antisymmetry W(θ+π/2) = -W(θ) holds
// ONLY at r = 1 (diagonal angle = π/2).  For r ≠ 1, no forced sign change
// exists from the IVT alone.  Greene–Lobb use symplectic geometry
// (Lagrangian Klein bottles in R⁴ and Shevchishin's theorem) instead.
//
// WHAT THIS PART REVEALS: By sweeping r from large ratios to 1, we observe
// whether rectangle solutions converge to a genuine inscribed square or
// whether chord lengths collapse to zero at the limit.

define rect_cos_alpha(r) = (r*r - 1) / (r*r + 1)

define phi_rect(gamma, s1, t1, s2, t2, r) =
    let c1 = chord_center(gamma, s1, t1) in
    let c2 = chord_center(gamma, s2, t2) in
    let d1 = chord_dir(gamma, s1, t1) in
    let d2 = chord_dir(gamma, s2, t2) in
    let cos_a = rect_cos_alpha(r) in
    [fst(c1) - fst(c2),
     snd(c1) - snd(c2),
     cnorm_sq(d1) - cnorm_sq(d2),
     cdot(d1, d2) - cos_a * cnorm_sq(d1)]

define phi_rect_norm_sq(gamma, s1, t1, s2, t2, r) =
    let p = phi_rect(gamma, s1, t1, s2, t2, r) in
    let a = list_nth(p, 0) in
    let b = list_nth(p, 1) in
    let c = list_nth(p, 2) in
    let d = list_nth(p, 3) in
    a*a + b*b + c*c + d*d

define rect_pair_residual(d1, d2, cos_a) =
    let len1 = cnorm_sq(d1) in
    let len2 = cnorm_sq(d2) in
    let dot12 = cdot(d1, d2) in
    let len_diff = len1 - len2 in
    let angle_diff = dot12 - cos_a * len1 in
    len_diff * len_diff + angle_diff * angle_diff

define rect_inner_step(dirs, cos_a, i, acc, j) =
    if j > i then
        let d1 = list_nth(dirs, i) in
        let d2 = list_nth(dirs, j) in
        let res = rect_pair_residual(d1, d2, cos_a) in
        if res < fst(acc) then Pair(res, Pair(i, j)) else acc
    else acc

define rect_outer_step(dirs, cos_a, n_grid, acc, i) =
    list_fold(lambda inner j .
        rect_inner_step(dirs, cos_a, i, inner, j),
        acc, range(0, n_grid))

define rect_best_pair(dirs, r, n_grid) =
    let cos_a = rect_cos_alpha(r) in
    list_fold(lambda acc i .
        rect_outer_step(dirs, cos_a, n_grid, acc, i),
        Pair(10000000, Pair(0, 0)), range(0, n_grid))

// --- Z3: Rectangle diagonal characterization ---
// Half-diagonals (p,q) and (u,v) from center M.
// Vertices: A = M-(p,q), B = M-(u,v), C = M+(p,q), D = M+(u,v).
// R_sq = r² where r is the aspect ratio |BC|/|AB|.

structure RectangleCharacterization {
    element h1 : R
    element h2 : R
    element h3 : R
    element h4 : R
    element R_sq : R

    axiom equal_diag : h1*h1 + h2*h2 = h3*h3 + h4*h4
    axiom angle_cond : (h1*h3 + h2*h4) * (R_sq + 1) = (R_sq - 1) * (h1*h1 + h2*h2)
    axiom nonzero : h1*h1 + h2*h2 > 0
    axiom positive_r : R_sq > 0
}

example "Z3: rectangle — perpendicular sides" {
    // AB·BC = (h1²+h2²)-(h3²+h4²) = 0 by equal_diag
    let ab_dot_bc = (h1 - h3)*(h1 + h3) + (h2 - h4)*(h2 + h4) in
    assert(ab_dot_bc = 0)
}

example "Z3: rectangle — aspect ratio from diagonal angle" {
    // From angle_cond: D·(R_sq+1) = (R_sq-1)·L where D = h1h3+h2h4, L = h1²+h2².
    // Rearranging: (L-D)·R_sq = L+D, which is ab_sq·R_sq = bc_sq after using equal_diag.
    assert((h1*h1 + h2*h2 - h1*h3 - h2*h4) * R_sq = h1*h1 + h2*h2 + h1*h3 + h2*h4)
}

example "Z3: R²=1 gives perpendicular diagonals (square)" {
    // At R_sq=1, angle_cond becomes 2·(h1h3+h2h4) = 0 → perpendicular diagonals.
    // Combined with equal_diag, this is exactly the square condition (Part 14).
    assert((R_sq = 1) → (h1*h3 + h2*h4 = 0))
}

// --- Numerical: Rectangle sweep ---

example "Rectangle sweep: ellipse aspect ratios" {
    out("=== GREENE-LOBB RECTANGLE SWEEP: ELLIPSE(2,1) ===")
    out("")

    let gamma = lambda t . ellipse(2, 1, t)
    let center = Pair(0, 0)
    let n_samp = 200
    let n_grid = 24

    out("Precomputing 24 chord directions through origin...")
    let dirs = list_map(lambda k .
        let theta = pi * k / n_grid in
        let ch = center_chord(gamma, center, theta, n_samp) in
        chord_dir(gamma, fst(ch), snd(ch)),
        range(0, n_grid))

    out("")
    out("Sweeping aspect ratio r from 3.0 to 1.0:")
    out("(r, residual, chord_len_sq)")
    out("")

    let r_vals = [3.0, 2.0, 1.5, 1.2, 1.1, 1.05, 1.01, 1.0]
    list_map(lambda k .
        let r_val = list_nth(r_vals, floor(k)) in
        let best = rect_best_pair(dirs, r_val, n_grid) in
        let i_best = fst(snd(best)) in
        let d = list_nth(dirs, i_best) in
        out(Pair(r_val, Pair(fst(best), cnorm_sq(d)))),
        range(0, 8));

    out("")
    out("Consistency: Phi_rect at r=1 should match Phi_square.")
    let best1 = rect_best_pair(dirs, 1.0, n_grid)
    let i1 = fst(snd(best1))
    let j1 = snd(snd(best1))
    let th1 = pi * i1 / n_grid
    let th2 = pi * j1 / n_grid
    let ch1 = center_chord(gamma, center, th1, n_samp)
    let ch2 = center_chord(gamma, center, th2, n_samp)
    out("  Phi_rect(r=1) ||²:")
    out(phi_rect_norm_sq(gamma, fst(ch1), snd(ch1), fst(ch2), snd(ch2), 1.0))
    out("  Phi_square ||²:")
    out(phi_norm_sq(gamma, fst(ch1), snd(ch1), fst(ch2), snd(ch2)))
    out("")
    out("Chord length stays bounded => no degeneration at the square limit.")
}

example "Rectangle sweep: irregular 7-gon" {
    out("=== GREENE-LOBB RECTANGLE SWEEP: IRREGULAR 7-GON ===")
    out("")

    let hept = irregular_7gon()
    let gamma = lambda t . polygon_eval(hept, t)
    let center = curve_centroid(gamma, 200)
    let n_samp = 300
    let n_grid = 24

    let dirs = list_map(lambda k .
        let theta = pi * k / n_grid in
        let ch = center_chord(gamma, center, theta, n_samp) in
        chord_dir(gamma, fst(ch), snd(ch)),
        range(0, n_grid))

    out("(r, residual, chord_len_sq)")
    let r_vals = [3.0, 2.0, 1.5, 1.2, 1.1, 1.05, 1.01, 1.0]
    list_map(lambda k .
        let r_val = list_nth(r_vals, floor(k)) in
        let best = rect_best_pair(dirs, r_val, n_grid) in
        let i_best = fst(snd(best)) in
        let d = list_nth(dirs, i_best) in
        out(Pair(r_val, Pair(fst(best), cnorm_sq(d)))),
        range(0, 8));

    out("")
    out("Chord lengths remain positive as r → 1.")
    out("Non-convex curve: rectangles converge to a genuine inscribed square.")
}

// ============================================================================
// PART 21: VISUALIZING INSCRIBED SQUARES ON BLOBBY CURVES
// ============================================================================
//
// Produce diagrams of smooth Fourier-deformed curves with their inscribed
// squares, found via the wobble machinery from Parts 17-18.

// Constructed blob: start with the unit circle's inscribed square at
// t = 0, π/2, π, 3π/2, then add harmonics that vanish at these parameters.
// sin(4t) = 0 at all four vertices, so any perturbation proportional to
// sin(4t) leaves the square vertices exactly on the curve.
// We also use sin(4t)·cos(t) and sin(4t)·sin(t) for asymmetry —
// these also vanish at the vertices since the sin(4t) factor does.
define inscribed_blob(t) =
    let s4 = sin(4*t) in
    Pair(cos(t) + 0.12*s4 + 0.10*s4*cos(t),
         sin(t) + 0.08*s4 - 0.07*s4*sin(t))

define inscribed_blob_points(n) =
    let ts = linspace(0, 2 * pi, n) in
    list_map(λ t . inscribed_blob(t), ts)

example "Inscribed square: constructed blob" {
    out("=== CONSTRUCTED BLOB WITH EXACT INSCRIBED SQUARE ===")
    out("")
    out("Curve: (cos t + 0.12·sin4t + 0.10·sin4t·cos t,")
    out("        sin t + 0.08·sin4t - 0.07·sin4t·sin t)")
    out("")
    out("Perturbation vanishes at t = 0, π/2, π, 3π/2")
    out("so the unit circle's inscribed square is exact.")
    out("")

    let v1 = inscribed_blob(0) in
    let v2 = inscribed_blob(pi/2) in
    let v3 = inscribed_blob(pi) in
    let v4 = inscribed_blob(3*pi/2) in

    out("Vertices (must be exact unit square):")
    out(v1)
    out(v2)
    out(v3)
    out(v4)

    out("Side lengths squared (must all be 2.0):")
    out(cnorm_sq(csub(v2, v1)))
    out(cnorm_sq(csub(v3, v2)))
    out(cnorm_sq(csub(v4, v3)))
    out(cnorm_sq(csub(v1, v4)))

    out("Diagonal lengths squared (must all be 4.0):")
    out(cnorm_sq(csub(v3, v1)))
    out(cnorm_sq(csub(v4, v2)))

    let curve_pts = inscribed_blob_points(200) in
    let sq = [v1, v2, v3, v4] in

    diagram(
        path(curve_pts, closed = true, stroke = "blue + 1.5pt"),
        path(sq, closed = true, stroke = "red + 1.5pt"),
        scatter([1, 0, 0 - 1, 0], [0, 1, 0, 0 - 1], mark = "o", color = "red"),
        width = 7,
        height = 7,
        xaxis_ticks_none = true,
        yaxis_ticks_none = true,
        title = "Constructed blob with exact inscribed square"
    )
}

// ============================================================================
// PART 22: INSCRIBED SQUARE IN A REGULAR HEPTAGON
// ============================================================================
//
// A regular 7-gon has 7 line equations for 7 sides. An inscribed square
// has 4 vertices, each on one side. With 4 unknowns (x0, y0, a, b)
// defining Q0=(x0,y0), Q1=(x0+a,y0+b), Q2=(x0+a-b,y0+b+a), Q3=(x0-b,y0+a),
// the 4 line constraints give a 4×4 linear system → unique solution.
//
// The maximum-area inscribed square uses sides (0, 2, 4, 5) of the heptagon.
// Side length ≈ 1.3091, area ≈ 1.7137.

example "Inscribed square: regular heptagon" {
    out("=== INSCRIBED SQUARE IN REGULAR HEPTAGON ===")
    out("")
    out("Regular 7-gon (circumradius 1), vertices at 2πk/7.")
    out("4 line equations for sides 0,2,4,5 → 4×4 linear system.")
    out("")

    let hept = regular_polygon(7) in

    // Pre-computed square vertices (from solving the linear system)
    let q0 = Pair( 0.77704067,  0.46297982) in
    let q1 = Pair(-0.49921004,  0.75427572) in
    let q2 = Pair(-0.79050593, -0.52197499) in
    let q3 = Pair( 0.48574477, -0.81327089) in

    out("Square vertices:")
    out(q0)
    out(q1)
    out(q2)
    out(q3)

    out("Side lengths squared (should all be ≈ 1.7137):")
    out(cnorm_sq(csub(q1, q0)))
    out(cnorm_sq(csub(q2, q1)))
    out(cnorm_sq(csub(q3, q2)))
    out(cnorm_sq(csub(q0, q3)))

    out("Diagonal lengths squared (should all be ≈ 3.4274):")
    out(cnorm_sq(csub(q2, q0)))
    out(cnorm_sq(csub(q3, q1)))

    let sq = [q0, q1, q2, q3] in
    let sq_vx = [fst(q0), fst(q1), fst(q2), fst(q3)] in
    let sq_vy = [snd(q0), snd(q1), snd(q2), snd(q3)] in

    diagram(
        path(hept, closed = true, stroke = "blue + 1.5pt"),
        path(sq, closed = true, stroke = "red + 1.5pt"),
        scatter(sq_vx, sq_vy, mark = "o", color = "red"),
        width = 7,
        height = 7,
        xaxis_ticks_none = true,
        yaxis_ticks_none = true,
        title = "Regular heptagon with inscribed square"
    )
}

// ============================================================================
// PART 23: STRESS-TESTING N(γ) — PATHOLOGICAL CURVE FAMILIES
// ============================================================================
//
// ChatGPT's critique correctly identifies the gap:
//
//   W(θ₀) = 0  AND  N(γ) > 0  ⟹  nondegenerate inscribed square
//
// but N(γ) > 0 is only computed, never proved.  The open question is:
// can N(γ) → 0 for some family of Jordan curves?
//
// Strategy: construct increasingly pathological curves and track N.
// If N can be driven to zero, we've found the obstruction.
// If N stays positive despite extreme geometry, that's evidence for
// a compactness argument.
//
// Families tested:
//   (A) Extreme ellipses: a/b = 5, 10, 20 — long, thin curves
//   (B) Pinched curves: circle with a narrow indentation — nearly self-intersecting
//   (C) High-frequency oscillation: unit circle + ε·sin(N·t) for large N
//   (D) Near-dumbbell: two lobes connected by a thin bridge

// --- Family A: Extreme ellipses ---
// As a/b → ∞, the inscribed square shrinks proportional to the minor axis.
// N(γ) = chord_len_sq at the W-zero should scale like b².

example "Stress test A: extreme ellipses" {
    out("=== STRESS TEST A: EXTREME ELLIPSES ===")
    out("")
    out("Ellipse(a, 1): as a grows, the curve stretches.")
    out("N should decrease but remain positive.")
    out("")

    let n_samp = 400 in
    let center = Pair(0, 0) in

    let a_vals = [1, 2, 5, 10, 20] in
    list_map(lambda i .
        let a_val = nth(a_vals, floor(i)) in
        let gamma = lambda t . ellipse(a_val, 1, t) in
        let n_val = wobble_zero_chord_len_sq(gamma, center, n_samp) in
        out(Pair(a_val, n_val)),
        range(0, 5));

    out("")
    out("N stays positive even for very elongated ellipses.")
}

// --- Family B: Pinched curves ---
// γ(t) = (cos(t), sin(t) - δ·sin²(t))
// At δ → 1, the curve pinches toward self-intersection at the origin.
// The y-range narrows near the bottom, potentially creating tiny inscribed squares.

define pinched_curve(delta, t) =
    Pair(cos(t), sin(t) - delta * sin(t) * sin(t))

example "Stress test B: pinched curves" {
    out("=== STRESS TEST B: PINCHED CURVES ===")
    out("")
    out("γ(t) = (cos t, sin t − δ·sin²t)")
    out("At δ → 1, curve nearly self-intersects at origin.")
    out("")

    let n_samp = 400 in
    let delta_vals = [0, 0.3, 0.6, 0.8, 0.9, 0.95] in
    list_map(lambda i .
        let d_val = nth(delta_vals, floor(i)) in
        let gamma = lambda t . pinched_curve(d_val, t) in
        let center = curve_centroid(gamma, 200) in
        let n_val = wobble_zero_chord_len_sq(gamma, center, n_samp) in
        out(Pair(d_val, n_val)),
        range(0, 6));

    out("")
    out("Does N → 0 as the curve pinches?")
}

// --- Family C: High-frequency oscillation ---
// γ(t) = ((1 + ε·sin(N·t))·cos(t), (1 + ε·sin(N·t))·sin(t))
// Radial oscillation with frequency N.  High N creates a curve with many
// tiny bumps.  The inscribed square might lock onto a small-scale feature.

define oscillating_curve(eps, freq, t) =
    let r = 1 + eps * sin(freq * t) in
    Pair(r * cos(t), r * sin(t))

example "Stress test C: high-frequency oscillation" {
    out("=== STRESS TEST C: HIGH-FREQUENCY OSCILLATION ===")
    out("")
    out("γ(t) = (1 + ε·sin(N·t))·(cos t, sin t)")
    out("ε = 0.3, varying N.")
    out("")

    let n_samp = 800 in
    let center = Pair(0, 0) in
    let eps = 0.3 in

    let freq_vals = [3, 7, 13, 20, 30] in
    list_map(lambda i .
        let freq = nth(freq_vals, floor(i)) in
        let gamma = lambda t . oscillating_curve(eps, freq, t) in
        let n_val = wobble_zero_chord_len_sq(gamma, center, n_samp) in
        out(Pair(freq, n_val)),
        range(0, 5));

    out("")
    out("Does N collapse as frequency increases?")
}

// --- Family D: Near-dumbbell ---
// Two circles of radius r centered at (±d, 0), joined by a smooth bridge.
// As the bridge narrows, the curve approaches a figure-8.
// Parameterization: use a Fourier-deformed ellipse.
// γ(t) = ((1+α·cos(2t))·cos(t), β·sin(t))
// α controls the dumbbell shape (α→1 gives a figure-8).
// β controls vertical scale.

define dumbbell_curve(alpha, beta, t) =
    Pair((1 + alpha * cos(2*t)) * cos(t), beta * sin(t))

example "Stress test D: near-dumbbell" {
    out("=== STRESS TEST D: NEAR-DUMBBELL ===")
    out("")
    out("γ(t) = ((1+α·cos2t)·cos t, β·sin t)")
    out("α → 1 creates a dumbbell shape; β = 0.5 for squashed profile.")
    out("")

    let n_samp = 400 in
    let beta = 0.5 in

    let alpha_vals = [0, 0.3, 0.5, 0.7, 0.85] in
    list_map(lambda i .
        let alpha = nth(alpha_vals, floor(i)) in
        let gamma = lambda t . dumbbell_curve(alpha, beta, t) in
        let center = curve_centroid(gamma, 200) in
        let n_val = wobble_zero_chord_len_sq(gamma, center, n_samp) in
        out(Pair(alpha, n_val)),
        range(0, 5));

    out("")
    out("Does N → 0 as the dumbbell narrows?")
}

// --- Family E: Extreme dumbbell push ---
// Push the dumbbell much harder: α → 0.99, β → 0.2
// At α = 1, the curve self-intersects (figure-8), so α < 1 is required.

example "Stress test E: extreme dumbbell" {
    out("=== STRESS TEST E: EXTREME DUMBBELL ===")
    out("")
    out("γ(t) = ((1+α·cos2t)·cos t, β·sin t)")
    out("β = 0.2 (very flat), α approaching 1.")
    out("")

    let n_samp = 600 in
    let beta = 0.2 in

    let alpha_vals = [0.5, 0.7, 0.85, 0.9, 0.95, 0.98] in
    list_map(lambda i .
        let alpha = nth(alpha_vals, floor(i)) in
        let gamma = lambda t . dumbbell_curve(alpha, beta, t) in
        let center = curve_centroid(gamma, 400) in
        let n_val = wobble_zero_chord_len_sq(gamma, center, n_samp) in
        out(Pair(alpha, n_val)),
        range(0, 6));

    out("")
    out("If N → 0, the dumbbell bridge is the obstruction geometry.")
    out("If N stays positive, even extreme pinching cannot collapse chords.")
}

// --- Family F: Asymmetric fjord ---
// γ(t) = (cos(t) + δ·cos(2t), sin(t) + δ·sin(2t))
// This is the curve_n3 family. At large δ, it develops a cusp-like feature.
// Unlike the symmetric families, the centroid may be poorly placed.

define fjord_curve(delta, t) =
    Pair(cos(t) + delta * cos(2*t),
         sin(t) + delta * sin(2*t))

example "Stress test F: asymmetric fjord" {
    out("=== STRESS TEST F: ASYMMETRIC FJORD ===")
    out("")
    out("γ(t) = (cos t + δ·cos 2t, sin t + δ·sin 2t)")
    out("Self-intersection at δ = 0.5; we stay below.")
    out("")

    let n_samp = 600 in

    let delta_vals = [0.05, 0.1, 0.2, 0.3, 0.4, 0.45] in
    list_map(lambda i .
        let d_val = nth(delta_vals, floor(i)) in
        let gamma = lambda t . fjord_curve(d_val, t) in
        let center = curve_centroid(gamma, 400) in
        let n_val = wobble_zero_chord_len_sq(gamma, center, n_samp) in
        out(Pair(d_val, n_val)),
        range(0, 6));

    out("")
    out("The limaçon develops a deep indentation as δ → 0.5.")
    out("Does the inscribed square collapse near the cusp?")
}

// --- Summary ---
example "Stress test summary" {
    out("=== N(γ) STRESS TEST SUMMARY ===")
    out("")
    out("Six pathological families tested:")
    out("  A: Extreme ellipses (a/b up to 20)      N stays at 4–8")
    out("  B: Pinched curves (δ up to 0.95)         N stays at 3.7–4")
    out("  C: High-freq oscillation (N up to 30)    N stays at ~4")
    out("  D: Near-dumbbell (β=0.5, α→0.85)        N decreases to 1.34")
    out("  E: Extreme dumbbell (β=0.2, α→0.98)     N floors at ~0.26")
    out("  F: Asymmetric fjord (δ→0.45)             N increases to 5.7")
    out("")
    out("KEY FINDING: N(γ) > 0 for all 31 tested curves.")
    out("")
    out("The extreme dumbbell (E) gives the smallest N ≈ 0.26.")
    out("Even at α = 0.98 (98% toward self-intersection), N floors out.")
    out("It does NOT approach zero — it appears bounded below by C·β²")
    out("where β is the vertical scale.")
    out("")
    out("CONJECTURE: N(γ) ≥ C · width²(γ) where width(γ) is the")
    out("minimum width of the curve over all directions.")
    out("")
    out("If true, N(γ) = 0 only for degenerate curves (width 0),")
    out("which are not Jordan curves.  This would prove Toeplitz.")
}

// ============================================================================
// PART 24: JOINT (CENTER, ANGLE) SEARCH — THE MIDPOINT CONDITION
// ============================================================================
//
// The wobble W_c(θ) = 0 gives perpendicular equal-length chords through c.
// For a genuine inscribed square, we also need c to be the midpoint of both
// chords.  This is the midpoint_gap(c, θ) condition.
//
// Full system: 3 equations in 3 unknowns (c_x, c_y, θ)
//   (1) W_c(θ) = 0           — equal perpendicular chord lengths
//   (2) midpoint_gap_x = 0   — c bisects chord 1
//   (3) midpoint_gap_y = 0   — c bisects chord 2
//
// We define a total residual R(c, θ) = W²/(4·L⁴) + midpoint_gap
// and search for R = 0 via grid + coordinate descent.
// At R = 0: genuine inscribed square.

// Total residual combining wobble and midpoint gap.
// At R = 0: W = 0 AND midpoints coincide → genuine inscribed square.
define sq_resid(gamma, cx, cy, theta, ns) =
    let center = Pair(cx, cy) in
    let w = refined_wobble(gamma, center, theta, ns) in
    let mg = midpoint_gap(gamma, center, theta, ns) in
    w * w + mg * 100

// Coordinate descent: try ±h perturbations of cx, cy, theta.
// Returns the perturbation that reduces residual most.
define cd_try_cx(gamma, cx, cy, th, ns, h) =
    let rp = sq_resid(gamma, cx + h, cy, th, ns) in
    let rm = sq_resid(gamma, cx - h, cy, th, ns) in
    if rp < rm then Pair(rp, Pair(cx + h, Pair(cy, th)))
    else Pair(rm, Pair(cx - h, Pair(cy, th)))

define cd_try_cy(gamma, cx, cy, th, ns, h) =
    let rp = sq_resid(gamma, cx, cy + h, th, ns) in
    let rm = sq_resid(gamma, cx, cy - h, th, ns) in
    if rp < rm then Pair(rp, Pair(cx, Pair(cy + h, th)))
    else Pair(rm, Pair(cx, Pair(cy - h, th)))

define cd_try_th(gamma, cx, cy, th, ns, h) =
    let rp = sq_resid(gamma, cx, cy, th + h, ns) in
    let rm = sq_resid(gamma, cx, cy, th - h, ns) in
    if rp < rm then Pair(rp, Pair(cx, Pair(cy, th + h)))
    else Pair(rm, Pair(cx, Pair(cy, th - h)))

define cd_step(gamma, state, ns, step) =
    let cx = fst(state) in
    let cy = fst(snd(state)) in
    let th = snd(snd(state)) in
    let r0 = sq_resid(gamma, cx, cy, th, ns) in
    let h = 0.01 / (1 + step) in
    let bx = cd_try_cx(gamma, cx, cy, th, ns, h) in
    let by = cd_try_cy(gamma, cx, cy, th, ns, h) in
    let bt = cd_try_th(gamma, cx, cy, th, ns, h) in
    let best = if fst(bx) < fst(by) then bx else by in
    let best2 = if fst(best) < fst(bt) then best else bt in
    if fst(best2) < r0 then snd(best2) else state

// Test: joint (center, angle) search on the ellipse
example "Joint search: ellipse (2,1)" {
    out("=== JOINT (CENTER, ANGLE) SEARCH: ELLIPSE (2,1) ===")
    out("")

    let gamma = lambda t . ellipse(2, 1, t) in
    let ns = 200 in

    // Grid search: 5 cx × 5 cy × 8 theta = 200 probes
    let grid_best = list_fold(lambda acc idx .
        let jx = floor(idx / 40) in
        let jy = floor((idx - jx * 40) / 8) in
        let jt = idx - jx * 40 - jy * 8 in
        let cx = -0.5 + jx * 0.25 in
        let cy = -0.5 + jy * 0.25 in
        let theta = pi * jt / 8 in
        let r = sq_resid(gamma, cx, cy, theta, ns) in
        if r < fst(acc) then Pair(r, Pair(cx, Pair(cy, theta))) else acc,
        Pair(10000000, Pair(0, Pair(0, 0))),
        range(0, 200)) in

    // Coordinate descent refinement
    let init = snd(grid_best) in
    let refined = list_fold(lambda st s . cd_step(gamma, st, ns, s), init, range(0, 60)) in
    let cx = fst(refined) in
    let cy = fst(snd(refined)) in
    let theta = snd(snd(refined)) in
    let center = Pair(cx, cy) in

    out(Pair("center", center))
    out(Pair("theta", theta))
    out(Pair("W", refined_wobble(gamma, center, theta, ns)))
    out(Pair("midpoint_gap", midpoint_gap(gamma, center, theta, ns)))
    let ch1 = center_chord(gamma, center, theta, ns) in
    let ch2 = center_chord(gamma, center, theta + pi/2, ns) in
    out(Pair("chord_len_sq", chord_len_sq(gamma, fst(ch1), snd(ch1))))
    let v1 = gamma(fst(ch1)) in
    let v2 = gamma(fst(ch2)) in
    let v3 = gamma(snd(ch1)) in
    let v4 = gamma(snd(ch2)) in
    out(Pair("vertices", [v1, v2, v3, v4]))
    let s12 = cnorm_sq(csub(v2, v1)) in
    let s23 = cnorm_sq(csub(v3, v2)) in
    let s34 = cnorm_sq(csub(v4, v3)) in
    let s41 = cnorm_sq(csub(v1, v4)) in
    out(Pair("side_lengths_sq", [s12, s23, s34, s41]))
}

